-- 2026-07-09 vocab pushdown: the foundry read every consensus row of a type
-- over the wire so the client could keep the ~1% whose endpoints are in the
-- synthesis vocab (12 relation heads = 27.5M rows scanned, 358K kept, 550s of a
-- 608s synthesis). p_vocab probes consensus_type_subject_btree instead; the type
-- id is resolved into a local FIRST (a variable is a bound parameter and
-- therefore an index condition — Rule #4; a function call in the qual is
-- not, lesson L12).
DROP FUNCTION IF EXISTS relation_plane(text, text, int);
CREATE OR REPLACE FUNCTION relation_plane(p_family text, p_name text, p_arg int DEFAULT NULL,
        p_vocab bytea[] DEFAULT NULL)
    RETURNS TABLE(subject_id bytea, object_id bytea, w double precision)
    LANGUAGE plpgsql VOLATILE
    SET search_path = @extschema@, public AS $$
DECLARE
    g int;
    v_type bytea;
BEGIN
    IF p_family = 'consensus' THEN
        v_type := relation_type_id(p_name);
        IF p_vocab IS NULL THEN
            RETURN QUERY
            SELECT c.subject_id, c.object_id,
                   (eff_mu(c.rating, c.rd) - glicko2_neutral_mu())::double precision / 1e9
            FROM consensus c
            WHERE c.type_id = v_type AND c.object_id IS NOT NULL;
        ELSE
            RETURN QUERY
            WITH v(id) AS (SELECT DISTINCT u FROM unnest(p_vocab) AS u)
            SELECT c.subject_id, c.object_id,
                   (eff_mu(c.rating, c.rd) - glicko2_neutral_mu())::double precision / 1e9
            FROM v
            JOIN consensus c ON c.type_id = v_type AND c.subject_id = v.id
            JOIN v vo ON vo.id = c.object_id
            WHERE c.object_id IS NOT NULL;
        END IF;
        RETURN;
    END IF;

    IF p_family <> 'traj' THEN
        RAISE EXCEPTION 'relation_plane: unknown family % (consensus | traj)', p_family;
    END IF;

    g := CASE p_name
             WHEN 'next'   THEN 1
             WHEN 'gap'    THEN COALESCE(p_arg, 1)
             WHEN 'window' THEN COALESCE(p_arg, 4)
             ELSE NULL
         END;
    IF g IS NULL THEN
        RAISE EXCEPTION 'relation_plane: unknown traj plane % (next | gap | window)', p_name;
    END IF;

    IF p_name = 'window' THEN
        RETURN QUERY
        SELECT t.subject_id, t.object_id, t.cnt::double precision / t.subject_total
        FROM trajectory_cooccurrence(g) t;
        RETURN;
    END IF;

    -- next/gap: read the maintained trajectory_pairs table instead of re-running
    -- the whole-corpus stride scan and discarding every gap but g (the old
    -- `FROM trajectory_cooccurrence_by_stride(g) WHERE gap = g` computed gaps
    -- 1..g and kept 1/g of the pairs, every call). Row parity: trajectory_pairs
    -- stores exactly trajectory_cooccurrence_by_stride's output, and its
    -- subject_total partitions by (subject_id, gap), so gap = g rows are
    -- identical whether the table was built with max_gap = g or larger; the
    -- ensure guard rebuilds only when the trajectory corpus fingerprint moved.
    PERFORM trajectory_pairs_ensure(g);
    RETURN QUERY
    SELECT t.subject_id, t.object_id, t.cnt::double precision / t.subject_total
    FROM trajectory_pairs t WHERE t.gap = g;
END;
$$;
