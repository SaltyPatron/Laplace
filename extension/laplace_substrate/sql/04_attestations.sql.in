/* 04_attestations.sql.in — the EVIDENCE layer. EVIDENCE IS PROVENANCE.
 *
 * Each row records THAT a witness witnessed: which relation (subject, type,
 * object), which source, which circuit instance (context = the model
 * layer/head witness entity), when, how many games, and whether it confirmed
 * or refuted (outcome — a CLASS, never a magnitude).
 *
 * It is NEVER a value channel: the witness's magnitude is testimony, consumed
 * into the consensus accumulation AT INGEST (the writer's period partials →
 * materialize_period_consensus) and not persisted. A stored per-witness score
 * is mathematically invertible to the weight — recording raw weights wearing
 * the evidence layer as a costume — and is banned. The accumulated Glicko-2
 * state (rating/rd/volatility) lives on the `consensus` table (one row per
 * (subject, type, object), source + context out of identity).
 *
 * id is content-addressed BLAKE3-128 of the 5-tuple — stable across re-
 * observation; repeated assertions are UPSERT-no-op idempotent (R5). */

/* Uniqueness = the content-addressed id ALONE. id IS the canonical hash of
 * the 5-tuple (every writer routes through AttestationFactory.ComputeId), so
 * a second UNIQUE over (subject, type, object, source, context) restated the
 * same invariant at a measured 144 B/row — at model-evidence scale (~params
 * rows) that is hundreds of GB of duplication. Identity is content; the PK
 * is the law. */
CREATE TABLE attestations (
    id                bytea         PRIMARY KEY CHECK (octet_length(id) = 16),
    subject_id        bytea         NOT NULL REFERENCES entities(id),
    type_id           bytea         NOT NULL REFERENCES entities(id),
    object_id         bytea                  REFERENCES entities(id),
    source_id         bytea         NOT NULL REFERENCES entities(id),
    context_id        bytea                  REFERENCES entities(id),
    outcome           smallint      NOT NULL CHECK (outcome IN (0, 1, 2)),
    last_observed_at  timestamptz   NOT NULL,
    observation_count bigint        NOT NULL DEFAULT 1 CHECK (observation_count >= 0)
);

COMMENT ON TABLE attestations IS
    'EVIDENCE layer = PROVENANCE: one row per (subject, type, object, source, context) recording WHO witnessed the relation (model layer/head in context_id), when, how many games, and the dissent record (outcome class). Never a value channel — the witness''s magnitude is consumed into the consensus accumulation at ingest and not persisted. The accumulated rating/rd/volatility live on the consensus table. Repeated assertions are UPSERT-no-op idempotent.';

COMMENT ON COLUMN attestations.id IS
    'Content-addressed BLAKE3-128 of canonical (subject_id, type_id, object_id, source_id, context_id) bytes. Stable across re-observation; same tuple -> same id regardless of insertion order.';
COMMENT ON COLUMN attestations.type_id IS
    'FK to entities(id) -- the kind entity (typed transform vocabulary). Kind significance enters the consensus match as kind_rank inside the witness weight, NOT as a tier on the kind and NOT as a persisted value here.';
COMMENT ON COLUMN attestations.outcome IS
    'The dissent record as a CLASS, never a magnitude: 0 = refute (the witness''s testimony was a loss), 1 = draw, 2 = confirm (a win). Derived from the sign of the testimony; the magnitude itself is consumed into consensus at ingest and never persisted.';

SELECT pg_extension_config_dump('attestations', '');
