-- converse_about(syn, lang): the REALIZE half of converse() -- weave prose for an
-- ALREADY-RESOLVED topic synset. Internal seam so callers that have already
-- oriented (chat() resolves its topic once per turn) do not pay converse()'s
-- prompt re-segmentation + band-mass re-orientation just to describe a synset
-- they hold in hand.
--
-- The facts come from converse_facts() -- the walk-driven fact engine (native
-- beam walk for the taxonomy chain, ranked consensus for the listings), each
-- row carrying provenance (eff_mu, witnesses, path). This wrapper is prose-only:
-- callers that want the provenance columns query converse_facts directly. The
-- 'web' arrow-chain row is a drill-down surface, not prose -- excluded here.
CREATE OR REPLACE FUNCTION converse_about(p_syn bytea, p_lang bytea DEFAULT NULL)
    RETURNS text
    LANGUAGE plpgsql STABLE
    SET search_path = @extschema@, public AS $$
DECLARE
    prose text;
    lbl   text;
BEGIN
    IF p_syn IS NULL THEN
        RETURN NULL;
    END IF;

    SELECT string_agg(f.sentence, ' ' ORDER BY f.ord)
      INTO prose
    FROM converse_facts(p_syn, p_lang)
         WITH ORDINALITY AS f(fact_kind, sentence, eff_mu, witnesses, path, types, ord)
    WHERE f.fact_kind <> 'web';

    IF prose IS NULL THEN
        lbl := realize(p_syn, p_lang);
        IF lbl IS NOT NULL THEN
            prose := 'The concept ' || lbl || ' is one I hold.';
        END IF;
    END IF;

    RETURN btrim(COALESCE(prose, ''));
END;
$$;
