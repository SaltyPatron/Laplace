-- Full population of entities.highway_mask via highway_mask_refresh, batched with a
-- COMMIT per batch (10M+ entities in one tx would bloat and lock). This is the
-- REGENERATE tool: run after any highway bit renumbering (adding a relation reorders
-- the alphabetical codegen) or to populate a generation seeded before the fold-time
-- refresh existed. Idempotent; safe to re-run and to interrupt (committed batches
-- persist).
--
-- SCAN SET (2026-07-21): drive the batches from the CANDIDATE set, not from every
-- entity. highway_mask_refresh derives a mask purely from consensus participation, so
-- an entity that appears in no consensus row can only ever resolve to NULL -- which is
-- already its stored value. The old loop walked all ~9M entities, paying two indexed
-- consensus probes each, and the ~7M tier-3/4 content rows were guaranteed no-ops.
-- Candidates are therefore:
--   (a) consensus participants (subject or object)  -- may gain or change a mask
--   (b) entities with a non-NULL mask today         -- may need one CLEARED after a
--       per-source evict removed their last governed edge
-- (b) keeps the "recompute-not-accumulate: idempotent, self-healing, no drift"
-- guarantee that a participants-only scan would quietly break, and costs one
-- sequential pass instead of the previous ~18 batched join passes.
--
-- PROGRESS (2026-07-21): RAISE LOG, not RAISE NOTICE. NOTICE is client-only -- with
-- log_min_messages at its WARNING default the old NOTICEs reached the server log
-- never, and any client that discards notices (the ingest writer does) made a
-- multi-minute rebuild look like a dead stall. LOG is the substrate law for
-- long-running folds: always emit LOG progress.
--
-- No SET clause on the procedure: a PL/pgSQL procedure carrying a SET clause is
-- barred from transaction control (COMMIT), so references are schema-qualified
-- instead. Invoke with: CALL @extschema@.highway_mask_rebuild();
CREATE OR REPLACE PROCEDURE highway_mask_rebuild(p_batch int DEFAULT 500000)
    LANGUAGE plpgsql AS $$
DECLARE
    last_id bytea := decode(repeat('00', 16), 'hex');
    ids bytea[];
    n bigint;
    total bigint := 0;
    scanned bigint := 0;
    candidates bigint;
    t0 timestamptz := clock_timestamp();
BEGIN
    -- Plain TEMP table (ON COMMIT PRESERVE ROWS): the per-batch COMMIT below would
    -- drop an ON COMMIT DROP table out from under the loop.
    DROP TABLE IF EXISTS _hmr_candidates;
    CREATE TEMP TABLE _hmr_candidates (id bytea PRIMARY KEY);

    INSERT INTO _hmr_candidates (id)
    SELECT c.subject_id FROM @extschema@.consensus c
    UNION
    SELECT c.object_id  FROM @extschema@.consensus c WHERE c.object_id IS NOT NULL
    UNION
    SELECT e.id FROM @extschema@.entities e WHERE e.highway_mask IS NOT NULL;
    GET DIAGNOSTICS candidates = ROW_COUNT;

    RAISE LOG 'highway_mask_rebuild: start — % mask candidates (consensus participants + already-masked)',
        candidates;
    COMMIT;

    LOOP
        SELECT array_agg(s.id ORDER BY s.id) INTO ids FROM (
            SELECT id FROM _hmr_candidates WHERE id > last_id ORDER BY id LIMIT p_batch) s;
        EXIT WHEN ids IS NULL;
        n := @extschema@.highway_mask_refresh(ids);
        total := total + n;
        scanned := scanned + cardinality(ids);
        last_id := ids[cardinality(ids)];
        RAISE LOG 'highway_mask_rebuild: % masks written / % of % candidates (%%) — %s elapsed',
            total, scanned, candidates,
            round(100.0 * scanned / NULLIF(candidates, 0), 1),
            round(extract(epoch FROM clock_timestamp() - t0)::numeric, 1);
        COMMIT;
    END LOOP;

    RAISE LOG 'highway_mask_rebuild: done — % masks written / % candidates in %s',
        total, scanned, round(extract(epoch FROM clock_timestamp() - t0)::numeric, 1);
    DROP TABLE IF EXISTS _hmr_candidates;
END $$;
