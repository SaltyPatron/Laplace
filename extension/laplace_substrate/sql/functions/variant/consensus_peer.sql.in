CREATE OR REPLACE FUNCTION consensus_peer(p_id bytea, p_k int DEFAULT 6)
    RETURNS bytea
    LANGUAGE plpgsql STABLE PARALLEL RESTRICTED
    SET search_path = @extschema@, public AS $$
DECLARE
    v_result bytea;
    v_type   bytea;
    v_coord  geometry;
    v_traj   geometry;
BEGIN
    -- Relational election: entities of p_id's own type that share p_id's
    -- (relation, partner) edges, scored by min-shared confidence. Reads through
    -- v_consensus_unrefuted (was two inline `NOT refuted` base-table scans). The
    -- winner is the top-p_k by score, then one picked by the deterministic
    -- hash tie-break -- identical to the old UNION's hash pick over `elected`.
    SELECT z.id INTO v_result
    FROM (
        SELECT x.id, sum(LEAST(m.mu, eff_mu(c2.rating, c2.rd))) AS score
        FROM (
            SELECT c.type_id AS rel,
                   CASE WHEN c.subject_id = p_id THEN c.object_id ELSE c.subject_id END AS partner,
                   (c.subject_id = p_id) AS as_subject,
                   eff_mu(c.rating, c.rd) AS mu
            FROM v_consensus_unrefuted c
            WHERE (c.subject_id = p_id OR c.object_id = p_id)
              AND c.object_id IS NOT NULL
        ) m
        JOIN v_consensus_unrefuted c2 ON c2.type_id = m.rel
          AND ((m.as_subject AND c2.object_id = m.partner AND c2.subject_id <> p_id)
            OR (NOT m.as_subject AND c2.subject_id = m.partner AND c2.object_id <> p_id))
        JOIN entities x
          ON x.id = CASE WHEN m.as_subject THEN c2.subject_id ELSE c2.object_id END
        JOIN entities self ON self.id = p_id AND x.type_id = self.type_id
        GROUP BY x.id
        ORDER BY score DESC
        LIMIT p_k
    ) z
    ORDER BY public.laplace_hash128_blake3(z.id || p_id)
    LIMIT 1;

    IF v_result IS NOT NULL THEN
        RETURN v_result;
    END IF;

    -- Geometric fallback -- only reached when the relational election is empty.
    -- As a single SQL statement this KNN was planned (and could run) on every
    -- call even when `elected` had rows, and its `me.coord` was a correlated
    -- FROM-subquery reference that could not drive the coord GiST index. Fetch
    -- the anchor into locals first so the ordering operand is a genuine bound
    -- parameter, and gate the whole branch behind the election miss.
    SELECT e.type_id, p.coord, p.trajectory
      INTO v_type, v_coord, v_traj
    FROM entities e
    JOIN physicalities p ON p.entity_id = e.id AND p.type = 1
    WHERE e.id = p_id AND p.trajectory IS NOT NULL
    LIMIT 1;
    IF v_coord IS NULL THEN
        RETURN NULL;
    END IF;

    SELECT z.id INTO v_result
    FROM (
        SELECT knn.id
        FROM (
            SELECT e2.id, p2.trajectory AS t2
            FROM entities e2
            JOIN physicalities p2 ON p2.entity_id = e2.id AND p2.type = 1
            WHERE e2.type_id = v_type AND e2.id <> p_id AND p2.trajectory IS NOT NULL
            ORDER BY p2.coord <<->> v_coord
            LIMIT 48
        ) knn
        ORDER BY public.laplace_frechet_4d(knn.t2, v_traj) ASC
        LIMIT p_k
    ) z
    ORDER BY public.laplace_hash128_blake3(z.id || p_id)
    LIMIT 1;

    RETURN v_result;
END;
$$;
