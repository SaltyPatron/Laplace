-- Inverse of laplace_highway_mask_bits: build a 32-byte mask from bit positions.
-- Native C (pg_laplace_highway_mask_from_bits in highway_mask.c): bit numbering
-- is byte b/8, LSB-first within the byte (mask[b>>3] |= 1 << (b&7)) — the same
-- memcpy-identity contract highway_mask.c documents and extracts via ctz, and
-- byte-identical to the prior plpgsql set_bit() loop. NULL input, or a mask that
-- ends up with no bits set (empty/all-out-of-range array), returns NULL — the
-- any_set contract highway_mask_refresh relies on every fold epoch. Round trip
-- laplace_highway_mask_bits(mask_from_bits(x)) = sorted(x) is a regression.
-- Bit VALUES still come only from relation_highway_bit (the perfcache); this
-- function never assigns meaning to a position.
CREATE OR REPLACE FUNCTION laplace_highway_mask_from_bits(p_bits int[])
    RETURNS bytea
    AS 'MODULE_PATHNAME', 'pg_laplace_highway_mask_from_bits'
    LANGUAGE C IMMUTABLE PARALLEL SAFE;
