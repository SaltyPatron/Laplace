-- KEYED (2026-07-16): id alone cannot prune the LIST(type_id) ->
-- HASH(subject_id) partitioning; the caller passes the partition keys it
-- already holds. Parallel arrays, length-checked natively.
DROP FUNCTION IF EXISTS attestations_exist_bitmap(bytea[]);
CREATE OR REPLACE FUNCTION attestations_exist_bitmap(
    ids bytea[], type_ids bytea[], subject_ids bytea[])
    RETURNS bytea
    AS 'MODULE_PATHNAME', 'pg_laplace_attestations_exist_bitmap'
    LANGUAGE C STABLE;
