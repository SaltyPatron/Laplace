-- An entity's verdict record: its edges grouped by the canonical
-- epistemic_status logic — confirmed / contested / refuted / thin. The verdict
-- rule lives THERE; this only counts, and no client re-derives it from raw mu.
CREATE OR REPLACE FUNCTION entity_record(p_id bytea)
    RETURNS TABLE(confirmed bigint, contested bigint, refuted bigint, thin bigint)
    LANGUAGE sql STABLE
    SET search_path = @extschema@, public AS $$
    SELECT count(*) FILTER (WHERE s.status = 'confirmed'),
           count(*) FILTER (WHERE s.status = 'contested'),
           count(*) FILTER (WHERE s.status = 'refuted'),
           count(*) FILTER (WHERE s.status = 'thin')
    FROM epistemic_status(p_id, NULL, 500) s
$$;
