CREATE OR REPLACE FUNCTION usage_overlap(p_x bytea, p_y bytea)
    RETURNS bigint
    LANGUAGE sql STABLE PARALLEL SAFE STRICT
    SET search_path = @extschema@, public AS $$
    -- Pillar 5 (2026-07-20): shared-usage is read from the GEOMETRY. The
    -- continuation neighbourhood of a point is the next content constituent in
    -- every trajectory containing it (geometry_successors) -- the same knowledge
    -- PRECEDES materialized as redundant attestations (Pillar 3a, e5e1b42).
    -- NOTE: this is now the forward (successor) neighbourhood only; the old
    -- consensus form unioned both edge directions. There is no geometry
    -- predecessor operator yet, so the measure is one-sided by construction.
    WITH xn(n) AS (
        SELECT successor_id FROM geometry_successors(p_x, 200, 8)
    ), yn(n) AS (
        SELECT successor_id FROM geometry_successors(p_y, 200, 8)
    )
    SELECT count(*)::bigint FROM xn JOIN yn USING (n)
$$;
