    CREATE OR REPLACE FUNCTION @extschema@.effective_mu(p_rating bigint, p_rd bigint)     RETURNS bigint     AS 'MODULE_PATHNAME', 'pg_laplace_effective_mu'     LANGUAGE C LAPLACE_IMMUTABLE_STRICT;  CREATE OR REPLACE FUNCTION @extschema@.eff_mu(p_rating bigint, p_rd bigint)     RETURNS bigint LANGUAGE sql LAPLACE_IMMUTABLE AS $$     SELECT p_rating - 2 * p_rd $$;  CREATE OR REPLACE FUNCTION eff_mu_display(p_rating bigint, p_rd bigint)     RETURNS numeric LANGUAGE sql LAPLACE_IMMUTABLE AS $$     SELECT round((@extschema@.eff_mu(p_rating, p_rd) / 1e9)::numeric, 3) $$;  CREATE OR REPLACE FUNCTION refuted(p_rating bigint, p_rd bigint)     RETURNS boolean LANGUAGE sql LAPLACE_IMMUTABLE AS $$     SELECT p_rating + 2 * p_rd < @extschema@.glicko2_neutral_mu() $$;    CREATE OR REPLACE FUNCTION glicko2_neutral_mu() RETURNS bigint     AS 'MODULE_PATHNAME', 'pg_laplace_glicko2_neutral_mu'     LANGUAGE C LAPLACE_IMMUTABLE; CREATE OR REPLACE FUNCTION glicko2_initial_rd() RETURNS bigint     LANGUAGE sql LAPLACE_IMMUTABLE AS $$ SELECT 350000000000::bigint $$; CREATE OR REPLACE FUNCTION glicko2_initial_volatility() RETURNS bigint     LANGUAGE sql LAPLACE_IMMUTABLE AS $$ SELECT 60000000::bigint $$; CREATE OR REPLACE FUNCTION glicko2_tau() RETURNS bigint     LANGUAGE sql LAPLACE_IMMUTABLE AS $$ SELECT 500000000::bigint $$;