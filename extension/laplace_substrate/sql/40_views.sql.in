-- Core substrate views — queryable surface over raw tables.
-- All consumers (Foundry, API, decomposers, chess) use these views; no one queries
-- attestations/consensus/entities directly for analysis queries.

-- v_consensus_resolved: consensus rows with eff_mu as a displayable numeric.
-- Use eff_mu_raw (bigint, fp1e9 scale) for index seeks;
-- use eff_mu (numeric) for display and cross-band comparisons.
CREATE OR REPLACE VIEW v_consensus_resolved AS
SELECT c.id, c.subject_id, c.type_id, c.object_id,
       c.rating, c.rd, c.volatility, c.witness_count,
       c.last_observed_at,
       eff_mu(c.rating, c.rd)         AS eff_mu_raw,
       eff_mu_display(c.rating, c.rd) AS eff_mu
FROM consensus c;

-- v_entities_highway: entities that have a non-NULL highway_mask (participate in at least one
-- highway relation). The highway_density column is the number of set bits (relation count).
-- For band-specific participation, use laplace_highway_match(e.highway_mask, $band_mask).
CREATE OR REPLACE VIEW v_entities_highway AS
SELECT e.*,
       laplace_highway_popcount(e.highway_mask) AS highway_density
FROM entities e
WHERE e.highway_mask IS NOT NULL;

-- v_consensus_edges: the "trusted" consensus set — object-bearing edges above the
-- probationary threshold (eff_mu > 0, meaning rating > 2*rd, i.e. above neutral+).
-- This is the primary read surface for the inference engine and Foundry.
CREATE OR REPLACE VIEW v_consensus_edges AS
SELECT c.id, c.subject_id, c.type_id, c.object_id,
       c.rating, c.rd, c.volatility, c.witness_count,
       c.last_observed_at,
       eff_mu(c.rating, c.rd)         AS eff_mu_raw,
       eff_mu_display(c.rating, c.rd) AS eff_mu
FROM consensus c
WHERE c.object_id IS NOT NULL
  AND eff_mu(c.rating, c.rd) > 0;
