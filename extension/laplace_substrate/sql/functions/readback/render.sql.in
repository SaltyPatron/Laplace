CREATE OR REPLACE FUNCTION render(p_id bytea) RETURNS text
    LANGUAGE sql STABLE
    SET search_path = @extschema@, public AS $$
    SELECT COALESCE(
        (SELECT n.name FROM @extschema@.canonical_names n WHERE n.id = p_id),
        -- Perfcache-backed: authoritative for a valid tier-0 codepoint on its own
        -- (a hash128 match against the reverse index *is* the proof), independent
        -- of whether that codepoint has been given its own entities row yet. Do
        -- NOT gate this on an entities lookup -- that would defeat the whole point
        -- of having a perfcache and would misrender orphaned-but-valid tier-0 ids
        -- via the slower fallbacks below (or worse, as opaque hex).
        chr(@extschema@.codepoint_for_id(p_id)),

        -- Name-edge resolution goes through the one shared primitive rather than a
        -- private HAS_NAME_ALIAS-only argmax: resolve_name() consults HAS_NAME
        -- (primary) + HAS_NAME_ALIAS + the synset-lemma path as families and
        -- abstains (NULL) when there is no grounded name, letting the fallbacks
        -- below run. It is reached only after the canonical-name and codepoint
        -- fast paths above, so tier-0 glyph reconstruction is unchanged.
        @extschema@.resolve_name(p_id),
        render_text(p_id),
        encode(p_id, 'hex') || '…')
$$;
