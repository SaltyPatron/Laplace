-- The geometry-native continuation operator: for a content point, the next (or
-- previous) CONTENT constituent in every trajectory that contains it, aggregated
-- by frequency. Reads the ordered sequence straight from the content-addressed
-- geometry (containers_of's single-key-GIN reverse index + the perfcache
-- separator classifier) -- no PRECEDES attestation, no gen_corpus flat corpus.
-- Native because the walk (find the point, skip separators, take the neighbour,
-- aggregate) is pointer/loop work SQL cannot do at scale; see geometry_successors.c.
--
-- p_backward flips the walk. The trajectory holds the EXACT ordered sequence of
-- everything ingested, so "what precedes x" is exactly as answerable as "what
-- follows x" -- same containment query, same separator cache, same aggregation.
-- Asking the question is always legal; what is banned is MATERIALISING the answer
-- as stored PRECEDES rows when the geometry already holds it losslessly.
DROP FUNCTION IF EXISTS geometry_successors(bytea, int, int);

CREATE OR REPLACE FUNCTION geometry_successors(
        p_point    bytea,
        p_limit    int DEFAULT 20,
        p_window   int DEFAULT 8,
        p_backward boolean DEFAULT false)
    RETURNS TABLE(successor_id bytea, seen bigint)
    AS 'MODULE_PATHNAME', 'pg_laplace_geometry_successors'
    LANGUAGE C STABLE;

-- Named mirror: "what comes before x", read from the same sequence.
CREATE OR REPLACE FUNCTION geometry_predecessors(
        p_point  bytea,
        p_limit  int DEFAULT 20,
        p_window int DEFAULT 8)
    RETURNS TABLE(predecessor_id bytea, seen bigint)
    LANGUAGE sql STABLE PARALLEL SAFE
    SET search_path = @extschema@, public AS $$
    SELECT successor_id, seen FROM geometry_successors(p_point, p_limit, p_window, true)
$$;

-- Both directions at once, for the symmetric questions (shared-usage overlap,
-- domain co-occurrence) that must not be silently halved to fit a one-way walk.
CREATE OR REPLACE FUNCTION geometry_neighbours(
        p_point  bytea,
        p_limit  int DEFAULT 20,
        p_window int DEFAULT 8)
    RETURNS TABLE(neighbour_id bytea, seen bigint)
    LANGUAGE sql STABLE PARALLEL SAFE
    SET search_path = @extschema@, public AS $$
    SELECT n.id, sum(n.seen)::bigint
    FROM (
        SELECT successor_id AS id, seen FROM geometry_successors(p_point, p_limit, p_window, false)
        UNION ALL
        SELECT successor_id AS id, seen FROM geometry_successors(p_point, p_limit, p_window, true)
    ) n
    GROUP BY n.id
    ORDER BY 2 DESC
$$;
