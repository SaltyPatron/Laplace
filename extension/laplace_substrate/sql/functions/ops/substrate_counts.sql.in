CREATE OR REPLACE FUNCTION substrate_counts()
    RETURNS TABLE(metric text, value bigint)
    LANGUAGE sql STABLE
    SET search_path = @extschema@, public AS $$
    -- Planner estimates (pg_class.reltuples), NOT count(*). Full scans on 100M+ unvacuumed
    -- tables hung every ingest tail; these numbers are directionally correct post-ingest.
    -- Run ANALYZE for exact counts, or evidence_count()/source_id() for source precision.
    SELECT 'entities (ESTIMATE)',      GREATEST(0, (SELECT reltuples FROM pg_class WHERE oid = '@extschema@.entities'::regclass))::bigint
    UNION ALL
    SELECT 'physicalities (ESTIMATE)', GREATEST(0, (SELECT reltuples FROM pg_class WHERE oid = '@extschema@.physicalities'::regclass))::bigint
    UNION ALL
    SELECT 'attestations (ESTIMATE)',  GREATEST(0, (SELECT reltuples FROM pg_class WHERE oid = '@extschema@.attestations'::regclass))::bigint
    UNION ALL
    SELECT 'consensus (ESTIMATE)',     GREATEST(0, (SELECT reltuples FROM pg_class WHERE oid = '@extschema@.consensus'::regclass))::bigint
$$;
