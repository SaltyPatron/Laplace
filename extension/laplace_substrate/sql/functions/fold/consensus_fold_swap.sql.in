-- Content swap, NOT identity swap.
--
-- The previous implementation swapped table identity (RENAME consensus →
-- consensus_retired, RENAME consensus_next → consensus, ALTER EXTENSION
-- DROP/ADD, DROP retired). PostgreSQL binds dependents to tables by OID, so
-- that dance silently destroyed everything attached to the real table:
--   * every view over consensus followed the rename onto the doomed table
--     (the function hand-recreated two views; v_consensus_unrefuted was added
--     later, missed the list, and made DROP consensus_retired fail outright);
--   * ALTER EXTENSION DROP TABLE deletes the pg_extension_config_dump
--     registration (extension_config_remove in PG source) and it cannot be
--     re-registered outside a CREATE/ALTER EXTENSION script — every swap
--     permanently stripped consensus from pg_dump backups;
--   * the six secondary indexes and the FK constraints lived on the old
--     table's OID and died with it — consensus_next only ever got a PK.
--
-- TRUNCATE + INSERT keeps the consensus OID stable, so views, indexes, FKs,
-- extension membership, and dump config all survive untouched, and no
-- compensating DDL list exists to drift. The INSERT runs under
-- session_replication_role = replica — same trick finish_consensus_fold_steps
-- already uses — because fold journals are pre-validated at attestation
-- insert time and regress fixtures fold synthetic ids with no entities rows
-- (identical observable semantics to the old swap, which produced a table
-- with no FKs at all).
CREATE OR REPLACE FUNCTION consensus_fold_swap()
    RETURNS void LANGUAGE plpgsql VOLATILE
    SET search_path = @extschema@, public AS $$
DECLARE
    rel record;
BEGIN
    IF to_regclass(current_schema() || '.consensus_next') IS NULL THEN
        RAISE EXCEPTION 'consensus_fold_swap: consensus_next missing — no fold staged';
    END IF;
    IF NOT EXISTS (SELECT 1 FROM consensus_next)
       AND EXISTS (SELECT 1 FROM consensus)
       AND COALESCE(NULLIF(current_setting('laplace.allow_empty_swap', true), ''), 'off') <> 'on'
    THEN
        RAISE EXCEPTION 'consensus_fold_swap: refusing to swap an empty consensus_next over a populated consensus — the fold produced no rows (errored or no-op); this would wipe consensus. Set laplace.allow_empty_swap=on to override.';
    END IF;

    SET LOCAL session_replication_role = replica;
    -- Truncate only NON-EMPTY leaves. `TRUNCATE consensus` on the partitioned
    -- parent recreates every leaf's files (~140 leaves x 3 forks) even when
    -- they hold nothing — on a fresh seed's terminal fold that is hundreds of
    -- pointless file ops (each Defender-scanned on Windows). A legacy plain
    -- consensus truncates as itself via the same pg_partition_tree call
    -- (isleaf includes the root when it is a plain relation).
    FOR rel IN
        SELECT relid::regclass AS leaf
        FROM pg_partition_tree(current_schema() || '.consensus')
        WHERE isleaf AND pg_relation_size(relid) > 0
    LOOP
        EXECUTE format('TRUNCATE %s', rel.leaf);
    END LOOP;
    INSERT INTO consensus (id, subject_id, type_id, object_id,
                           rating, rd, volatility, witness_count, last_observed_at)
    SELECT id, subject_id, type_id, object_id,
           rating, rd, volatility, witness_count, last_observed_at
    FROM consensus_next
    ORDER BY id;
    SET LOCAL session_replication_role = origin;

    DROP TABLE consensus_next;

    FOR rel IN
        SELECT c.relname
        FROM pg_class c JOIN pg_namespace ns ON ns.oid = c.relnamespace
        WHERE ns.nspname = current_schema() AND c.relkind = 'r'
          AND c.relname ~ '^consensus_period_staging_e\d{4}_\d+$'
    LOOP
        EXECUTE format('DROP TABLE %I', rel.relname);
    END LOOP;

    EXECUTE 'ANALYZE consensus';
END;
$$;
