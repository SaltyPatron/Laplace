CREATE FUNCTION canonical_id(p_name text) RETURNS bytea
    LANGUAGE sql IMMUTABLE STRICT AS $$
    SELECT public.laplace_hash128_blake3(convert_to(p_name, 'UTF8'))
$$;

CREATE TABLE canonical_names (
    id   bytea PRIMARY KEY CHECK (octet_length(id) = 16),
    name text  NOT NULL
);
SELECT pg_extension_config_dump('canonical_names', '');

CREATE FUNCTION register_canonical(p_name text) RETURNS bytea
    LANGUAGE sql AS $$
    INSERT INTO canonical_names (id, name)
    VALUES (@extschema@.canonical_id(p_name), p_name)
    ON CONFLICT (id) DO NOTHING;
    SELECT @extschema@.canonical_id(p_name)
$$;

CREATE TABLE codepoint_render (
    id bytea   PRIMARY KEY CHECK (octet_length(id) = 16),
    cp integer NOT NULL
);
SELECT pg_extension_config_dump('codepoint_render', '');

CREATE FUNCTION build_codepoint_render() RETURNS bigint
    LANGUAGE sql AS $$
    INSERT INTO codepoint_render (id, cp)
    SELECT @extschema@.canonical_id(chr(g.cp)), g.cp
    FROM generate_series(1, 1114111) AS g(cp)
    WHERE g.cp NOT BETWEEN 55296 AND 57343
    ON CONFLICT (id) DO NOTHING;
    SELECT count(*) FROM @extschema@.codepoint_render
$$;

CREATE FUNCTION constituents(p_id bytea)
    RETURNS TABLE(ordinal integer, child_id bytea, run_length integer, flags bigint)
    LANGUAGE sql STABLE
    SET search_path = @extschema@, public AS $$
    SELECT u.ordinal, u.entity_id, u.run_length, u.flags
    FROM (
        SELECT p.trajectory AS traj
        FROM physicalities p
        WHERE p.entity_id = p_id
          AND p.type = 1
          AND p.trajectory IS NOT NULL
        ORDER BY p.source_id
        LIMIT 1
    ) t
    CROSS JOIN LATERAL public.ST_DumpPoints(t.traj) AS dp
    CROSS JOIN LATERAL public.laplace_mantissa_unpack(dp.geom) AS u
    ORDER BY 1
$$;

CREATE FUNCTION vertex_atom(p_flags bigint) RETURNS integer
    LANGUAGE sql LAPLACE_IMMUTABLE AS $$
    SELECT CASE WHEN p_flags & 1 = 1
                THEN ((p_flags >> 31) & 2097151)::integer END
$$;

CREATE FUNCTION vertex_tier(p_flags bigint) RETURNS smallint
    LANGUAGE sql LAPLACE_IMMUTABLE AS $$
    SELECT ((p_flags >> 1) & 31)::smallint
$$;

CREATE FUNCTION render_text(p_id bytea, p_max_depth integer DEFAULT 32)
    RETURNS text
    AS 'MODULE_PATHNAME', 'pg_laplace_render_text'
    LANGUAGE C STABLE;

CREATE FUNCTION render(p_id bytea) RETURNS text
    LANGUAGE sql STABLE
    SET search_path = @extschema@, public AS $$
    SELECT COALESCE(
        (SELECT n.name FROM @extschema@.canonical_names n WHERE n.id = p_id),
        (SELECT chr(r.cp) FROM @extschema@.codepoint_render r WHERE r.id = p_id),
        render_text(p_id),
        encode(p_id, 'hex') || '…')
$$;

CREATE FUNCTION register_canonicals(p_names text[]) RETURNS bigint
    LANGUAGE sql AS $$
    INSERT INTO canonical_names (id, name)
    SELECT @extschema@.canonical_id(n), n FROM unnest(p_names) AS n
    ON CONFLICT (id) DO NOTHING;
    SELECT count(*)::bigint FROM unnest(p_names)
$$;
