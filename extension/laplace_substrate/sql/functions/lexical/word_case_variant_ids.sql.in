-- Thin wrapper over the native word_case_variants (src/lexical_case.c). The old
-- SQL body composed word_case_map_surface x3 (each a per-grapheme
-- grapheme_case_target consensus subquery + render_text) -- the RBAR that
-- lexical_peers -> senses/define/bubble_up amplified. The native function does
-- the identical selection/render/mint/exist steps in a fixed handful of batched
-- SPI round trips. Kept as a wrapper so lexical_peers and callers are unchanged.
CREATE OR REPLACE FUNCTION word_case_variant_ids(p_word bytea)
    RETURNS bytea[]
    LANGUAGE sql STABLE STRICT PARALLEL SAFE
    SET search_path = @extschema@, public AS $$
    SELECT word_case_variants(p_word)
$$;
