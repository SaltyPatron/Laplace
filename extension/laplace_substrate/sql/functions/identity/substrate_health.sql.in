CREATE OR REPLACE FUNCTION substrate_health()
RETURNS TABLE(
    ok boolean,
    fake_tier_bands bigint,
    identity_violations bigint,
    bootstrap_entities bigint
)
LANGUAGE sql
STABLE
SET search_path = @extschema@, public
AS $$
    -- Each verification scan runs exactly once: the planner does not
    -- common-subexpression-eliminate independent scalar subqueries in one
    -- targetlist, so deriving `ok` from the scanned columns (not re-invoking
    -- the scans inside the boolean) halves the entities passes per call.
    WITH scans AS (
        SELECT
            @extschema@.fake_tier_band_count() AS fake_tier_bands,
            (SELECT count(*) FROM @extschema@.identity_law_violations()) AS identity_violations,
            (SELECT count(*) FROM @extschema@.entities) AS bootstrap_entities,
            EXISTS (
                SELECT 1 FROM @extschema@.entities
                WHERE id = public.laplace_hash128_blake3('substrate/source/SubstrateCanonical/v1'::bytea)
            ) AS canonical_source_present
    )
    SELECT
        (s.fake_tier_bands = 0
         AND s.identity_violations = 0
         AND s.canonical_source_present) AS ok,
        s.fake_tier_bands,
        s.identity_violations,
        s.bootstrap_entities
    FROM scans s;
$$;
