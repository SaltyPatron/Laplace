[submodule "external/postgresql"]
	path = external/postgresql
	url = https://git.postgresql.org/git/postgresql.git
[submodule "external/postgis"]
	path = external/postgis
	url = https://github.com/postgis/postgis.git
[submodule "external/proj"]
	path = external/proj
	url = https://github.com/OSGeo/PROJ.git
[submodule "external/geos"]
	path = external/geos
	url = https://github.com/libgeos/geos.git
[submodule "external/gdal"]
	path = external/gdal
	url = https://github.com/OSGeo/gdal.git
[submodule "external/eigen"]
	path = external/eigen
	url = https://gitlab.com/libeigen/eigen.git
[submodule "external/spectra"]
	path = external/spectra
	url = https://github.com/yixuan/spectra.git
[submodule "external/blake3"]
	path = external/blake3
	url = https://github.com/BLAKE3-team/BLAKE3.git
