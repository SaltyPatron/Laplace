-- Plan Phase 6 (doc 14 P2): per-entity 256-bit relation-membership mask for the
-- foundry's content-dependent FFN gate — which relation families a token
-- participates in is a genuine step function of content, poured, not learned.
CREATE OR REPLACE FUNCTION entity_highway_masks(p_vocab bytea[])
    RETURNS TABLE(entity_id bytea, highway_mask bytea)
    LANGUAGE sql STABLE PARALLEL SAFE
    SET search_path = @extschema@, public AS $$
    SELECT e.id, e.highway_mask
    FROM entities e
    JOIN unnest(p_vocab) AS u(id) ON u.id = e.id
    WHERE e.highway_mask IS NOT NULL
$$;
