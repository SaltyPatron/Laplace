CREATE OR REPLACE FUNCTION top_relations(p_limit integer DEFAULT 50, p_type bytea DEFAULT NULL)
    RETURNS TABLE(subject_id bytea, type_id bytea, object_id bytea, eff_mu numeric, witnesses bigint)
    LANGUAGE sql STABLE SET search_path = @extschema@, public AS $$
    -- Issue 52: edge_rank() per row over ALL consensus before LIMIT measured >9min at
    -- 124M rows and killed three endpoints. Bounded-candidate form, same ranking law:
    -- consensus_eff_mu_btree serves a top-M head by raw eff_mu; edge_rank (salience
    -- band x eff_mu, the single readout law) reorders only that pool. Bands span
    -- 1.0..0.05, so anything reachable at the top of edge_rank sits inside a generous
    -- raw-eff_mu head (measured 0.5s live at 124M via the API-side prototype).
    -- With p_type fixed the band is a constant, edge_rank is monotone in eff_mu_raw,
    -- and the index order IS the answer - no candidate pool needed on that arm.
    WITH pool AS (
        SELECT c.subject_id, c.type_id, c.object_id,
               c.eff_mu, c.eff_mu_raw, c.witness_count
        FROM v_consensus_resolved c
        WHERE p_type IS NULL AND c.object_id IS NOT NULL
        ORDER BY c.eff_mu_raw DESC
        LIMIT GREATEST(5000, p_limit * 25)
    ),
    typed AS (
        SELECT c.subject_id, c.type_id, c.object_id,
               c.eff_mu, c.eff_mu_raw, c.witness_count
        FROM v_consensus_resolved c
        WHERE p_type IS NOT NULL AND c.type_id = p_type AND c.object_id IS NOT NULL
        ORDER BY c.eff_mu_raw DESC
        LIMIT p_limit
    )
    SELECT u.subject_id, u.type_id, u.object_id, u.eff_mu, u.witness_count
    FROM (SELECT * FROM pool UNION ALL SELECT * FROM typed) u
    ORDER BY edge_rank(u.type_id, u.eff_mu_raw) DESC, u.witness_count DESC
    LIMIT p_limit
$$;
