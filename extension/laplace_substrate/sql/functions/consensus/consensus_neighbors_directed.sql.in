DROP FUNCTION IF EXISTS consensus_neighbors_directed(bytea, bytea[], int);
CREATE OR REPLACE FUNCTION consensus_neighbors_directed(
    p_subject bytea,
    p_types   bytea[],
    p_limit   int)
    RETURNS TABLE(nbr bytea, rating bigint, rd bigint, witness_count bigint)
    LANGUAGE sql STABLE PARALLEL SAFE
    SET search_path = @extschema@, public AS $$
    SELECT c.object_id AS nbr, c.rating, c.rd, c.witness_count
    FROM v_consensus_unrefuted c
    WHERE c.subject_id = p_subject
      AND c.object_id IS NOT NULL
      AND c.type_id = ANY (p_types)
    ORDER BY eff_mu(c.rating, c.rd) DESC
    LIMIT p_limit
$$;
