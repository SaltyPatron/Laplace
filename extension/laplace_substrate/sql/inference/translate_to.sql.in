


CREATE OR REPLACE FUNCTION translate_to(p_word bytea, p_lang text DEFAULT NULL,
                                        p_limit int DEFAULT 24)
    RETURNS TABLE(translation text, language text, eff_mu numeric, witnesses bigint)
    LANGUAGE sql STABLE PARALLEL SAFE
    SET search_path = @extschema@, public AS $$
    -- Dedup and rank by (member, lang) id pair, never by rendered surface (the
    -- old GROUP BY render_text(member) conflated homographs). The user-supplied
    -- language reference is text, so it is resolved at the INPUT boundary: each
    -- DISTINCT candidate language is matched once against the reference (by
    -- label or definition surface), instead of re-rendering per member row.
    -- render_text runs above the sort, streaming until p_limit rows survive.
    WITH src_langs AS (
        SELECT c.object_id AS id FROM consensus c
        WHERE c.subject_id = p_word AND c.type_id = relation_type_id('HAS_LANGUAGE')
    ),
    want AS (SELECT NULLIF(btrim(lower(COALESCE(p_lang, ''))), '') AS name),
    agg AS (
        SELECT sm.member, sm.lang, max(sm.mu) AS mu, max(sm.witnesses) AS witnesses,
               max(sm.sense_mu) AS sense_mu
        FROM synset_members(p_word) sm
        WHERE sm.lang IS NOT NULL
          AND sm.lang NOT IN (SELECT id FROM src_langs)
        GROUP BY sm.member, sm.lang
    ),
    lang_match AS (
        -- No-filter call (name IS NULL): pass every candidate language through with
        -- ZERO rendering — Postgres does not guarantee OR short-circuit, so the old
        -- single-WHERE shape could evaluate label()/render_text() even when no
        -- language filter was supplied (the common call).
        SELECT l.lang
        FROM (SELECT DISTINCT lang FROM agg) l, want w
        WHERE w.name IS NULL
        UNION ALL
        -- Named filter: label rendered ONCE per candidate language as a fenced
        -- projection (not re-evaluated inside a predicate); the definition-surface
        -- fallback renders only for languages whose label missed. Accept set is
        -- identical to the old matcher.
        SELECT s.lang
        FROM (
            SELECT l.lang, lower(label(l.lang)) AS lbl
            FROM (SELECT DISTINCT lang FROM agg) l, want w0
            WHERE w0.name IS NOT NULL
        ) s, want w
        WHERE s.lbl = w.name
           OR EXISTS (SELECT 1 FROM consensus d
                      WHERE d.subject_id = s.lang
                        AND d.type_id = relation_type_id('HAS_DEFINITION')
                        AND lower(render_text(d.object_id, 32)) = w.name)
    )
    -- a.mu is fp1e9 (synset_members) — convert through the one display definition
    SELECT r.txt AS translation, label(a.lang) AS language, eff_mu_display(a.mu), a.witnesses
    FROM (
        SELECT member, lang, mu, witnesses FROM agg
        WHERE lang IN (SELECT lang FROM lang_match)
        ORDER BY sense_mu DESC NULLS LAST, mu DESC, witnesses DESC, lang, member
    ) a
    CROSS JOIN LATERAL (SELECT render_text(a.member, 64) AS txt) r
    WHERE NULLIF(btrim(r.txt), '') IS NOT NULL
    LIMIT p_limit
$$;
