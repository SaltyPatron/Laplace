# Single source of truth for all image tags and submodule versions.
# Bump a value here, re-run scripts/docker/Build.ps1, downstream layers rebuild.
# These MUST match the git submodule checkouts under external/.

ONEAPI_HPCKIT=2025.3.1-0-devel-ubuntu22.04
ONEAPI_RUNTIME=2025.3.1-0-devel-ubuntu22.04

POSTGRES_VERSION=18.3
POSTGIS_VERSION=3.6.3
PROJ_VERSION=9.8.1
GEOS_VERSION=3.14.1

# Image namespace
IMG_NS=laplace
