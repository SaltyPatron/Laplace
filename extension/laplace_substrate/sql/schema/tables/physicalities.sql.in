CREATE TABLE IF NOT EXISTS physicalities (
    id                 bytea            PRIMARY KEY CHECK (octet_length(id) = 16),
    entity_id          bytea            NOT NULL REFERENCES entities(id) ON DELETE CASCADE,
    type               smallint         NOT NULL,
    coord              geometry(PointZM)    NOT NULL,
    hilbert_index      bytea                NOT NULL CHECK (octet_length(hilbert_index) = 16),
    trajectory         geometry(GeometryZM),
    radius_origin      double precision GENERATED ALWAYS AS (
        sqrt(ST_X(coord)^2 + ST_Y(coord)^2 + ST_Z(coord)^2 + ST_M(coord)^2)
    ) STORED,
    n_constituents     integer          NOT NULL DEFAULT 0 CHECK (n_constituents >= 0),
    alignment_residual double precision,
    source_dim         integer          CHECK (source_dim IS NULL OR source_dim > 0),
    observed_at        timestamptz      NOT NULL DEFAULT now()
    
    
    
    
    
    
);

-- Skip the expensive PostGIS ND-stats on the geometry columns. The ingest pipeline reaches these
-- via the GiST index (KNN), never via column histograms, so dropping per-column stats costs the
-- planner nothing here while making ANALYZE/autoanalyze on this table ~160x cheaper (measured on
-- 88M rows: 137s -> 0.87s) — which is what lets autoanalyze run at all instead of timing out of
-- its budget and leaving stats permanently stale.
ALTER TABLE physicalities ALTER COLUMN coord      SET STATISTICS 0;
ALTER TABLE physicalities ALTER COLUMN trajectory SET STATISTICS 0;

-- Fire autoanalyze at 2% / 100k changes instead of the 10% default (see entities.sql.in).
ALTER TABLE physicalities SET (autovacuum_analyze_scale_factor = 0.02, autovacuum_analyze_threshold = 100000);

SELECT pg_extension_config_dump('physicalities', '');
