CREATE TABLE geometry_placement_evidence (
    id                bytea            PRIMARY KEY CHECK (octet_length(id) = 16),
    entity_id         bytea            NOT NULL REFERENCES entities(id) ON DELETE CASCADE,
    projection_type   smallint         NOT NULL,
    source_id         bytea            NOT NULL REFERENCES entities(id) ON DELETE CASCADE,
    layer             integer,
    head              integer,
    expert            integer,
    coord             geometry(PointZM) NOT NULL,
    weight            bigint           NOT NULL DEFAULT 1000000000 CHECK (weight >= 0),
    observation_count bigint           NOT NULL DEFAULT 1 CHECK (observation_count >= 0),
    observed_at       timestamptz      NOT NULL DEFAULT now(),
    UNIQUE NULLS NOT DISTINCT (entity_id, projection_type, source_id, layer, head, expert)
);

SELECT pg_extension_config_dump('geometry_placement_evidence', '');

CREATE INDEX geometry_placement_evidence_entity_btree
    ON geometry_placement_evidence (entity_id);
CREATE INDEX geometry_placement_evidence_entity_kind_btree
    ON geometry_placement_evidence (entity_id, projection_type);
CREATE INDEX geometry_placement_evidence_source_btree
    ON geometry_placement_evidence (source_id);

CREATE TABLE geometry_consensus (
    id                bytea            PRIMARY KEY CHECK (octet_length(id) = 16),
    entity_id         bytea            NOT NULL REFERENCES entities(id) ON DELETE CASCADE,
    projection_type   smallint         NOT NULL,
    coord             geometry(PointZM) NOT NULL,
    radius_origin     double precision GENERATED ALWAYS AS (
        sqrt(ST_X(coord)^2 + ST_Y(coord)^2 + ST_Z(coord)^2 + ST_M(coord)^2)
    ) STORED,
    dispersion        bigint           CHECK (dispersion IS NULL OR dispersion >= 0),
    witness_count     bigint           NOT NULL DEFAULT 1 CHECK (witness_count >= 0),
    last_observed_at  timestamptz      NOT NULL,
    UNIQUE (entity_id, projection_type)
);

SELECT pg_extension_config_dump('geometry_consensus', '');

CREATE INDEX geometry_consensus_entity_btree   ON geometry_consensus (entity_id);
CREATE INDEX geometry_consensus_kind_btree     ON geometry_consensus (projection_type);
CREATE INDEX geometry_consensus_coord_gist     ON geometry_consensus USING gist (coord);

CREATE OR REPLACE FUNCTION geometry_consensus_id(
    p_entity bytea, p_projection_type smallint)
    RETURNS bytea LANGUAGE sql LAPLACE_IMMUTABLE
    SET search_path = @extschema@, public AS $$
    SELECT public.laplace_hash128_blake3(
        p_entity || int2send(p_projection_type))
$$;
