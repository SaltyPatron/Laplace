CREATE OR REPLACE FUNCTION chess_moves(p_position bytea, p_limit integer DEFAULT 12)
    RETURNS TABLE(next_position bytea, eff_mu double precision, rd double precision,
                  witness_count bigint)
    LANGUAGE sql STABLE PARALLEL SAFE AS $$
    -- Opening explorer over the rated MOVE web: every continuation the fold has
    -- ever witnessed out of one position, ranked by the conservative estimate.
    -- Position ids are COMPOSED (ChessCompose merkle path), never
    -- canonical_id(surface) — callers hold them from composing a board state or
    -- from a prior chess_moves step. Rides
    -- consensus_subject_type_eff_mu_btree (subject_id, type_id, rating-2*rd DESC
    -- WHERE object_id IS NOT NULL); eff_mu() inlines to that exact expression.
    -- LIMIT is the only cut — no floors, no thresholds.
    SELECT c.object_id,
           @extschema@.eff_mu(c.rating, c.rd)::double precision,
           c.rd::double precision,
           c.witness_count
    FROM @extschema@.consensus c
    WHERE c.subject_id = p_position
      AND c.type_id = @extschema@.relation_type_id('MOVE')
      AND c.object_id IS NOT NULL
    ORDER BY @extschema@.eff_mu(c.rating, c.rd) DESC
    LIMIT p_limit
$$;
