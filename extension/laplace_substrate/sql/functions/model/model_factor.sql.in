-- Model-factor query surface (campaign doc 26 item B, v1): SQL over the factor
-- trajectories the model lane deposits. Loops live in C (model_factor.c);
-- trajectory layout is the FactorTrajectory law. Tokens returned are WORD
-- ENTITIES — joinable against consensus/senses/anything in the web. v1 reads
-- the PostGIS varlena with a linear header scan (~450 ms/call); the factor
-- perfcache blob turns both into pointer arithmetic.

-- The model's own coupling q(A)·k(B) in one circuit, by lookup.
CREATE OR REPLACE FUNCTION model_pair_score(
    p_q_slice bytea,
    p_k_slice bytea,
    p_tok_a   bytea,
    p_tok_b   bytea)
    RETURNS float8
    AS 'MODULE_PATHNAME', 'pg_laplace_model_pair_score'
    LANGUAGE C STABLE;

-- One token's attention row in one circuit: k strongest partners, native scan.
CREATE OR REPLACE FUNCTION model_row_topk(
    p_q_slice bytea,
    p_k_slice bytea,
    p_tok     bytea,
    p_k       int DEFAULT 20)
    RETURNS TABLE(token bytea, score float8)
    AS 'MODULE_PATHNAME', 'pg_laplace_model_row_topk'
    LANGUAGE C STABLE ROWS 20;

-- Circuit navigation by anatomy. Order disambiguates layer vs head via
-- PRECEDES attestations whose CONTEXT is the coordinate (text-lane structure
-- law); a single-constituent coordinate collapses to the plane anchor (emb).
-- Uses attestations_relation_btree + consensus_object_type_btree.
CREATE OR REPLACE FUNCTION model_circuit_slices(
    p_plane text,
    p_layer int DEFAULT NULL,
    p_head  int DEFAULT NULL)
    RETURNS TABLE(slice_id bytea, coord_id bytea)
    LANGUAGE sql STABLE ROWS 1
    AS $fn$
    WITH anchor AS (
        SELECT canonical_id('substrate/entity/model/plane/' || p_plane || '/v1') AS id
    ),
    coord AS (
        SELECT CASE WHEN p_layer IS NULL THEN a.id ELSE lh.ctx END AS id
        FROM anchor a
        LEFT JOIN LATERAL (
            SELECT p1.context_id AS ctx
            FROM attestations p1
            WHERE p1.type_id = relation_type_id('PRECEDES')
              AND p1.subject_id = a.id
              AND p1.object_id = word_id(p_layer::text)
              AND (p_head IS NULL OR EXISTS (
                    SELECT 1 FROM attestations p2
                    WHERE p2.type_id = p1.type_id
                      AND p2.context_id = p1.context_id
                      AND p2.subject_id = word_id(p_layer::text)
                      AND p2.object_id = word_id(p_head::text)))
              AND (p_head IS NOT NULL OR NOT EXISTS (
                    SELECT 1 FROM attestations p3
                    WHERE p3.type_id = p1.type_id
                      AND p3.context_id = p1.context_id
                      AND p3.subject_id = word_id(p_layer::text)))
            LIMIT 1
        ) lh ON p_layer IS NOT NULL
        WHERE p_layer IS NULL OR lh.ctx IS NOT NULL
    )
    SELECT s.subject_id, coord.id
    FROM coord
    JOIN consensus s
      ON s.object_id = coord.id
     AND s.type_id = relation_type_id('APPEARS_IN')
    $fn$;

-- Gravity decomposition: dot = |q|·|k|·cosθ — mass × mass × alignment.
-- Norms come from self-scores; no extra native surface needed.
CREATE OR REPLACE FUNCTION model_pair_cos(
    p_q bytea, p_k bytea, p_a bytea, p_b bytea,
    OUT raw_dot float8, OUT cos_theta float8, OUT mass_q float8, OUT mass_k float8)
    LANGUAGE plpgsql STABLE AS $fn$
BEGIN
    raw_dot := model_pair_score(p_q, p_k, p_a, p_b);
    mass_q  := sqrt(model_pair_score(p_q, p_q, p_a, p_a));
    mass_k  := sqrt(model_pair_score(p_k, p_k, p_b, p_b));
    cos_theta := raw_dot / NULLIF(mass_q * mass_k, 0);
END $fn$;

-- Token-joinable attention row by circuit NAME and WORD — the everyday entry.
-- Returns word entities + text, ready to JOIN against senses/consensus/web:
--   SELECT r.*, c.rating FROM model_attention_row(2,9,'king',10) r
--   LEFT JOIN consensus c ON c.subject_id = r.token AND ...
CREATE OR REPLACE FUNCTION model_attention_row(
    p_layer int,
    p_head  int,
    p_word  text,
    p_k     int DEFAULT 20)
    RETURNS TABLE(partner text, token bytea, score float8)
    LANGUAGE sql STABLE ROWS 20
    AS $fn$
    SELECT render_text(t.token), t.token, t.score
    FROM model_circuit_slices('qproj', p_layer, p_head) q,
         model_circuit_slices('kproj', p_layer, p_head) k,
         LATERAL model_row_topk(q.slice_id, k.slice_id, word_id(p_word), p_k) t
    $fn$;
