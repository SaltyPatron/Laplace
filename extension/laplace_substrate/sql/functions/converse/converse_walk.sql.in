-- converse_walk(prompt, steps, seed): the FUSED free-form walk.
--
-- Sequence PROPOSES, meaning STEERS -- now with real semantic steering:
--   ORIENT  -> the prompt's richest concept synset (as converse()).
--   GATHER  -> ordered token trajectories of the concept's own attested sentence
--              (weight 50, the seed) plus the tier-3 sentences that contain the
--              topic word (weight 40). Drawn from physicality trajectories =
--              precedes/follows/co-occurrence. Each token carries its source's
--              topic weight, so the corpus knows what is central vs peripheral.
--              Set-based: render_text runs once per DISTINCT token id to drop
--              whitespace constituents (the old loop rendered every occurrence
--              of every token of every sentence).
--   WALK    -> steered_walk_raw (steered_walk.c): trigram->bigram backoff over
--              the restricted stream, SEEDED from the core concept's own
--              sentence and STEERED by topic weight (RNG breaks ties), with the
--              anti-repeat guard forcing novel recombination at shared n-gram
--              pivots. Ends at a sentence boundary once it has said enough.
--              Grounded only in attested token order; deterministic per seed.
--   REALIZE -> render_text of the emitted token ids.
CREATE OR REPLACE FUNCTION converse_walk(p_prompt text, p_steps int DEFAULT 40,
                                         p_seed bigint DEFAULT NULL)
    RETURNS text
    LANGUAGE plpgsql VOLATILE
    SET search_path = @extschema@, public AS $$
DECLARE
    b_def  int := 1;   -- definitional band (gloss)
    b_tax  int := 2;   -- taxonomic band (is-a)
    b_part int := 4;   -- partitive band (parts)
    b_assoc int := 7;  -- associative band (related)
    SENT   bytea := '\x00';
    MINLEN int := 5;
    syn    bytea;
    topic_word bytea;   -- the tier-2 word whose usage lives in the tier above
    stream bytea[];
    w      bigint[];    -- per-token topic weight, aligned to stream
    starts bytea[];     -- starts of CORE sentences (on-topic seed)
    core_seq bytea[];   -- longest CORE gloss (deterministic seed)
    n      int;
    rng    bigint;
    out_ids bytea[];
BEGIN
    -- ORIENT: keep BOTH the tier-2 word (for the tier fan-out) and its synset.
    SELECT x.tok, x.syn INTO topic_word, syn
    FROM (SELECT p.id AS tok, top_synset(p.id) AS syn, lower(render_text(p.id,32)) AS surface
          FROM prompt_state(p_prompt) p WHERE p.id IS NOT NULL) x
    WHERE x.syn IS NOT NULL
    ORDER BY (lower(realize(x.syn)) = x.surface AND char_length(x.surface) >= 3) DESC NULLS LAST,
             (SELECT count(*) FROM consensus c WHERE c.subject_id = x.syn
                AND relation_highway_band(c.type_id) IN (b_def,b_tax,b_part,b_assoc)) DESC,
             char_length(x.surface) DESC
    LIMIT 1;
    IF syn IS NULL THEN RETURN NULL; END IF;

    -- GATHER: the concept's own gloss (tier-1 definition, the seed) PLUS the
    -- TIER FAN-OUT -- a word's usage lives in the tier above it, so pull the
    -- tier-3 sentences that contain the topic word as a constituent (dense real
    -- usage) via the constituents index. This is the corpus, not just the gloss.
    -- Word-level tokens only: the inter-word whitespace constituents are
    -- dropped, else (word,space) bigrams match every boundary and the walk
    -- jumps (e.g. "a"+space -> "creek" from "...than a creek").
    WITH gids AS (
        -- DISTINCT: a gloss reachable through two def-band relation types
        -- contributes its token stream once, not twice.
        SELECT DISTINCT g.gid, g.wt, g.is_core FROM (
            SELECT c.object_id AS gid, 50::bigint AS wt, true AS is_core
            FROM consensus c
            WHERE c.subject_id = syn AND relation_highway_band(c.type_id) = b_def
            UNION ALL
            SELECT co.entity_id, 40, false
            FROM containers_of(topic_word, 1, 400) co
            WHERE co.tier = 3
            ORDER BY is_core DESC, gid
            LIMIT 160
        ) g
    ),
    toks AS (
        SELECT g.gid, g.wt, g.is_core, u.entity_id, u.ord
        FROM gids g
        CROSS JOIN LATERAL trajectory_unpacked_points(g.gid)
             WITH ORDINALITY AS u(entity_id, run_length, ctier, ord)
    ),
    ws AS MATERIALIZED (
        SELECT d.entity_id AS id,
               COALESCE(render_text(d.entity_id, 64), ' ') ~ '^\s*$' AS is_ws
        FROM (SELECT DISTINCT t.entity_id FROM toks t) d
    ),
    kept AS MATERIALIZED (
        SELECT q.* FROM (
            SELECT t.gid, t.wt, t.is_core, t.entity_id,
                   row_number() OVER (PARTITION BY t.gid ORDER BY t.ord) AS rn,
                   count(*)    OVER (PARTITION BY t.gid) AS cnt
            FROM toks t
            JOIN ws ON ws.id = t.entity_id
            WHERE NOT ws.is_ws
        ) q
        WHERE q.cnt >= 2
    ),
    seq AS MATERIALIZED (
        -- Each sentence's tokens in order, then one SENT boundary (weight 0)
        -- ordered past every real token of its sentence.
        SELECT k.gid, k.is_core, k.wt, k.entity_id AS id, k.rn
        FROM kept k
        UNION ALL
        SELECT DISTINCT k.gid, k.is_core, 0::bigint, SENT, 2147483647::bigint
        FROM kept k
    )
    SELECT (SELECT array_agg(s.id ORDER BY s.is_core DESC, s.gid, s.rn) FROM seq s),
           (SELECT array_agg(s.wt ORDER BY s.is_core DESC, s.gid, s.rn) FROM seq s),
           (SELECT array_agg(k.entity_id ORDER BY k.gid) FROM kept k
             WHERE k.is_core AND k.rn = 1),
           (SELECT array_agg(k.entity_id ORDER BY k.rn) FROM kept k
             WHERE k.is_core AND k.gid = (
                 SELECT k2.gid FROM kept k2 WHERE k2.is_core
                 GROUP BY k2.gid ORDER BY max(k2.cnt) DESC, k2.gid LIMIT 1))
    INTO stream, w, starts, core_seq;

    n := COALESCE(array_length(stream,1), 0);
    IF n < 3 OR starts IS NULL THEN RETURN NULL; END IF;

    rng := abs(COALESCE(p_seed, ('x'||substr(md5(p_prompt),1,8))::bit(32)::bigint)) % 2147483647;

    -- SEED + WALK run natively; single-token results fall out of a seed with no
    -- attested successor (the old `IF b IS NULL` path).
    out_ids := steered_walk_raw(stream, w, COALESCE(core_seq, ARRAY[]::bytea[]),
                                starts, p_steps, MINLEN, rng);
    IF out_ids IS NULL OR array_length(out_ids,1) IS NULL THEN RETURN NULL; END IF;
    IF array_length(out_ids,1) = 1 THEN RETURN render_text(out_ids[1], 64); END IF;

    -- REALIZE: join tokens, drop orphan gloss punctuation, normalize whitespace.
    RETURN btrim(regexp_replace(
        regexp_replace(
            (SELECT string_agg(COALESCE(render_text(t,64),''), ' ')
             FROM unnest(out_ids) WITH ORDINALITY gg(t,o)),
            '\s*[();:]\s*', ' ', 'g'),
        '\s+', ' ', 'g'));
END;
$$;
