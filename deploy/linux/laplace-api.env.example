LAPLACE_DB=Host=/var/run/postgresql;Username=laplace_admin;Database=laplace

LD_LIBRARY_PATH=/opt/laplace/lib

LAPLACE_PERFCACHE_BIN=/opt/laplace/share/laplace/laplace_t0_perfcache_17.0.0.bin

ASPNETCORE_URLS=http://127.0.0.1:5187
ASPNETCORE_ENVIRONMENT=Production

# Auth: "header" trusts X-Laplace-Tenant (dev only); "key" requires API keys
# (sk-laplace-…, issued via plan checkout redemption or the operator endpoint)
# on /v1/* outside the anonymous signup surface.
LAPLACE_AUTH_MODE=key

# Billing persistence: postgres | memory | unset (auto: postgres when the
# app.billing_* tables are reachable, else memory). Quotes, plan credits,
# usage, API keys, and webhook state must survive deploys in production.
LAPLACE_BILLING_STORE=postgres

# Billing enforcement: unset = enforce exactly when a Stripe key is configured
# (a fresh install with secrets charges out of the box). true forces the gates
# open (local dev); false forces enforcement even without Stripe.
# LAPLACE_BILLING_BYPASS=

# Externally reachable base URL. Enables Stripe webhook self-provisioning
# (products/prices/webhook endpoint created idempotently at startup and via
# POST /v1/billing/operator/bootstrap) and anchors checkout success/cancel URLs.
# LAPLACE_PUBLIC_BASE_URL=https://laplace.example.com

# Operator token for X-Laplace-Operator-Token (manual quote approval, API key
# issuance, bootstrap re-run). Generate once: openssl rand -hex 32
# LAPLACE_OPERATOR_TOKEN=

LAPLACE_LOG_JSON=true
LAPLACE_LOG_DIR=/opt/laplace/app/logs

# Chess Lab binary paths — written by setup-host / pipeline publish (managed block).
# Lichess: /opt/laplace/secrets/lichess.env (seeded by setup-host from
#   ~/.config/shell/secrets.env; systemd EnvironmentFile loads it).
# Stripe:  /opt/laplace/secrets/stripe.env (STRIPE_API_SECRET + STRIPE_WEBHOOK_SECRET).
# LAPLACE_CUTECHESS=/opt/laplace/bin/cutechess-cli
# LAPLACE_STOCKFISH=/usr/games/stockfish
# LAPLACE_QT_BIN=/usr/lib/qt6/bin
