-- 2026-07-09: `edges` must be MATERIALIZED. Inlined, the planner pushes the
-- `rk IS NOT NULL` filter into the consensus scan and evaluates
-- relation_rank_resolved (~27µs/call) on all 124M rows — 255-368s measured,
-- in either function language. Fenced, rank runs once per vocab-joined row
-- (369k) and the vocab probe takes the indexed nestloop: ~20s measured
-- (edges fetch 12s + rank calls ~10s).
DROP FUNCTION IF EXISTS consensus_adjacency(bytea[], int);
CREATE OR REPLACE FUNCTION consensus_adjacency(
        p_vocab bytea[], p_degree_cap int DEFAULT 64)
    RETURNS TABLE(subject_id bytea, object_id bytea, w double precision)
    LANGUAGE plpgsql STABLE PARALLEL RESTRICTED
    SET search_path = @extschema@, public AS $$
BEGIN
    RETURN QUERY
    WITH v(id) AS (SELECT DISTINCT u FROM unnest(p_vocab) AS u),
         edges AS MATERIALIZED (
             SELECT c.subject_id, c.object_id, c.rating, c.rd, c.witness_count,
                    relation_rank_resolved(c.type_id) AS rk
             FROM v
             JOIN consensus c ON c.subject_id = v.id
             JOIN v vo        ON vo.id = c.object_id
             WHERE c.object_id IS NOT NULL
         ),
         -- P5 Glicko-complete weight (doc 14 M5): signed, rd-discounted,
         -- witness-saturated. Positivity is NOT clamped here — the basis union
         -- clamps client-side (FoundryExport.PositivePart); the unary operator
         -- plane keeps refutation as negative weight.
         summed AS (
             SELECT e.subject_id, e.object_id,
                    sum(e.rk
                        * (eff_mu(e.rating, e.rd) - glicko2_neutral_mu())::float8 / 1e9
                        * exp(- foundry_rd_kappa() * e.rd::float8 / 1e9)
                        * foundry_witness_sat(e.witness_count)) AS w
             FROM edges e
             WHERE e.rk IS NOT NULL
             GROUP BY e.subject_id, e.object_id
         ),
         capped AS (
             SELECT s.subject_id, s.object_id, s.w,
                    row_number() OVER (PARTITION BY s.subject_id ORDER BY abs(s.w) DESC, s.object_id) AS rn
             FROM summed s
             WHERE s.w <> 0
         )
    SELECT c.subject_id, c.object_id, c.w FROM capped c WHERE c.rn <= p_degree_cap;
END;
$$;
