LAPLACE_DB=Host=localhost;Port=5432;Username=postgres;Password=postgres;Database=laplace

# header = trust X-Laplace-Tenant (dev); key = require sk-laplace-… API keys on /v1/*.
LAPLACE_AUTH_MODE=header

# postgres | memory | unset (auto: postgres when app.billing_* reachable).
LAPLACE_BILLING_STORE=postgres

# Unset = enforce billing exactly when a Stripe key is configured.
# true forces gates open (dev); false forces enforcement without Stripe.
LAPLACE_BILLING_BYPASS=true

# Webhook self-provisioning + checkout return URLs (prod only):
# LAPLACE_PUBLIC_BASE_URL=https://laplace.example.com
# Operator endpoints (quote approval / key issuance / bootstrap):
# LAPLACE_OPERATOR_TOKEN=

# Stripe + Lichess secrets live in deploy/secrets/{stripe,lichess}.env
# (scripts\win\sync-operator-secrets.cmd). publish.cmd injects them into web.config.

ASPNETCORE_ENVIRONMENT=Production
LAPLACE_LOG_JSON=false
