-- converse(prompt [, lang]): the fused OODA walk as a deterministic narrative.
--
-- Relation selection is gated by SALIENCE BAND (the governed highway structure),
-- not hardcoded English relation names: band 1 = definitional (the gloss),
-- 2 = taxonomic (is-a), 4 = partitive (parts), 7 = associative (kin). A band is
-- the language-agnostic family -- taxonomic catches every subsumption relation, not
-- just IS_A -- and it is the same 13-band ladder the manifest governs and the highway
-- perfcache bit-packs. (Native per-entity highway_mask AND is the intended fast path
-- once the highway perfcache + entities.highway_mask are built; here we gate by
-- relation_highway_band on the read side, which is band-correct and works today.)
CREATE OR REPLACE FUNCTION converse(p_prompt text, p_lang bytea DEFAULT NULL)
    RETURNS text
    LANGUAGE plpgsql STABLE
    SET search_path = @extschema@, public AS $$
DECLARE
    b_def  int := 1;   -- definitional band (gloss)
    b_tax  int := 2;   -- taxonomic band (is-a / hypernym)
    b_part int := 4;   -- partitive band (parts)
    b_assoc int := 7;  -- associative band (related)
    syn    bytea;
    label  text;
    gloss  text;
    parent bytea;
    parent_lbl text;
    parent_gloss text;
    parts  text;
    kin    text;
    out    text := '';
BEGIN
    -- ORIENT: the prompt token whose synset carries the most content-band mass.
    -- Guard against loose lexical resolution (e.g. "me" -> "Maine"): prefer tokens
    -- whose realized lemma equals the surface, so the topic is a word truly in the
    -- prompt resolved to ITS OWN synset (fall back to mass; keeps plurals).
    SELECT x.syn INTO syn
    FROM (
        SELECT top_synset(p.id) AS syn,
               lower(render_text(p.id, 32)) AS surface
        FROM prompt_state(p_prompt) p
        WHERE p.id IS NOT NULL
    ) x
    WHERE x.syn IS NOT NULL
    ORDER BY (lower(realize(x.syn, p_lang)) = x.surface
              AND char_length(x.surface) >= 3) DESC NULLS LAST,
             (SELECT count(*) FROM consensus c
              WHERE c.subject_id = x.syn
                AND relation_highway_band(c.type_id) IN (b_def, b_tax, b_part, b_assoc)) DESC,
             char_length(x.surface) DESC
    LIMIT 1;

    IF syn IS NULL THEN
        RETURN NULL;
    END IF;

    label := realize(syn, p_lang);

    -- definition (highest eff_mu edge in the definitional band)
    SELECT render_text(c.object_id, 96) INTO gloss
    FROM consensus c
    WHERE c.subject_id = syn AND relation_highway_band(c.type_id) = b_def
    ORDER BY (c.rating - 2*c.rd) DESC LIMIT 1;

    -- taxonomy: the hypernym (taxonomic band), and (bridge hop) its own definition
    SELECT c.object_id INTO parent
    FROM consensus c
    WHERE c.subject_id = syn AND relation_highway_band(c.type_id) = b_tax
    ORDER BY (c.rating - 2*c.rd) DESC LIMIT 1;
    IF parent IS NOT NULL THEN
        parent_lbl := realize(parent, p_lang);
        SELECT render_text(c.object_id, 96) INTO parent_gloss
        FROM consensus c
        WHERE c.subject_id = parent AND relation_highway_band(c.type_id) = b_def
        ORDER BY (c.rating - 2*c.rd) DESC LIMIT 1;
    END IF;

    -- parts (partitive band, up to 3 by eff_mu)
    SELECT string_agg(x.lbl, ', ' ORDER BY x.mu DESC) INTO parts
    FROM (
        SELECT realize(c.object_id, p_lang) AS lbl, (c.rating - 2*c.rd) AS mu
        FROM consensus c
        WHERE c.subject_id = syn AND relation_highway_band(c.type_id) = b_part
        ORDER BY (c.rating - 2*c.rd) DESC LIMIT 3
    ) x
    WHERE x.lbl IS NOT NULL;

    -- kin (associative band, up to 2)
    SELECT string_agg(x.lbl, ' and ' ORDER BY x.mu DESC) INTO kin
    FROM (
        SELECT realize(c.object_id, p_lang) AS lbl, (c.rating - 2*c.rd) AS mu
        FROM consensus c
        WHERE c.subject_id = syn AND relation_highway_band(c.type_id) = b_assoc
          AND c.object_id <> COALESCE(parent, '\x00'::bytea)
        ORDER BY (c.rating - 2*c.rd) DESC LIMIT 8
    ) x
    -- the associative band also carries mesh/structural edges; keep only real
    -- content concepts (skip bare ILI ids "09411430-n" and lexfile "noun.object").
    WHERE x.lbl IS NOT NULL
      AND x.lbl !~ '^[0-9]{6,}-[nvasr]$'
      AND x.lbl !~ '^(noun|verb|adj|adv|adjs)\.'
      AND x.lbl !~ ' '
    LIMIT 2;

    -- REALIZE: weave flowing prose from whatever was attested.
    IF gloss IS NOT NULL THEN
        out := initcap(COALESCE(label, 'it')) || ' is ' || gloss || '.';
    ELSIF label IS NOT NULL THEN
        out := 'The concept ' || label || ' is one I hold.';
    END IF;

    IF parent_lbl IS NOT NULL THEN
        out := out || ' It is a kind of ' || parent_lbl;
        IF parent_gloss IS NOT NULL THEN
            out := out || ' -- ' || parent_gloss;
        END IF;
        out := out || '.';
    END IF;

    IF parts IS NOT NULL THEN
        out := out || ' It has parts such as ' || parts || '.';
    END IF;

    IF kin IS NOT NULL THEN
        out := out || ' It is related to ' || kin || '.';
    END IF;

    RETURN btrim(out);
END;
$$;
