CREATE OR REPLACE FUNCTION entities_exist_bitmap(ids bytea[])     RETURNS bytea     AS 'MODULE_PATHNAME', 'pg_laplace_entities_exist_bitmap'     LANGUAGE C STABLE;  CREATE OR REPLACE FUNCTION entities_present_ordinals(p_ids bytea[])     RETURNS TABLE(idx int)     LANGUAGE sql STABLE PARALLEL SAFE     SET search_path = @extschema@, public AS $$     SELECT (u.ord - 1)::int     FROM unnest(p_ids) WITH ORDINALITY u(id, ord)     JOIN entities e ON e.id = u.id $$;  CREATE OR REPLACE FUNCTION table_present_ordinals(p_table text, p_ids bytea[])     RETURNS TABLE(idx int)     LANGUAGE plpgsql STABLE PARALLEL SAFE     SET search_path = @extschema@, public AS $$ BEGIN     IF p_table = 'entities' THEN         RETURN QUERY SELECT * FROM entities_present_ordinals(p_ids);     ELSIF p_table = 'physicalities' THEN         RETURN QUERY         SELECT (u.ord - 1)::int         FROM unnest(p_ids) WITH ORDINALITY u(id, ord)         JOIN physicalities t ON t.id = u.id;     ELSIF p_table = 'attestations' THEN         RETURN QUERY         SELECT (u.ord - 1)::int         FROM unnest(p_ids) WITH ORDINALITY u(id, ord)         JOIN attestations t ON t.id = u.id;     ELSE         RAISE EXCEPTION 'table_present_ordinals: unknown table %', p_table;     END IF; END; $$;  CREATE OR REPLACE FUNCTION content_descent_novel_ordinals(p_ids bytea[], p_parents int[])     RETURNS TABLE(idx int)     LANGUAGE sql STABLE PARALLEL SAFE     SET search_path = @extschema@, public AS $$     WITH RECURSIVE nodes(idx, id, parent) AS (         SELECT (u.ord - 1)::int, u.id, p_parents[u.ord]         FROM unnest(p_ids) WITH ORDINALITY u(id, ord)     ), descent AS (         SELECT n.idx, NOT EXISTS (SELECT 1 FROM entities e WHERE e.id = n.id) AS novel         FROM nodes n WHERE n.parent < 0         UNION ALL         SELECT c.idx, NOT EXISTS (SELECT 1 FROM entities e WHERE e.id = c.id)         FROM descent d         JOIN nodes c ON c.parent = d.idx         WHERE d.novel     )     SELECT d.idx FROM descent d WHERE d.novel $$;  