{
  "kind": "laplace.recipe",
  "name": "chat-min-v1",
  "structure": "dense",
  "hidden_size": 256,
  "num_layers": 1,
  "rope": true,
  "tie_embeddings": false,
  "norm": "rmsnorm",
  "vocab": { "source": "crawl", "seeds": ["the","king","water","good","time","people","make","world","day","said"], "hops": 2, "fanout": 30, "size": 1500 },
  "embed": { "op": "coord" },
  "lm_head": { "op": "trajectory" },
  "compile": "continuation",
  "layers": [
    { "kv_heads": 4, "heads": [ {"op":"context"}, {"op":"trajectory"}, {"op":"relation","type":"PRECEDES"}, {"op":"trajectory"} ], "ffn": {"op":"trajectory"} }
  ]
}
