CREATE OR REPLACE FUNCTION entities_exist_bitmap(ids bytea[])     RETURNS bytea     AS 'MODULE_PATHNAME', 'pg_laplace_entities_exist_bitmap'     LANGUAGE C STABLE;  CREATE OR REPLACE FUNCTION entities_present_ordinals(p_ids bytea[])     RETURNS TABLE(idx int)     LANGUAGE sql STABLE PARALLEL SAFE     SET search_path = @extschema@, public AS $$     SELECT (u.ord - 1)::int     FROM unnest(p_ids) WITH ORDINALITY u(id, ord)     JOIN entities e ON e.id = u.id $$;  CREATE OR REPLACE FUNCTION table_present_ordinals(p_table text, p_ids bytea[])     RETURNS TABLE(idx int)     LANGUAGE plpgsql STABLE PARALLEL SAFE     SET search_path = @extschema@, public AS $$ BEGIN     IF p_table = 'entities' THEN         RETURN QUERY SELECT * FROM entities_present_ordinals(p_ids);     ELSIF p_table = 'physicalities' THEN         RETURN QUERY         SELECT (u.ord - 1)::int         FROM unnest(p_ids) WITH ORDINALITY u(id, ord)         JOIN physicalities t ON t.id = u.id;     ELSIF p_table = 'attestations' THEN         RETURN QUERY         SELECT (u.ord - 1)::int         FROM unnest(p_ids) WITH ORDINALITY u(id, ord)         JOIN attestations t ON t.id = u.id;     ELSE         RAISE EXCEPTION 'table_present_ordinals: unknown table %', p_table;     END IF; END; $$;  CREATE OR REPLACE FUNCTION content_descent_novel_ordinals(p_ids bytea[], p_parents int[])     RETURNS TABLE(idx int)     LANGUAGE sql STABLE PARALLEL SAFE     SET search_path = @extschema@, public AS $$     WITH RECURSIVE nodes(idx, id, parent) AS (         SELECT (u.ord - 1)::int, u.id, p_parents[u.ord]         FROM unnest(p_ids) WITH ORDINALITY u(id, ord)     ), descent AS (         SELECT n.idx, NOT EXISTS (SELECT 1 FROM entities e WHERE e.id = n.id) AS novel         FROM nodes n WHERE n.parent < 0         UNION ALL         SELECT c.idx, NOT EXISTS (SELECT 1 FROM entities e WHERE e.id = c.id)         FROM descent d         JOIN nodes c ON c.parent = d.idx         WHERE d.novel     )     SELECT d.idx FROM descent d WHERE d.novel $$;  -- Universal O(tier) containment probe ΓÇö the top-down sibling of entities_exist_bitmap. The substrate -- IS a content-addressed Merkle DAG: an entity's id = BLAKE3(its constituents), so a PRESENT trunk -- implies its whole subtree is present. Given a batch's tree as node ids + a parent-index array -- (parents[k] = 0-based index of node k's parent, < 0 for a root), it returns the SAME present-bitmap -- contract as entities_exist_bitmap (bit k set Γƒ║ candidate k present, LSB-first) but descends ONLY -- under novel parents ΓÇö a present trunk short-circuits its subtree, so re-ingesting known content -- costs O(tier-depth) DB checks, not O(nodes). The bitmap is built in C (one home for the bit -- convention); the native content emit then does the staging descent. This is how dedup works for -- EVERY source and modality ΓÇö the schema's operating model, not a per-decomposer add-on. (T0/T1 -- codepoints/graphemes are perfcache-known and are simply never put in the tree handed here.) CREATE OR REPLACE FUNCTION content_descent_bitmap(ids bytea[], parents int[])     RETURNS bytea     AS 'MODULE_PATHNAME', 'pg_laplace_content_descent_bitmap'     LANGUAGE C STABLE;