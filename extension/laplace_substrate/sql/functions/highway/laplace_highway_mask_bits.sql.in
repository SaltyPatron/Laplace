-- Set bit positions of a highway mask as int4[] — the indexable form. GIN over
-- this expression serves bit-overlap plane queries (bits && band-bits) with
-- posting lists built for duplicate-heavy keys, replacing the pathological
-- hash-on-66-distinct-values indexes removed in Issue 36.
CREATE OR REPLACE FUNCTION laplace_highway_mask_bits(mask bytea)
    RETURNS int[]
    AS 'MODULE_PATHNAME', 'pg_laplace_highway_mask_bits'
    LANGUAGE C IMMUTABLE;
