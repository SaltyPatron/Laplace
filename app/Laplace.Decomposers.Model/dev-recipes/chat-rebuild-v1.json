{
  "kind": "laplace.recipe",
  "name": "chat-rebuild-v1",
  "structure": "dense",
  "hidden_size": 256,
  "num_layers": 4,
  "rope": true,
  "tie_embeddings": false,
  "norm": "rmsnorm",
  "vocab": { "source": "crawl", "seeds": ["the","king","water","good","time","people","make","world","day","said"], "hops": 2, "fanout": 30, "size": 1500 },
  "embed": { "op": "coord" },
  "lm_head": { "op": "trajectory" },
  "compile": "continuation",
  "layers": [
    { "kv_heads": 4, "heads": [ {"op":"context"}, {"op":"metric","metric":"angular"}, {"op":"relation","type":"IS_SYNONYM_OF"}, {"op":"relation","type":"RELATED_TO"} ], "ffn": {"op":"unary"} },
    { "kv_heads": 4, "heads": [ {"op":"context"}, {"op":"relation","type":"IS_A"}, {"op":"metric","metric":"frechet"}, {"op":"relation","type":"RELATED_TO"} ], "ffn": {"op":"unary"} },
    { "kv_heads": 4, "heads": [ {"op":"context"}, {"op":"relation","type":"PRECEDES"}, {"op":"trajectory"}, {"op":"relation","type":"RELATED_TO"} ], "ffn": {"op":"trajectory"} },
    { "kv_heads": 4, "heads": [ {"op":"context"}, {"op":"trajectory"}, {"op":"relation","type":"PRECEDES"}, {"op":"metric","metric":"angular"} ], "ffn": {"op":"trajectory"} }
  ]
}
