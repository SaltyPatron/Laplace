# Line endings: LF for source, native for scripts that must run on Windows
*           text=auto eol=lf

# Windows-only scripts keep CRLF
*.ps1       text eol=crlf
*.psm1      text eol=crlf
*.psd1      text eol=crlf
*.cmd       text eol=crlf
*.bat       text eol=crlf

# Source code
*.c         text eol=lf
*.h         text eol=lf
*.cpp       text eol=lf
*.hpp       text eol=lf
*.cc        text eol=lf
*.cs        text eol=lf
*.csproj    text eol=lf
*.props     text eol=lf
*.targets   text eol=lf
*.sln       text eol=lf
*.slnx      text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.md        text eol=lf
*.sql       text eol=lf
CMakeLists.txt text eol=lf
*.cmake     text eol=lf

# Binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.tar       binary
*.gz        binary
*.bz2       binary
*.xz        binary
*.7z        binary
*.dll       binary
*.exe       binary
*.lib       binary
*.so        binary
*.dylib     binary
*.pdb       binary
*.safetensors binary
*.bin       binary
*.onnx      binary

# Diff hints
*.cs        diff=csharp
*.c         diff=cpp
*.cpp       diff=cpp
*.h         diff=cpp
*.hpp       diff=cpp
*.md        diff=markdown
