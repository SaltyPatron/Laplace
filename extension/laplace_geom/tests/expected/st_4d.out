SET client_min_messages = warning;
CREATE EXTENSION IF NOT EXISTS postgis;
CREATE EXTENSION IF NOT EXISTS laplace_geom;
RESET client_min_messages;
SELECT laplace_distance_4d(
    ST_MakePoint(1.0, 2.0, 3.0, 4.0),
    ST_MakePoint(1.0, 2.0, 3.0, 4.0)
) AS distance_same;
