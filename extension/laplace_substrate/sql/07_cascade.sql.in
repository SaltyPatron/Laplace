CREATE OR REPLACE FUNCTION astar_path_raw(     p_start     bytea,     p_goals     bytea[],     p_types     bytea[],     p_max_depth int  DEFAULT 7,     p_directed  bool DEFAULT false)     RETURNS TABLE(step int, entity_id bytea, g double precision)     AS 'MODULE_PATHNAME', 'pg_laplace_astar_path'     LANGUAGE C STABLE;