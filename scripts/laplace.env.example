# Laplace environment — copy to laplace.env (or export in shell) and adjust for your host.
# Windows: scripts/win/env.cmd sets most of these; INGEST maps to LAPLACE_DATA_ROOT.
# Linux/CI self-hosted: defaults assume /vault/Data and peer-auth PostgreSQL.

# --- Data layout (witness-manifest.json vault_root) ---
# Primary control: LAPLACE_DATA_ROOT. Relative witness paths (SemLink, Wordnet, …) live under it.
# Linux/CI default; Windows env.cmd sets INGEST then LAPLACE_DATA_ROOT=%INGEST% when unset.
LAPLACE_DATA_ROOT=/vault/Data
# Windows legacy alias (env.cmd sets LAPLACE_DATA_ROOT=%INGEST% when INGEST is set)
# INGEST=D:\Data\Ingest
# LAPLACE_CILI_DIR=$LAPLACE_DATA_ROOT/CILI   # Predicate Matrix / ILI resolution (optional override)
#
# FrameNet→WordNet LU bridges (after wordnet + framenet ingest):
#   MapNet:       http://danielepighin.net/cms/files/MapNet-0.1.zip → $LAPLACE_DATA_ROOT/MapNet-0.1/
#                 mapping_frame_synsets.txt, mapping_lus_synsets.txt (tab: frame, luName, pos#offset)
#   WordFrameNet: https://adimen.ehu.eus/web/files/WordFrameNet/WFN.tar.gz → $LAPLACE_DATA_ROOT/WordFrameNet/
#                 or XWFN.tar.gz → $LAPLACE_DATA_ROOT/eXtendedWFN/ (lu_synset.map or *.txt tab rows)

LAPLACE_MODEL_HUB=/vault/Models/hub
# REPOS=/vault/Repositories

# --- Database ---
LAPLACE_DBNAME=laplace
# Canonical cumulative DB — grows only when decomposer-promote re-ingests a validated source.
LAPLACE_CANONICAL_DB=laplace
# Isolated proof DB prefix: laplace_d_<source> (throwaway; fresh db-isolate per test).
LAPLACE_ISOLATE_PREFIX=laplace_d
# LAPLACE_DB=Host=localhost;Username=postgres;Password=postgres;Database=laplace
# PGPASSWORD=postgres   # dev default in scripts/win/env.cmd — override in production

# --- Decomposer matrix (isolate → promote; no pg clone) ---
#
# 1. TEST  — fresh laplace_d_<source>: db-isolate, prerequisite ingests (from
#            decomposer-gates.json, e.g. omw runs wordnet first), target ingest, gates.
# 2. PROMOTE — re-run the same ingest on laplace (idempotent); canonical DB accumulates.
# 3. MATRIX — test → promote → next source in manifest order.
#
# Isolated DBs are throwaway proof environments, not templates copied forward.
#
# Windows:
#   scripts\win\decomposer-test.cmd wordnet
#   scripts\win\decomposer-promote.cmd wordnet
#   scripts\win\decomposer-matrix.cmd              # full test+promote ladder
#   scripts\win\decomposer-matrix.cmd --test-only  # proof only, no promote
#   scripts\win\decomposer-matrix.cmd --from omw    # resume after failure
#   scripts\win\decomposer-smoke.cmd               # unicode test + promote smoke
# Linux/just:
#   just decomposer-test wordnet
#   just decomposer-promote wordnet
#   just decomposer-matrix --test-only
#
# Gate reports: .ingest-proof/decomposer-<source>.json
# Promote markers: .ingest-proof/promoted/<source>.marker

# --- Ingest orchestration ---
LAPLACE_INGEST_LANGS=
LAPLACE_INGEST_WORKERS=1
LAPLACE_INGEST_BATCH=65536
LAPLACE_SKIP_USAGE=0
LAPLACE_SKIP_MODELS=0
LAPLACE_PERSIST_EVIDENCE=

# Ladder knobs (scripts/win/seed-ladder.cmd, witness-manifest stop_and_resume_knobs)
LAPLACE_LADDER_START=floor
LAPLACE_LADDER_STOP=
LAPLACE_LADDER_DRY=0

# Resume helpers
INGEST_FROM=
INGEST_DOCUMENT_PATH=
INGEST_LOGDIR=/tmp

# --- Model paths (ingest safetensors / synthesis) ---
# LAPLACE_TINYLLAMA_DIR=/path/to/HF/snapshot
# LAPLACE_MODEL_TINYLLAMA=
# LAPLACE_MODEL_PHI=
# LAPLACE_MODEL_QWEN25_CODER=

# --- Build/runtime ---
# LAPLACE_ROOT=/path/to/Laplace
# LAPLACE_PERFCACHE_BIN=
# LAPLACE_INSTALL_PREFIX=/opt/laplace
