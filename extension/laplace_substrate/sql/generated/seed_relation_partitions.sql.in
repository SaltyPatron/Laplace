-- GENERATED by scripts/codegen-attestation-law.py — do not edit.
-- Highway-axis partitions: hot relations get HASH(subject_id) x8 partitions
-- on consensus + attestations; the low-volume tail shares DEFAULT.
DO $$
DECLARE
    hot text[] := ARRAY[
        'APPEARS_IN',
        'ATTENDS',
        'COMPLETES_TO',
        'CONTAINS',
        'CONTINUES_TO',
        'HAS_DEFINITION',
        'HAS_LANGUAGE',
        'HAS_POS',
        'HAS_SENSE',
        'HAS_SYNSET_KEY',
        'IS_A',
        'IS_SENSE_OF',
        'IS_SYNONYM_OF',
        'MOVE',
        'OV_RELATES',
        'PRECEDES',
        'SIMILAR_TO',
        'TOKEN_MAPS_TO'
    ];
    r text; rid bytea; tbl text; part text; i int;
    -- storage params are per-LEAF (PG forbids them on partitioned parents)
    opts text := ' SET (autovacuum_analyze_scale_factor = 0.02, autovacuum_analyze_threshold = 100000)';
BEGIN
    IF (SELECT c.relkind FROM pg_class c JOIN pg_namespace ns ON ns.oid = c.relnamespace
        WHERE ns.nspname = current_schema() AND c.relname = 'consensus') <> 'p' THEN
        RETURN;  -- legacy plain tables: greenfield layout applies on fresh installs only
    END IF;
    FOREACH r IN ARRAY hot LOOP
        rid := relation_type_id(r);
        FOREACH tbl IN ARRAY ARRAY['consensus', 'attestations'] LOOP
            part := tbl || '_r_' || lower(r);
            IF to_regclass(current_schema() || '.' || part) IS NOT NULL THEN
                CONTINUE;
            END IF;
            EXECUTE format('CREATE TABLE %I PARTITION OF %I FOR VALUES IN (%L) PARTITION BY HASH (subject_id)', part, tbl, rid);
            FOR i IN 0..7 LOOP
                EXECUTE format('CREATE TABLE %I PARTITION OF %I FOR VALUES WITH (MODULUS 8, REMAINDER %s)', part || '_h' || i, part, i);
                EXECUTE format('ALTER TABLE %I', part || '_h' || i) || opts;
            END LOOP;
        END LOOP;
    END LOOP;
END $$;
