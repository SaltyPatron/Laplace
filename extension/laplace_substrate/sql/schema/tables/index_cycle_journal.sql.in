-- Crash-recovery journal for bulk-load index cycling. The working-set apply
-- drops secondary indexes before a fresh-seed-shaped COPY and rebuilds them
-- after; each dropped index's definition is journaled here in its own
-- committed transaction first. Rows are deleted as rebuilds succeed, so a
-- non-empty journal after a crash lists exactly the indexes to re-create.
CREATE TABLE IF NOT EXISTS index_cycle_journal (
    index_name  text         PRIMARY KEY,
    table_name  text         NOT NULL,
    index_def   text         NOT NULL,
    dropped_at  timestamptz  NOT NULL DEFAULT now()
);
