# Chess Lab external binaries (Windows dev host).
# Copy to deploy\secrets\chess-lab.env (gitignored). Loaded by the API at startup
# (Program.cs -> ChessLabPaths.LoadEnvFile). Does not override existing env vars.
#
# Build cutechess: scripts\win\build-cutechess.cmd
# Build laplace-uci: dotnet build app\Laplace.Chess.Uci -c Release

LAPLACE_CUTECHESS=<path-to-cutechess-cli.exe>
LAPLACE_STOCKFISH=<path-to-stockfish.exe>
LAPLACE_QT_BIN=<path-to-qt-msvc-bin>
LAPLACE_UCI=<path-to-laplace-uci.exe>
