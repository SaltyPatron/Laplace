  CREATE INDEX IF NOT EXISTS entities_tier_brin     ON entities USING brin (tier) WITH (pages_per_range = 128);  CREATE INDEX IF NOT EXISTS entities_tier_type_brin     ON entities USING brin (tier, type_id) WITH (pages_per_range = 64);  COMMENT ON INDEX entities_tier_brin IS     'BRIN tier banding for ingest validation and tier-distribution reads at scale.';