-- ── generation surface ────────────────────────────────────────────────────────
-- Stride-continuation generation over witnessed content trajectories.
-- SINGLE SOURCE: physicalities.trajectory — each vertex mantissa-encodes its
-- entity id, so the geometry IS the sequence. The kernel (trajectory_walk.c)
-- builds a backend-cached trajectory stream straight from the trajectories (edge scan +
-- constituency walk to the token floor), then a suffix array; longest-context
-- stride descent is binary search; weighted selection is seeded, so (stream, prompt, seed)
-- reproduces its output exactly. When the witnessed stream is silent at every
-- order, the COMPLETES_TO consensus is the floor (steps marked stride_used = 0).
--
-- The separator rule (word stride): whitespace tokens are witnessed content
-- (round-trip law) but are NOT units of order — the stream excludes them, so
-- contexts, pairs, and gap distances count in content-bearing strides. Display
-- re-inserts separators (SubstrateClient.cs is the single separator authority).
--
-- There is no content_index table, no constituency_edge table, no content_pairs
-- cache — those were derived disk copies of the trajectories and are retired.

-- refresh-safe retirement of the derived copies (live DBs converge on refresh;
-- retired objects may be extension MEMBERS there — membership drops first)
DO $do$
DECLARE
    obj text;
BEGIN
    FOREACH obj IN ARRAY ARRAY[
        'TABLE @extschema@.content_pairs',
        'PROCEDURE @extschema@.rebuild_content_index(int)',
        'PROCEDURE @extschema@.rebuild_content_index_deep()',
        'PROCEDURE @extschema@.rebuild_content_pairs(int)']
    LOOP
        BEGIN
            EXECUTE format('ALTER EXTENSION %I DROP %s', 'laplace_substrate', obj);
        EXCEPTION WHEN OTHERS THEN
            NULL;  -- not a member / does not exist: already converged
        END;
    END LOOP;
    EXECUTE 'DROP TABLE IF EXISTS @extschema@.content_pairs';
    EXECUTE 'DROP TABLE IF EXISTS @extschema@.content_index';
    EXECUTE 'DROP TABLE IF EXISTS @extschema@.constituency_edge';
    EXECUTE 'DROP PROCEDURE IF EXISTS @extschema@.rebuild_content_index(int)';
    EXECUTE 'DROP PROCEDURE IF EXISTS @extschema@.rebuild_content_index_deep()';
    EXECUTE 'DROP PROCEDURE IF EXISTS @extschema@.rebuild_content_pairs(int)';
    -- retired foundry-export experiments: the export reads consensus (foundry_vocab +
    -- entity_relation_plane), it does not re-fold trajectories at export time.
    EXECUTE 'DROP FUNCTION IF EXISTS @extschema@.entity_trajectory_plane(bytea[], int, int)';
    EXECUTE 'DROP FUNCTION IF EXISTS @extschema@.cooccurrence_scan(int, bytea[])';
END $do$;

-- trajectory-stream observability + warm verb: building the stream IS the warm-up; the
-- stats are the receipt (sequences walked, word-stride positions, distinct entities,
-- separators excluded, and the invalidation probe state).
CREATE OR REPLACE FUNCTION stream_stats(
        OUT sequences bigint, OUT positions bigint, OUT distinct_entities int,
        OUT separators bigint, OUT trajectories bigint, OUT last_witnessed timestamptz)
    AS 'MODULE_PATHNAME', 'pg_laplace_stream_stats'
    LANGUAGE C VOLATILE;

-- Trajectory pairs straight from the trajectory stream (word-stride by
-- construction): one walk, sliding window, in-memory hash aggregation —
-- engine computes, SQL orchestrates.
-- Native trajectory-pair scan: the GENERATION co-occurrence surface (relation_plane
-- 'traj', trajectory_cooccurrence). The foundry's order ladder does NOT use this — it
-- reads the trajectories set-based in SQL (entity_trajectory_plane). One walk over the
-- per-backend stream, in-memory hash aggregation.
CREATE OR REPLACE FUNCTION cooccurrence_scan(p_max_gap int)
    RETURNS TABLE(gap int, subject_id bytea, object_id bytea, cnt bigint)
    AS 'MODULE_PATHNAME', 'pg_laplace_cooccurrence_scan'
    LANGUAGE C STRICT VOLATILE;

-- Trajectory pair surface for the foundry: forward co-occurrence counts within
-- a window over witnessed content sequences, with per-subject totals so callers
-- form conditional frequencies — the "followed by N% of the time" distribution.
-- p_window=1 is strict continuation; larger windows give the forward co-occurrence
-- surface.
CREATE OR REPLACE FUNCTION trajectory_cooccurrence(p_window int DEFAULT 1)
    RETURNS TABLE(subject_id bytea, object_id bytea, cnt bigint, subject_total bigint)
    LANGUAGE sql VOLATILE
    SET search_path = @extschema@, public AS $$
    -- one GROUP BY collapses the native scan's per-gap rows; the per-subject total
    -- comes from a window over that result, NOT a second GROUP BY + self-join (which
    -- re-scanned the aggregate). Single pass, matches trajectory_cooccurrence_by_stride.
    WITH pairs AS (
        SELECT s.subject_id, s.object_id, sum(s.cnt) AS cnt
        FROM cooccurrence_scan(p_window) s
        GROUP BY s.subject_id, s.object_id
    )
    SELECT p.subject_id, p.object_id, p.cnt::bigint,
           sum(p.cnt) OVER (PARTITION BY p.subject_id)::bigint
    FROM pairs p
$$;

-- The order ladder, one pass: pair counts BY GAP (exact forward word-stride
-- distance within a witnessed sequence) up to p_max_gap, with per-(subject,gap)
-- totals. The foundry pours gap g into layer g of the mold — depth in the cast
-- model is bought with sequential order from the trajectories.
CREATE OR REPLACE FUNCTION trajectory_cooccurrence_by_stride(p_max_gap int DEFAULT 8)
    RETURNS TABLE(subject_id bytea, object_id bytea, gap int, cnt bigint, subject_total bigint)
    LANGUAGE sql VOLATILE
    SET search_path = @extschema@, public AS $$
    SELECT s.subject_id, s.object_id, s.gap, s.cnt,
           sum(s.cnt) OVER (PARTITION BY s.subject_id, s.gap)::bigint
    FROM cooccurrence_scan(p_max_gap) s
$$;

-- MATERIALIZED order ladder. trajectory_cooccurrence_by_stride is correct but pays the
-- per-backend corpus stream rebuild on EVERY call (the 33-minute scan). This stores its
-- output once, keyed to the SAME trajectory probe the corpus uses (row count + max
-- observed_at), so it is a derived AGGREGATE invalidated by its source, not a drifting
-- cache: any deposit that moves the probe forces a rebuild on next ensure. Readers do an
-- index scan instead of rebuilding the stream. (The in-memory corpus is already a derived
-- copy of the trajectories; persisting the aggregate is the same copy paid once, globally,
-- instead of per backend.)
CREATE TABLE IF NOT EXISTS trajectory_pairs (
    subject_id    bytea  NOT NULL,
    object_id     bytea  NOT NULL,
    gap           int    NOT NULL,
    cnt           bigint NOT NULL,
    subject_total bigint NOT NULL
);
CREATE INDEX IF NOT EXISTS trajectory_pairs_subject_idx ON trajectory_pairs (subject_id);

CREATE TABLE IF NOT EXISTS trajectory_pairs_meta (
    only_row     boolean PRIMARY KEY DEFAULT true CHECK (only_row),
    probe_rows   bigint  NOT NULL,
    probe_max_us bigint  NOT NULL,
    max_gap      int     NOT NULL,
    built_at     timestamptz NOT NULL DEFAULT now()
);

-- Rebuild iff the trajectory probe moved or a deeper gap is requested than materialized.
-- The expensive stream build happens HERE, once, not in every reader. Returns row count.
CREATE OR REPLACE FUNCTION trajectory_pairs_ensure(p_max_gap int DEFAULT 8)
    RETURNS bigint
    LANGUAGE plpgsql VOLATILE
    SET search_path = @extschema@, public AS $$
DECLARE
    cur_rows bigint;
    cur_us   bigint;
    m        trajectory_pairs_meta%ROWTYPE;
    n        bigint;
BEGIN
    SELECT count(*)::bigint,
           COALESCE((extract(epoch FROM max(observed_at)) * 1000000)::bigint, 0)
      INTO cur_rows, cur_us
      FROM physicalities
     WHERE type = 1 AND trajectory IS NOT NULL;

    SELECT * INTO m FROM trajectory_pairs_meta WHERE only_row;
    IF FOUND AND m.probe_rows = cur_rows AND m.probe_max_us = cur_us
       AND m.max_gap >= p_max_gap THEN
        RETURN (SELECT count(*) FROM trajectory_pairs);   -- fresh: no rebuild
    END IF;

    TRUNCATE trajectory_pairs;
    INSERT INTO trajectory_pairs (subject_id, object_id, gap, cnt, subject_total)
    SELECT subject_id, object_id, gap, cnt, subject_total
    FROM trajectory_cooccurrence_by_stride(p_max_gap);
    GET DIAGNOSTICS n = ROW_COUNT;

    INSERT INTO trajectory_pairs_meta (only_row, probe_rows, probe_max_us, max_gap, built_at)
    VALUES (true, cur_rows, cur_us, p_max_gap, now())
    ON CONFLICT (only_row) DO UPDATE
        SET probe_rows = excluded.probe_rows, probe_max_us = excluded.probe_max_us,
            max_gap = excluded.max_gap, built_at = excluded.built_at;
    RETURN n;
END $$;

-- Vocab-bounded read of the materialized ladder: index scan by subject, gap-discounted
-- conditional continuation w = Σ_gap (cnt/subject_total)/gap, both endpoints in vocab.
-- This is the foundry's order source — no stream rebuild.
CREATE OR REPLACE FUNCTION trajectory_pairs_plane(p_vocab bytea[], p_max_gap int DEFAULT 8)
    RETURNS TABLE(subject_id bytea, object_id bytea, w double precision)
    LANGUAGE sql STABLE
    SET search_path = @extschema@, public AS $$
    WITH v(id) AS (SELECT DISTINCT u FROM unnest(p_vocab) AS u)
    SELECT t.subject_id, t.object_id,
           sum( (t.cnt::float8 / NULLIF(t.subject_total, 0)) / t.gap )::float8 AS w
    FROM trajectory_pairs t
    JOIN v vs ON vs.id = t.subject_id
    JOIN v vo ON vo.id = t.object_id
    WHERE t.gap <= p_max_gap
    GROUP BY t.subject_id, t.object_id
$$;

-- ── the generic plane surface ───────────────────────────────────────────────────
-- ONE read surface for entity→entity strength, whatever the source: adjudicated
-- consensus arenas, or readings of the content trajectories (which carry
-- precedes/follows/co-occurs at every gap without new records). Everything that
-- consumes planes — the foundry, audits, walk views — reads THIS, so sources are
-- interchangeable, combinations are plain SQL, and the surface is regress-pinnable.
--
--   relation_plane('consensus', 'SIMILAR_TO')   eff-μ RELATIVE TO NEUTRAL, in μ units
--                                               (signed: refuted < 0 < confirmed)
--   relation_plane('traj', 'next')              P(object follows subject), gap 1
--   relation_plane('traj', 'gap', 3)            P(object at exact distance 3 | subject)
--   relation_plane('traj', 'window', 4)         P(object within 4 ahead | subject)
--
-- Trajectory families read the trajectory stream (word stride) via the native scan.
CREATE OR REPLACE FUNCTION relation_plane(p_family text, p_name text, p_arg int DEFAULT NULL)
    RETURNS TABLE(subject_id bytea, object_id bytea, w double precision)
    LANGUAGE plpgsql VOLATILE
    SET search_path = @extschema@, public AS $$
DECLARE
    g int;
BEGIN
    IF p_family = 'consensus' THEN
        RETURN QUERY
        SELECT c.subject_id, c.object_id,
               (eff_mu(c.rating, c.rd) - glicko2_neutral_mu())::double precision / 1e9
        FROM consensus c
        WHERE c.type_id = relation_type_id(p_name) AND c.object_id IS NOT NULL;
        RETURN;
    END IF;

    IF p_family <> 'traj' THEN
        RAISE EXCEPTION 'relation_plane: unknown family % (consensus | traj)', p_family;
    END IF;

    g := CASE p_name
             WHEN 'next'   THEN 1
             WHEN 'gap'    THEN COALESCE(p_arg, 1)
             WHEN 'window' THEN COALESCE(p_arg, 4)
             ELSE NULL
         END;
    IF g IS NULL THEN
        RAISE EXCEPTION 'relation_plane: unknown traj plane % (next | gap | window)', p_name;
    END IF;

    IF p_name = 'window' THEN
        RETURN QUERY
        SELECT t.subject_id, t.object_id, t.cnt::double precision / t.subject_total
        FROM trajectory_cooccurrence(g) t;
        RETURN;
    END IF;

    RETURN QUERY
    SELECT t.subject_id, t.object_id, t.cnt::double precision / t.subject_total
    FROM trajectory_cooccurrence_by_stride(g) t WHERE t.gap = g;
END;
$$;

-- Vocab-bounded entity→entity consensus plane: ONLY the vocab×vocab edges of the
-- given relation types, degree-capped per subject by |eff-μ|, computed server-side
-- via the (subject_id, type_id) index — no full-type scan, no row streaming to the
-- client. The foundry passes its vocab entity set + the relation names for a role
-- (similarity / relation / completion / co-occurrence) and gets back exactly the
-- intra-vocab adjacency it pours, already capped. PARALLEL SAFE so PG fans it out.
CREATE OR REPLACE FUNCTION entity_relation_plane(
        p_vocab bytea[], p_rel_names text[], p_degree_cap int DEFAULT 48)
    RETURNS TABLE(subject_id bytea, object_id bytea, w double precision)
    LANGUAGE sql STABLE PARALLEL SAFE
    SET search_path = @extschema@, public AS $$
    WITH v(id) AS (SELECT DISTINCT u FROM unnest(p_vocab) AS u),
         t(tid) AS (SELECT relation_type_id(n) FROM unnest(p_rel_names) AS n),
         edges AS MATERIALIZED (
             -- MATERIALIZED: same inlining trap as consensus_adjacency — inlined, the
             -- join + eff_mu re-run per scanned row; pinning one eval per edge measured
             -- 13x (729ms → 55ms, vocab 5000). Smaller multiplier than the rank planes
             -- (eff_mu is cheaper than relation_rank) but the same shape and the same win.
             SELECT c.subject_id, c.object_id,
                    (eff_mu(c.rating, c.rd) - glicko2_neutral_mu())::double precision / 1e9 AS w
             FROM v
             JOIN consensus c ON c.subject_id = v.id
             JOIN t           ON t.tid = c.type_id
             JOIN v vo        ON vo.id = c.object_id   -- hash join, O(edges); never an
                                                       -- EXISTS-over-unnest (the large-vocab hang)
         ),
         capped AS (
             SELECT e.subject_id, e.object_id, e.w,
                    row_number() OVER (PARTITION BY e.subject_id
                                       ORDER BY abs(e.w) DESC, e.object_id) AS rn
             FROM edges e
         )
    SELECT c.subject_id, c.object_id, c.w FROM capped c WHERE c.rn <= p_degree_cap
$$;

-- WITHIN-LAYER plane (the export's data source done right): the rated adjacency among the
-- vocab for ONE layer = one rank band. Stays inside the layer (the ranks ARE the layers):
--   * relation_rank IS NOT NULL  -> a relation in the banked law (drops unnamed/unregistered types)
--   * relation_rank BETWEEN lo,hi -> the layer's rank band (e.g. 0.45..0.85 = the semantic layers)
--   * object in the vocab          -> the claim points at CONTENT, not a schema anchor (drops HAS_POS
--                                     etc. whose object is a grammatical anchor)
-- weight w = eff_mu (the adjudicated rating; positive affinity), degree-capped by rank*eff_mu.
-- The export transcribes one of these per rank into the container's per-layer slots — no flatten,
-- no metadata, no learning. See memory attestations-are-tensors / layering-data-class-law.
CREATE OR REPLACE FUNCTION consensus_layer_plane(
        p_vocab bytea[], p_rank_lo float8, p_rank_hi float8, p_degree_cap int DEFAULT 48)
    RETURNS TABLE(subject_id bytea, object_id bytea, w double precision, layer_rank double precision)
    LANGUAGE sql STABLE PARALLEL RESTRICTED  -- relation_rank_resolved may SPI (dynamic-type IS_A walk); leader-only
    SET search_path = @extschema@, public AS $$
    WITH v(id) AS (SELECT DISTINCT u FROM unnest(p_vocab) AS u),
         edges AS MATERIALIZED (
             -- MATERIALIZED is load-bearing, not stylistic. Inlined (single-reference
             -- CTE), the planner re-expands the rk alias into relation_rank(type_id) at
             -- the pushed-down index-scan filter, evaluating it once per SCANNED consensus
             -- row (~78k at vocab 5000) instead of once per surviving edge (~1.5k).
             -- Materializing pins one eval per edge; measured 76x (7.8s → 0.1s, vocab 5000).
             SELECT c.subject_id, c.object_id, c.rating, c.rd,
                    relation_rank_resolved(c.type_id) AS rk  -- RESOLVED: dynamic UD types (DEP_/EDEP_/FEAT_) inherit rank via IS_A; bare relation_rank() = NULL for them, and the rk IS NOT NULL filter below was dropping 533 types / ~234k edges from every export plane
             FROM v
             JOIN consensus c ON c.subject_id = v.id
             JOIN v vo        ON vo.id = c.object_id   -- hash join, O(edges); never an
                                                       -- EXISTS-over-unnest (the large-vocab hang)
         ),
         ranked AS (
             SELECT e.subject_id, e.object_id,
                    (eff_mu(e.rating, e.rd))::float8 / 1e9 AS w, e.rk
             FROM edges e
             WHERE e.rk IS NOT NULL AND e.rk BETWEEN p_rank_lo AND p_rank_hi
         ),
         capped AS (
             SELECT r.subject_id, r.object_id, r.w, r.rk,
                    row_number() OVER (PARTITION BY r.subject_id ORDER BY r.rk * r.w DESC, r.object_id) AS rn
             FROM ranked r
         )
    SELECT c.subject_id, c.object_id, c.w, c.rk FROM capped c WHERE c.rn <= p_degree_cap
$$;

-- PER-TYPE head reader for the ATTESTATION-TENSOR cast (attestations ARE the tensors): one row
-- group per relation TYPE = one attention HEAD, the type's rank = its LAYER (11 ranks → 11 layers),
-- eff_mu = the head's weight. The transformer head h is the SPARSE rated adjacency A_h[X,Y] =
-- eff_mu(X, type_h, Y) — there is NO flat vocab² matrix and NO band collapse: each type stays its
-- own head, factored to head_dim on its own (few edges per token → low rank, trivial). Degree-capped
-- PER (subject, type) so every head is bounded. Same MATERIALIZED rk-eval discipline as the band
-- readers (one relation_rank eval per scanned consensus row, not per surviving edge).
CREATE OR REPLACE FUNCTION consensus_type_plane(
        p_vocab bytea[], p_degree_cap int DEFAULT 48)
    RETURNS TABLE(subject_id bytea, object_id bytea, w double precision,
                  type_id bytea, layer_rank double precision)
    LANGUAGE sql STABLE PARALLEL RESTRICTED  -- relation_rank_resolved may SPI (dynamic-type IS_A walk); leader-only
    SET search_path = @extschema@, public AS $$
    WITH v(id) AS (SELECT DISTINCT u FROM unnest(p_vocab) AS u),
         edges AS MATERIALIZED (
             SELECT c.subject_id, c.object_id, c.rating, c.rd, c.type_id,
                    relation_rank_resolved(c.type_id) AS rk  -- RESOLVED: dynamic UD types (DEP_/EDEP_/FEAT_) inherit rank via IS_A; bare relation_rank() = NULL for them, and the rk IS NOT NULL filter below was dropping 533 types / ~234k edges from every export plane
             FROM v
             JOIN consensus c ON c.subject_id = v.id
             JOIN v vo        ON vo.id = c.object_id
         ),
         ranked AS (
             SELECT e.subject_id, e.object_id,
                    (eff_mu(e.rating, e.rd))::float8 / 1e9 AS w, e.type_id, e.rk
             FROM edges e
             WHERE e.rk IS NOT NULL
         ),
         capped AS (
             SELECT r.subject_id, r.object_id, r.w, r.type_id, r.rk,
                    row_number() OVER (PARTITION BY r.subject_id, r.type_id
                                       ORDER BY r.w DESC, r.object_id) AS rn
             FROM ranked r
         )
    SELECT c.subject_id, c.object_id, c.w, c.type_id, c.rk
    FROM capped c WHERE c.rn <= p_degree_cap
$$;

-- FAITHFUL adjacency (the generative mold's transcription source): the rank-weighted rated
-- CONTENT adjacency among the vocab. Each X→Y edge weight is the SUM over every relation type
-- of relation_rank(type_id) · eff_mu — the rank read PER EDGE from the banked relation law
-- (engine/manifest/relation_types.toml is the single source; relation_rank() wraps the native
-- lookup), NEVER a hand-typed band weight in the caller. There is NO rank-band slicing: the
-- FULL ladder contributes, each relation by its OWN authority, so mandate>taxonomic>…>probationary
-- falls out of the data, not out of magic numbers. Content objects only — object must be IN the
-- vocab (a tier-2 wordform), which structurally drops schema/metadata claims like HAS_POS (whose
-- object is a grammatical anchor, not in the vocab). relation_rank IS NOT NULL drops unnamed/
-- unregistered types. Degree-capped per subject by the summed weight.
-- The generator writes lm_head = A, embed = I; in the cast, logits[Y] = √dim·lm_head[Y,X], and
-- the mold pre-divides A by √dim, so logits[Y] = A[Y,X] EXACTLY — the rank-weighted rating
-- looked up, the GEMM literally is the lookup. No SVD, no gains, no learning.
CREATE OR REPLACE FUNCTION consensus_adjacency(
        p_vocab bytea[], p_degree_cap int DEFAULT 64)
    RETURNS TABLE(subject_id bytea, object_id bytea, w double precision)
    LANGUAGE sql STABLE PARALLEL RESTRICTED  -- relation_rank_resolved may SPI (dynamic-type IS_A walk); leader-only
    SET search_path = @extschema@, public AS $$
    WITH v(id) AS (SELECT DISTINCT u FROM unnest(p_vocab) AS u),
         edges AS MATERIALIZED (
             -- BOTH endpoints joined to the vocab set (hash join, O(edges)) — never an
             -- EXISTS-over-unnest, which is a per-edge linear scan of the array (O(edges·vocab),
             -- the hang at large vocab). subject ∈ vocab AND object ∈ vocab keeps the adjacency
             -- inside the token set and drops schema/metadata objects (HAS_POS' anchor ∉ vocab).
             -- MATERIALIZED is load-bearing: inlined, the planner re-expands rk into
             -- relation_rank(type_id) at the index-scan filter, evaluating it once per SCANNED
             -- consensus row (~78k at vocab 5000) — measured 76x slower (7.8s vs 0.1s).
             SELECT c.subject_id, c.object_id, c.rating, c.rd,
                    relation_rank_resolved(c.type_id) AS rk  -- RESOLVED: dynamic UD types (DEP_/EDEP_/FEAT_) inherit rank via IS_A; bare relation_rank() = NULL for them, and the rk IS NOT NULL filter below was dropping 533 types / ~234k edges from every export plane
             FROM v
             JOIN consensus c ON c.subject_id = v.id
             JOIN v vo        ON vo.id = c.object_id
         ),
         summed AS (
             SELECT e.subject_id, e.object_id,
                    sum(e.rk * (eff_mu(e.rating, e.rd))::float8 / 1e9) AS w
             FROM edges e
             WHERE e.rk IS NOT NULL
             GROUP BY e.subject_id, e.object_id
         ),
         capped AS (
             SELECT s.subject_id, s.object_id, s.w,
                    row_number() OVER (PARTITION BY s.subject_id ORDER BY s.w DESC, s.object_id) AS rn
             FROM summed s
             WHERE s.w > 0
         )
    SELECT c.subject_id, c.object_id, c.w FROM capped c WHERE c.rn <= p_degree_cap
$$;

-- The foundry's TOKEN LIST: a COHERENT, self-defining vocabulary of single UAX29
-- wordforms (entities.tier = 2 — never multi-word lexical entries, Unicode-name blobs, or
-- id junk). Two parts so the vocab can represent its own members:
--   seeds   = the most FREQUENT single words (forward-sequence/PRECEDES degree = the
--             tokenizer's frequency axis) — the words that actually tile text.
--   closure = the single words those seeds DEFINE / RELATE to (IS_A, IS_SYNONYM_OF,
--             RELATED_TO, HAS_PART, DERIVATIONALLY_RELATED, coordinate terms) — so if `dog`
--             is in, `animal / canine / domestic / …` are in too (no top-k that can't
--             define its own tokens). weight = frequency (the SPM score). Set-based; the
--             CLI calls THIS, never ad-hoc SQL.
CREATE OR REPLACE FUNCTION foundry_vocab(p_size int)
    RETURNS TABLE(entity_id bytea, surface text, weight bigint)
    LANGUAGE sql STABLE PARALLEL SAFE
    SET search_path = @extschema@, public AS $$
    WITH freq AS (
        SELECT c.subject_id AS id, count(*) AS d
        FROM consensus c
        WHERE c.type_id = relation_type_id('PRECEDES') AND c.object_id IS NOT NULL
        GROUP BY c.subject_id
    ),
    seeds AS (
        SELECT f.id, f.d
        FROM freq f JOIN entities e ON e.id = f.id AND e.tier = 2
        ORDER BY f.d DESC LIMIT p_size
    ),
    closure AS (
        SELECT DISTINCT c.object_id AS id
        FROM consensus c
        JOIN seeds s ON s.id = c.subject_id
        JOIN entities e ON e.id = c.object_id AND e.tier = 2
        WHERE c.object_id IS NOT NULL
          AND c.type_id IN (
              relation_type_id('IS_A'), relation_type_id('IS_SYNONYM_OF'),
              relation_type_id('RELATED_TO'), relation_type_id('HAS_PART'),
              relation_type_id('DERIVATIONALLY_RELATED'), relation_type_id('IS_COORDINATE_TERM_WITH'))
    ),
    ids AS (SELECT id FROM seeds UNION SELECT id FROM closure),
    -- THE MATH BEFORE THE DISPLAY: selection is frequency, cheap and on ids alone.
    -- Render is the EXPENSIVE display step (a trajectory decode per id) and the final
    -- output is the top p_size by d regardless, so render only the survivors: rank all
    -- ~17k ids by d, keep the top (p_size + margin), render JUST those (~p_size*3, not
    -- 17k). Same selection — low-d closure never clears the final LIMIT — at ~4x
    -- (measured 25s → 6s). The 3x margin covers surface-dedup + filter losses.
    ranked AS (
        SELECT i.id, COALESCE(f.d, 0) AS d
        FROM ids i LEFT JOIN freq f ON f.id = i.id
        ORDER BY COALESCE(f.d, 0) DESC, i.id
        LIMIT p_size * 3
    ),
    arr AS (
        SELECT array_agg(id ORDER BY d DESC, id) AS a,
               array_agg(d  ORDER BY d DESC, id) AS ds
        FROM ranked
    ),
    named AS (
        -- ONE batch render over the survivors (render_text_batch == render_text
        -- vectorized: same per-id decode, one SQL→C crossing); ordinality pairs d back.
        SELECT u.id, u.s, a.ds[u.ord::int] AS d
        FROM arr a
        CROSS JOIN LATERAL unnest(a.a, render_text_batch(a.a, 64)) WITH ORDINALITY AS u(id, s, ord)
        WHERE a.a IS NOT NULL
    ),
    clean AS (
        SELECT DISTINCT ON (n.s) n.id, n.s, n.d
        FROM named n
        WHERE n.s IS NOT NULL AND btrim(n.s) <> '' AND NOT is_all_whitespace(n.s)
          AND position(' ' IN n.s) = 0 AND char_length(n.s) <= 40
        ORDER BY n.s, n.d DESC
    )
    SELECT c.id, c.s, c.d FROM clean c ORDER BY c.d DESC, c.id LIMIT p_size
$$;

-- GRAPHEME-FLOOR vocab: the single-grapheme tokens that tile text, ranked by how often
-- they occur in word constituencies. This is the UNIVERSAL tokenizer floor — every string
-- decomposes to these, each carries perfcache super-Fibonacci geometry, and a single-
-- grapheme SP vocab tokenizes ANY input char-by-char in-engine (no merge path, no byte-
-- shredding — the failure mode of a whole-word vocab). Bounded to the richest words so it
-- stays index-time, not a full constituency walk.
CREATE OR REPLACE FUNCTION grapheme_floor_vocab(p_size int DEFAULT 512, p_words int DEFAULT 50000)
    RETURNS TABLE(entity_id bytea, surface text, weight bigint)
    LANGUAGE sql STABLE PARALLEL SAFE
    SET search_path = @extschema@, public AS $$
    -- The order/identity is already in the trajectory LineString; laplace_trajectory_constituents
    -- unpacks the whole stored geometry in ONE native C loop (run_length carries repeat counts).
    -- No constituents() tree walk, no per-grapheme render in the hot path — render only the
    -- surviving top-p_size.
    WITH t AS (
        SELECT p.trajectory
        FROM physicalities p
        JOIN entities e ON e.id = p.entity_id AND e.tier = 2
        WHERE p.type = 1 AND p.trajectory IS NOT NULL
        ORDER BY p.entity_id LIMIT p_words
    ),
    g AS (
        SELECT tc.entity_id, tc.run_length
        FROM t CROSS JOIN LATERAL laplace_trajectory_constituents(t.trajectory) tc
    ),
    agg AS (
        -- the trajectory's vertices ARE the floor atoms in order: codepoints (tier 0) and
        -- single-codepoint graphemes (tier 1). For ASCII a grapheme IS its codepoint (tier 0).
        SELECT g.entity_id, sum(GREATEST(g.run_length,1))::bigint AS cnt
        FROM g JOIN entities e ON e.id = g.entity_id AND e.tier <= 1
        GROUP BY g.entity_id
    ),
    named AS (
        SELECT a.entity_id, render_text(a.entity_id, 8) AS s, a.cnt
        FROM agg a ORDER BY a.cnt DESC LIMIT p_size * 2
    )
    SELECT n.entity_id, n.s, n.cnt
    FROM named n
    WHERE char_length(n.s) = 1 AND NOT is_all_whitespace(n.s)
    ORDER BY n.cnt DESC LIMIT p_size
$$;

-- GRAPHEME ORDER: P(next grapheme | current grapheme) from word constituencies — the
-- readout signal for the grapheme-floor model (er/on/in/th… real letter statistics).
-- Bigram counts within each word's ordered graphemes, masked to the vocab on both ends.
-- Bounded to the richest words (the common bigrams saturate quickly).
CREATE OR REPLACE FUNCTION grapheme_order(p_vocab bytea[], p_words int DEFAULT 50000, p_gap int DEFAULT 1)
    RETURNS TABLE(subject_id bytea, object_id bytea, w double precision)
    LANGUAGE sql STABLE PARALLEL SAFE
    SET search_path = @extschema@, public AS $$
    -- Order is the LineString itself: unpack each word's trajectory in one native C loop
    -- (laplace_trajectory_constituents), take vertices at distance p_gap as the (cur,next)
    -- pair. p_gap=1 is the bigram readout; p_gap=2 is the SKIP-gram (prev -> next, skipping
    -- the current grapheme) — the signal the history subspace decodes. No constituents()
    -- recursion. Both endpoints masked to the vocab.
    WITH v(id) AS (SELECT DISTINCT u FROM unnest(p_vocab) AS u),
    t AS (
        -- ONE trajectory per word (lowest source_id — the corpus convention) so the bigram
        -- stays within a single k,i,n,g sequence. Without this, a word's many witness
        -- trajectories concatenate into one partition and lead() pairs identical vertices
        -- at the same ordinal → spurious self-loops (k→k).
        SELECT DISTINCT ON (p.entity_id) p.entity_id AS wid, p.trajectory
        FROM physicalities p
        JOIN entities e ON e.id = p.entity_id AND e.tier = 2
        WHERE p.type = 1 AND p.trajectory IS NOT NULL
        ORDER BY p.entity_id, p.source_id LIMIT p_words
    ),
    g AS (
        -- EXPAND run-length: a vertex with run_length r is r consecutive identical
        -- graphemes (the ss in Mississippi, nn/ee in Tennessee), contributing r-1
        -- self-transitions (s→s) plus the move to the next vertex. Replay the run so the
        -- doubled letters are real bigrams, not lost to RLE.
        SELECT t.wid, tc.ordinal AS ord, gs.i AS sub, tc.entity_id AS ch
        FROM t CROSS JOIN LATERAL laplace_trajectory_constituents(t.trajectory) tc
        CROSS JOIN LATERAL generate_series(1, GREATEST(tc.run_length, 1)) gs(i)
    ),
    bg AS (
        SELECT ch AS cur, lead(ch, p_gap) OVER (PARTITION BY wid ORDER BY ord, sub) AS nxt FROM g
    ),
    cnt AS (
        SELECT cur, nxt, count(*)::float8 AS c
        FROM bg WHERE nxt IS NOT NULL GROUP BY cur, nxt
    )
    SELECT b.cur, b.nxt, b.c
    FROM cnt b
    JOIN v vs ON vs.id = b.cur
    JOIN v vo ON vo.id = b.nxt
$$;

-- WORD ORDER: P(next word | current word) from the CONTENT TRAJECTORY GEOMETRY — the word-tier
-- analog of grapheme_order, one tier up. The witnessed word sequence IS the sentence/phrase
-- trajectory (tier > 2): unpack its constituents in trajectory order (laplace_trajectory_constituents),
-- mask to the in-vocab tier-2 words (interspersed tier-0 punctuation/space vertices drop out), and
-- lead(gap) pairs adjacent in-vocab words. This is the ORDER signal read DIRECTLY off the geometry —
-- NOT the trajectory_pairs materialization, NOT the folded PRECEDES relation. gap=1 is the bigram
-- readout; gap=2 is the skip-gram (prev -> next) the history subspace of the shift head decodes.
-- One trajectory per entity (lowest source_id) so lead() stays within a single witnessed sequence.
CREATE OR REPLACE FUNCTION word_order(p_vocab bytea[], p_trajs int DEFAULT 100000, p_gap int DEFAULT 1)
    RETURNS TABLE(subject_id bytea, object_id bytea, w double precision)
    LANGUAGE sql STABLE PARALLEL SAFE
    SET search_path = @extschema@, public AS $$
    WITH v(id) AS (SELECT DISTINCT u FROM unnest(p_vocab) AS u),
    t AS (
        SELECT DISTINCT ON (p.entity_id) p.entity_id AS sid, p.trajectory
        FROM physicalities p
        JOIN entities e ON e.id = p.entity_id AND e.tier > 2
        WHERE p.type = 1 AND p.trajectory IS NOT NULL
        ORDER BY p.entity_id, p.source_id LIMIT p_trajs
    ),
    g AS (
        SELECT t.sid, tc.ordinal AS ord, tc.entity_id AS wid
        FROM t CROSS JOIN LATERAL laplace_trajectory_constituents(t.trajectory) tc
        JOIN v ON v.id = tc.entity_id
    ),
    bg AS (
        SELECT wid AS cur, lead(wid, p_gap) OVER (PARTITION BY sid ORDER BY ord) AS nxt FROM g
    ),
    cnt AS (
        SELECT cur, nxt, count(*)::float8 AS c
        FROM bg WHERE nxt IS NOT NULL AND cur <> nxt GROUP BY cur, nxt
    )
    SELECT cur, nxt, c FROM cnt
$$;

-- CORPUS-FREQUENCY word vocab: the tier-2 wordforms that ACTUALLY OCCUR in the content
-- trajectories, ranked by occurrence count — the FLOW vocabulary (function/stop words the/of/and/to
-- INCLUDED, which the richness-ranked foundry_vocab drops). A whole-word n-gram model needs these or
-- word_order bigrams get masked away (both endpoints must be in vocab) and the continuation set
-- collapses to a handful of words. Counted over the same sentence trajectories word_order reads.
CREATE OR REPLACE FUNCTION corpus_word_vocab(p_size int, p_trajs int DEFAULT 400000)
    RETURNS TABLE(surface text, weight bigint)
    LANGUAGE sql STABLE PARALLEL SAFE
    SET search_path = @extschema@, public AS $$
    WITH t AS (
        SELECT DISTINCT ON (p.entity_id) p.entity_id, p.trajectory
        FROM physicalities p JOIN entities e ON e.id = p.entity_id AND e.tier > 2
        WHERE p.type = 1 AND p.trajectory IS NOT NULL
        ORDER BY p.entity_id, p.source_id LIMIT p_trajs
    ),
    w AS (
        SELECT tc.entity_id AS id, count(*) AS c
        FROM t CROSS JOIN LATERAL laplace_trajectory_constituents(t.trajectory) tc
        JOIN entities e ON e.id = tc.entity_id AND e.tier = 2
        GROUP BY tc.entity_id
    ),
    -- rank by frequency, render a candidate band, then keep only Latin-script word surfaces
    -- (drops the multilingual corpus's Arabic/CJK tokens and the U+FFFD replacement char for a
    -- clean first English model — language split is a later refinement). render only the band.
    cand AS (SELECT id, c, render_text(id, 80) AS s FROM w ORDER BY c DESC LIMIT p_size * 4)
    SELECT s, c FROM cand
    WHERE s ~ '^[A-Za-z][A-Za-z''.-]*$'
    ORDER BY c DESC LIMIT p_size
$$;

-- METRIC EDGES: a transformer head is a bilinear score between two token entities, and
-- the substrate already computes NAMED metrics between entity trajectories/coords —
-- laplace_frechet_4d / laplace_hausdorff_4d / laplace_angular_distance_4d (native C in
-- laplace_geom). A head does not LEARN an attention pattern; it TRANSCRIBES one of these
-- metrics. This returns, per vocab token, its k nearest neighbours UNDER THE CHOSEN METRIC
-- over the realized trajectory ('frechet'/'hausdorff') or the centroid coord ('angular') —
-- the sparse pairwise matrix a single (layer,head) factors into q·k. The metric is
-- intrinsically LOCAL: prune the candidate set by the cheap angular distance on the
-- centroid coord (Fréchet is documented as a "structural refine after coord KNN"), then
-- refine the survivors with the exact metric. 'w' is a DISTANCE (small = near); the cast
-- writer converts it to a similarity kernel (−w) for the attention softmax. Token entities
-- with no realized trajectory (single graphemes) fall back to the angular coord distance.
CREATE OR REPLACE FUNCTION metric_edges(
        p_vocab bytea[], p_metric text DEFAULT 'frechet', p_k int DEFAULT 16, p_probe int DEFAULT 64)
    RETURNS TABLE(subject_id bytea, object_id bytea, w double precision)
    LANGUAGE sql STABLE PARALLEL SAFE
    SET search_path = @extschema@, public AS $$
    WITH v AS (
        -- ONE physicality per token (lowest source_id), masked to the vocab.
        SELECT DISTINCT ON (p.entity_id) p.entity_id AS id, p.coord, p.trajectory
        FROM physicalities p
        JOIN unnest(p_vocab) AS u(id) ON u.id = p.entity_id
        WHERE p.type = 1
        ORDER BY p.entity_id, p.source_id
    ),
    cand AS (
        -- cheap angular distance on the centroid coord for every ordered vocab pair
        SELECT a.id AS aid, b.id AS bid, a.trajectory AS at, b.trajectory AS bt,
               laplace_angular_distance_4d(a.coord, b.coord) AS ang
        FROM v a JOIN v b ON a.id <> b.id
    ),
    pruned AS (
        SELECT aid, bid, at, bt, ang,
               row_number() OVER (PARTITION BY aid ORDER BY ang) AS rn
        FROM cand
    ),
    refined AS (
        -- exact metric only on the angular-KNN candidate survivors
        SELECT aid, bid,
            CASE p_metric
                WHEN 'angular'   THEN ang
                WHEN 'frechet'   THEN coalesce(laplace_frechet_4d(at, bt), ang)
                WHEN 'hausdorff' THEN coalesce(laplace_hausdorff_4d(at, bt), ang)
                ELSE ang
            END AS d
        FROM pruned
        WHERE rn <= GREATEST(p_probe, p_k)
    ),
    topk AS (
        SELECT aid, bid, d,
               row_number() OVER (PARTITION BY aid ORDER BY d) AS rn
        FROM refined
    )
    SELECT aid, bid, d FROM topk WHERE rn <= p_k
$$;

-- native crawl kernel (the heavy lifter): BFS over consensus from the seed ids
-- along the strongest-affirmed edges, O(1) HTAB dedup, index-driven per-node
-- fanout. Returns tier-2 word ids ranked by path relevance (product of edge
-- strengths). Implemented in foundry_crawl.c — SQL never walks the graph itself.
CREATE OR REPLACE FUNCTION foundry_crawl(
        p_seeds bytea[], p_budget int DEFAULT 32000, p_hops int DEFAULT 3, p_fanout int DEFAULT 64,
        p_rel_types bytea[] DEFAULT NULL)
    RETURNS TABLE(entity_id bytea, weight bigint)
    AS 'MODULE_PATHNAME', 'pg_laplace_foundry_crawl'
    LANGUAGE C VOLATILE;

-- SEEDED CRAWL vocab (thin orchestrator over foundry_crawl): pick a few words;
-- the substrate crawls the consensus OUTWARD from them and returns the connected
-- word neighborhood — that IS the token list (focused on the seeds, self-defining,
-- NOT a global top-N). SQL only resolves seed text→id, renders the returned ids
-- (render_text_batch — also native), dedups by surface, and trims to budget; the
-- graph walk and the rendering are both C. Bounded by p_hops + per-node fanout so
-- it runs in the seeds' time, not the whole graph's. Single UAX29 wordforms (tier 2).
CREATE OR REPLACE FUNCTION foundry_vocab_crawl(
        p_seeds text[], p_max int DEFAULT 32000, p_hops int DEFAULT 3, p_fanout int DEFAULT 64)
    RETURNS TABLE(entity_id bytea, surface text, weight bigint)
    LANGUAGE sql VOLATILE
    SET search_path = @extschema@, public AS $$
    WITH seed_ids AS (
        SELECT coalesce(array_agg(wid), '{}'::bytea[]) AS ids
        FROM (SELECT word_id(s) AS wid FROM unnest(p_seeds) AS s) q
        WHERE wid IS NOT NULL
    ),
    -- the SEMANTIC / definitional edge set: what a word IS, MEANS, RELATES TO and
    -- is BUILT FROM — never PRECEDES/co-occurrence (that is the stop-word axis) and
    -- never the Unicode/language metadata relations. This is the "walk the trees,
    -- include the tokens it references and relates to" set.
    -- the clean WordNet/lexical edge set: hypernymy, synonymy, meronymy,
    -- derivation, sense bridges. ConceptNet RELATED_TO / HAS_DOMAIN_TOPIC are
    -- deliberately OUT — at depth they drag in high-frequency function words
    -- (the stop-word axis); the lexical relations stay on the seeds' meaning.
    rel_types AS (
        SELECT array_agg(relation_type_id(n)) AS ids
        FROM unnest(ARRAY[
            'IS_A','IS_SYNONYM_OF','IS_COORDINATE_TERM_WITH','IS_ANTONYM_OF',
            'HAS_PART','PART_OF','MEMBER_OF','HAS_MEMBER','DERIVATIONALLY_RELATED',
            'FORM_OF','HAS_HYPONYM','IS_HYPERNYM_OF','SIMILAR_TO','PERTAINS_TO',
            'HAS_SENSE','IS_SENSE_OF'
        ]) AS n
    ),
    crawled AS (
        SELECT c.entity_id, c.weight,
               row_number() OVER (ORDER BY c.weight DESC, c.entity_id) AS rn
        FROM seed_ids si, rel_types rt
        CROSS JOIN LATERAL foundry_crawl(si.ids, p_max, p_hops, p_fanout, rt.ids) c
    ),
    -- ORDER CLOSURE (seed-local): PRECEDES successors of the seeds, 1-hop + 2-hop.
    -- Geographic/factual chains (capital→of→France) live on witnessed order, NOT the lexical
    -- crawl edge set — the global scaffold below ranks by corpus-wide out-degree and never asks
    -- "what follows capital". Path weight = product of edge eff_mu so multi-hop facts rank by
    -- chain strength; fanout capped per hop so bridge words (of) do not flood the budget.
    order1 AS (
        SELECT c.object_id AS entity_id,
               eff_mu(c.rating, c.rd)::numeric AS w,
               row_number() OVER (PARTITION BY seed.wid ORDER BY eff_mu(c.rating, c.rd) DESC, c.object_id) AS rn
        FROM seed_ids si
        CROSS JOIN unnest(si.ids) AS seed(wid)
        JOIN consensus c ON c.subject_id = seed.wid
            AND c.type_id = relation_type_id('PRECEDES')
            AND c.object_id IS NOT NULL
            AND NOT refuted(c.rating, c.rd)
        JOIN entities e ON e.id = c.object_id AND e.tier = 2
    ),
    order1_cut AS (
        SELECT entity_id, w::bigint AS weight FROM order1 WHERE rn <= p_fanout
    ),
    order2 AS (
        SELECT c.object_id AS entity_id,
               (o.w * eff_mu(c.rating, c.rd)::numeric / 1000000000)::bigint AS weight,
               row_number() OVER (PARTITION BY o.entity_id ORDER BY eff_mu(c.rating, c.rd) DESC, c.object_id) AS rn
        FROM order1_cut o
        JOIN consensus c ON c.subject_id = o.entity_id
            AND c.type_id = relation_type_id('PRECEDES')
            AND c.object_id IS NOT NULL
            AND NOT refuted(c.rating, c.rd)
        JOIN entities e ON e.id = c.object_id AND e.tier = 2
    ),
    order2_cut AS (
        SELECT entity_id, weight FROM order2 WHERE rn <= p_fanout
    ),
    order_lemma AS (
        SELECT c.object_id AS entity_id, o.weight
        FROM (SELECT entity_id, max(weight) AS weight FROM (
                  SELECT entity_id, weight FROM order1_cut
                  UNION ALL SELECT entity_id, weight FROM order2_cut
              ) u GROUP BY entity_id) o
        JOIN consensus c ON c.subject_id = o.entity_id
            AND c.type_id = relation_type_id('IS_LEMMA_OF')
            AND c.object_id IS NOT NULL
            AND NOT refuted(c.rating, c.rd)
        JOIN entities e ON e.id = c.object_id AND e.tier = 2
    ),
    order_closure AS (
        SELECT entity_id, max(weight) AS weight,
               row_number() OVER (ORDER BY max(weight) DESC, entity_id) AS rn
        FROM (
            SELECT entity_id, weight FROM order1_cut
            UNION ALL SELECT entity_id, weight FROM order2_cut
            UNION ALL SELECT entity_id, weight FROM order_lemma
        ) u
        GROUP BY entity_id
    ),
    -- SEQUENCE GLUE (scaffold): the highest-PRECEDES single wordforms. A lexical-only
    -- crawl has no SEQUENCE coverage — the words that actually follow content words in
    -- text (dog → and/the/he/growls/look) are function/common words the crawl excludes,
    -- so without these the model has nothing to complete TO and cannot form sentences.
    -- Reserved to a quarter of the budget and ranked BELOW the crawl, so the vocab stays
    -- topic-first but can still sequence. (PRECEDES is the generation axis; it earns its
    -- place here even though it is the stop-word axis for SELECTION.)
    scaffold AS (
        SELECT f.id AS entity_id, f.d::bigint AS weight,
               row_number() OVER (ORDER BY f.d DESC) AS rn
        FROM (
            SELECT c.subject_id AS id, count(*) AS d
            FROM consensus c
            JOIN entities e ON e.id = c.subject_id AND e.tier = 2
            WHERE c.type_id = relation_type_id('PRECEDES') AND c.object_id IS NOT NULL
            GROUP BY c.subject_id
        ) f
    ),
    picked AS (
        SELECT entity_id, weight, 2 AS pri FROM order_closure WHERE rn <= p_max / 4
        UNION ALL
        SELECT entity_id, weight, 1 AS pri FROM crawled  WHERE rn <= p_max - p_max / 2
        UNION ALL
        SELECT entity_id, weight, 0 AS pri FROM scaffold WHERE rn <= p_max / 4
    ),
    uniq AS (
        SELECT DISTINCT ON (entity_id) entity_id, weight, pri
        FROM picked ORDER BY entity_id, pri DESC, weight DESC
    ),
    ids_arr AS (
        SELECT array_agg(entity_id ORDER BY pri DESC, weight DESC) AS ids,
               array_agg(weight     ORDER BY pri DESC, weight DESC) AS ws,
               array_agg(pri        ORDER BY pri DESC, weight DESC) AS prs
        FROM uniq
    ),
    rendered AS (
        SELECT u.entity_id, u.s, a.ws[u.ord::int] AS weight, a.prs[u.ord::int] AS pri
        FROM ids_arr a
        CROSS JOIN LATERAL unnest(a.ids, render_text_batch(a.ids, 8))
                   WITH ORDINALITY AS u(entity_id, s, ord)
        WHERE a.ids IS NOT NULL AND cardinality(a.ids) > 0
    ),
    clean AS (
        SELECT DISTINCT ON (n.s) n.entity_id, n.s, n.weight, n.pri
        FROM rendered n
        WHERE n.s IS NOT NULL AND btrim(n.s) <> '' AND NOT is_all_whitespace(n.s)
          AND position(' ' IN n.s) = 0 AND char_length(n.s) <= 40
          AND n.s ~ '[[:alpha:]]'          -- must carry a letter (no pure punctuation)
          AND n.s !~ '^i[0-9]+$'           -- drop bare ILI concept ids (i46531) — not words
        ORDER BY n.s, n.pri DESC, n.weight DESC
    )
    SELECT c.entity_id, c.s, c.weight FROM clean c ORDER BY c.pri DESC, c.weight DESC LIMIT p_max
$$;

-- native kernel ----------------------------------------------------------------
-- stride_used: the witnessed order that produced the step; 0 = the step came from
-- the COMPLETES_TO consensus floor (no witnessed continuation at any order).
CREATE OR REPLACE FUNCTION walk_continuations(
        p_ctx bytea[], p_steps int DEFAULT 24, p_max_stride int DEFAULT 5,
        p_spread float8 DEFAULT 0.7, p_breadth int DEFAULT 10,
        p_seed bigint DEFAULT NULL)
    RETURNS TABLE(step int, entity bytea, stride_used int, sep_entity bytea)
    AS 'MODULE_PATHNAME', 'pg_laplace_walk_continuations'
    LANGUAGE C VOLATILE;

CREATE OR REPLACE FUNCTION stream_reset() RETURNS boolean
    AS 'MODULE_PATHNAME', 'pg_laplace_stream_reset'
    LANGUAGE C VOLATILE;

-- endpoint surface: prompt text in, rendered tokens out (the signature
-- SubstrateClient.GenerateNgramStreamAsync calls)
CREATE OR REPLACE FUNCTION walk_text(
        p_prompt text, p_steps int DEFAULT 24, p_max_stride int DEFAULT 5,
        p_spread float8 DEFAULT 0.7, p_breadth int DEFAULT 10,
        p_seed bigint DEFAULT NULL)
    RETURNS TABLE(step int, entity text, stride_used int)
    LANGUAGE sql VOLATILE
    SET search_path = @extschema@, public AS $$
    WITH ctx AS (
        SELECT array_agg(id ORDER BY ord) AS ids
        FROM prompt_state(p_prompt) WHERE id IS NOT NULL
    )
    -- the kernel is deterministic given a seed. An unseeded call MUST stay deterministic
    -- (substrate invariant: repeatable), so the seed is derived from the prompt content
    -- via BLAKE3 — identical prompts yield identical output. Callers wanting variation
    -- pass an explicit p_seed (e.g. a turn counter); random() is never used here.
    -- entity carries the word PLUS its witnessed trailing separator (omniglottal spacing:
    -- Latin space / 。、 / U+3000 / nothing for CJK) — reconstruct text with NO delimiter.
    SELECT g.step,
           render_text(g.entity, 64) || COALESCE(render_text(g.sep_entity, 8), ''),
           g.stride_used
    FROM ctx, walk_continuations(ctx.ids, p_steps, p_max_stride, p_spread, p_breadth,
                              COALESCE(p_seed,
                                  ('x' || encode(substring(
                                       public.laplace_hash128_blake3(convert_to(p_prompt, 'UTF8'))
                                       for 8), 'hex'))::bit(64)::bigint)) g
    WHERE ctx.ids IS NOT NULL
$$;

-- THE generation surface: prompt in, clean witnessed-spacing text out (omniglottal,
-- no detok rules — spacing is the witnessed separators). One call.
CREATE OR REPLACE FUNCTION generate(
        p_prompt text, p_steps int DEFAULT 40, p_max_stride int DEFAULT 5,
        p_spread float8 DEFAULT 0.7, p_breadth int DEFAULT 12,
        p_seed bigint DEFAULT NULL)
    RETURNS text
    LANGUAGE sql VOLATILE
    SET search_path = @extschema@, public AS $$
    SELECT btrim(string_agg(entity, '' ORDER BY step))
    FROM walk_text(p_prompt, p_steps, p_max_stride, p_spread, p_breadth, p_seed)
$$;

-- legacy shim: ranked-μ SQL walk removed; delegate to native stride kernel
CREATE OR REPLACE FUNCTION continue_text(
        p_prompt text, p_steps int DEFAULT 16, p_window int DEFAULT 3,
        p_spread double precision DEFAULT 0.6, p_breadth int DEFAULT 8,
        p_stop text[] DEFAULT '{}', p_boost double precision DEFAULT 0,
        p_require_pos boolean DEFAULT true)
    RETURNS TABLE(step int, entity text, mu numeric)
    LANGUAGE sql VOLATILE
    SET search_path = @extschema@, public AS $$
    SELECT g.step, g.entity, NULL::numeric AS mu
    FROM walk_text(p_prompt, p_steps, GREATEST(p_window, 1), p_spread, p_breadth) g
$$;

-- variant synthesis over witnessed constituency ----------------------------------
-- A content trajectory is a witnessed WHOLE. respell_variant walks a witnessed
-- instance in trajectory order and substitutes COMPOSITE constituents with
-- elected peers. Tokens (tier <= 2) are the floor — never opened, never
-- respelled. Novelty arises only at substitution points, and every substitution
-- is justified by adjudicated testimony; every emitted fragment stays a
-- witnessed whole.
-- Peer election is CONSENSUS-FIRST (Glicko-2 replaces nearest neighbor): a peer
-- is an entity of the same node type co-witnessed in the same typed relation
-- contexts, scored by the weaker of the two adjudicated eff_mu ratings — so
-- uncertain testimony (high RD) cannot elect a peer. Geometry (coord KNN +
-- Fréchet over trajectories) is only the fallback for thinly-witnessed entities.
CREATE OR REPLACE FUNCTION consensus_peer(p_id bytea, p_k int DEFAULT 6)
    RETURNS bytea
    AS 'MODULE_PATHNAME', 'pg_laplace_consensus_peer'
    LANGUAGE C STABLE;

CREATE OR REPLACE FUNCTION variant_walk(p_id bytea, p_swap float8 DEFAULT 0.3,
                          p_k int DEFAULT 6, p_depth int DEFAULT 4)
    RETURNS text
    AS 'MODULE_PATHNAME', 'pg_laplace_variant_walk'
    LANGUAGE C VOLATILE;

CREATE OR REPLACE FUNCTION respell_variant(p_node_type text, p_modality text DEFAULT 'c-sharp',
                     p_substitution_rate float8 DEFAULT 0.3, p_k int DEFAULT 6, p_depth int DEFAULT 4)
    RETURNS text
    AS 'MODULE_PATHNAME', 'pg_laplace_respell_variant'
    LANGUAGE C VOLATILE;

-- CONTENT-ADDRESSED book/fact recall: which content trajectories (sentences) contain entity X,
-- via the GIN inverted index (physicalities_constituents_gin over laplace_trajectory_constituent_ids).
-- A trajectory's bbox spans the whole 4D sphere so NO spatial index discriminates — the entity id
-- IS the exact cell; @> ARRAY[word_id(x)] is a direct index seek (~105ms over 48M trajectories).
-- Surface sentence-length trajectories, render ONLY the final N. From a hit, read precedes/follows
-- off the trajectory: the same content trajectory that feeds the generative order/chat readout.
CREATE OR REPLACE FUNCTION recall_trajectories(p_word text, p_limit int DEFAULT 6)
    RETURNS TABLE(answer text)
    LANGUAGE sql STABLE
    SET search_path = @extschema@, public AS $$
  WITH ids AS (
    SELECT ph.entity_id
    FROM physicalities ph
    WHERE ph.type = 1 AND ph.trajectory IS NOT NULL
      AND public.laplace_trajectory_constituent_ids(ph.trajectory) @> ARRAY[word_id(p_word)]
    ORDER BY abs(ph.n_constituents - 7)        -- sentence-length, not the bare token / a paragraph
    LIMIT p_limit
  )
  SELECT left(replace(render_text(entity_id, 300), chr(10), ' '), 180) FROM ids
$$;
