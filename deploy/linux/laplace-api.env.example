# Laplace API runtime environment (Linux / systemd).
# Copy to /opt/laplace/app/laplace-api.env (bootstrap-host.sh does this).
# Every value here is plain config — override per environment via GitHub
# Actions variables/secrets, never by editing code.

# --- substrate backend (Npgsql conn string) ---
# hart-server: peer auth as laplace_admin over the unix socket, db = laplace.
LAPLACE_DB=Host=/var/run/postgresql;Username=laplace_admin;Database=laplace

# --- native engine libs (laplace_core/dynamics/synthesis .so) ---
LD_LIBRARY_PATH=/opt/laplace/lib

# --- Kestrel bind (localhost only; nginx reverse-proxies to it) ---
ASPNETCORE_URLS=http://127.0.0.1:5187
ASPNETCORE_ENVIRONMENT=Production

# --- auth / billing (dev posture until billing is turned on) ---
LAPLACE_AUTH_MODE=header
LAPLACE_BILLING_STORE=memory
LAPLACE_BILLING_BYPASS=true

# --- logging ---
LAPLACE_LOG_JSON=true
LAPLACE_LOG_DIR=/opt/laplace/app/logs

# --- optional: structured tracing endpoint (leave unset to disable) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
