   COMMENT ON INDEX physicalities_coord_gist IS     'ND-GIST on content coords: KNN via <<->> yields angular ranking on S┬│.';  CREATE OR REPLACE FUNCTION trajectory_point_count(p_traj geometry)     RETURNS integer     LANGUAGE sql IMMUTABLE STRICT     SET search_path = public AS $$     SELECT CASE WHEN p_traj IS NULL THEN 0                 ELSE public.ST_NPoints(p_traj)::integer END $$;  CREATE OR REPLACE FUNCTION trajectory_prefix_distance(     p_a geometry, p_b geometry)     RETURNS double precision     LANGUAGE sql STABLE STRICT     SET search_path = @extschema@, public AS $$     SELECT public.laplace_frechet_4d(p_a, p_b) $$;  COMMENT ON FUNCTION trajectory_prefix_distance(geometry, geometry) IS     'Exact discrete Fr├⌐chet between two realized trajectories (structural refine after coord KNN).';