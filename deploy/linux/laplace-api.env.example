LAPLACE_DB=Host=/var/run/postgresql;Username=laplace_admin;Database=laplace

LD_LIBRARY_PATH=/opt/laplace/lib

LAPLACE_PERFCACHE_BIN=/opt/laplace/share/laplace/laplace_t0_perfcache_17.0.0.bin

ASPNETCORE_URLS=http://127.0.0.1:5187
ASPNETCORE_ENVIRONMENT=Production

LAPLACE_AUTH_MODE=header
LAPLACE_BILLING_STORE=memory
LAPLACE_BILLING_BYPASS=true

LAPLACE_LOG_JSON=true
LAPLACE_LOG_DIR=/opt/laplace/app/logs

# Chess Lab binary paths — written by setup-host / pipeline publish (managed block).
# Lichess: /opt/laplace/secrets/lichess.env (seeded by setup-host from
#   ~/.config/shell/secrets.env; systemd EnvironmentFile loads it).
# LAPLACE_CUTECHESS=/opt/laplace/bin/cutechess-cli
# LAPLACE_STOCKFISH=/usr/games/stockfish
# LAPLACE_QT_BIN=/usr/lib/qt6/bin
