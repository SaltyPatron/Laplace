/* 14_geometry_consensus.sql.in — the GEOMETRY axis of the consensus layer
 * (S³ structural placements; mirrors 13_consensus.sql.in / ADR 0036 + ADR 0039).
 *
 * Two layers, exactly as the relation side (attestations → consensus):
 *
 *   geometry_placement_evidence  — EVIDENCE. One row per
 *       (entity, projection_kind, source, layer, head, expert): a single
 *       per-model placement of the entity on S³ (a unit PointZM), with FULL
 *       provenance (which model, which layer/head/expert produced it) and the
 *       per-placement weight + observation count. Retained for interpretability
 *       / audit / embed-species (GROUP BY layer/head characterizes a circuit).
 *
 *   geometry_consensus           — ATTESTATION. ONE row per
 *       (entity, projection_kind). source / layer / head / expert are
 *       PROVENANCE, NEVER identity — they are dropped from the id and the
 *       UNIQUE key, exactly as 13_consensus.sql.in drops source + context.
 *       The consensus coord is the WEIGHTED KARCHER (Fréchet) MEAN on S³ over
 *       all placement evidence — geodesic, NOT the Euclidean centroid — i.e.
 *       the frame-invariant structural position the witnesses agree on.
 *
 * Coords are STRUCTURAL, not semantic (S³ placement geometry); semantics live
 * on the relation consensus (13_consensus). The Karcher materializer itself
 * (engine math4d_karcher_mean over this evidence) lands with the geometry-
 * consensus build job; this file is the storage + identity discipline. */

/* ── EVIDENCE: per-witness S³ placements ──────────────────────────────────── */

CREATE TABLE geometry_placement_evidence (
    id                bytea            PRIMARY KEY CHECK (octet_length(id) = 16),
    entity_id         bytea            NOT NULL REFERENCES entities(id) ON DELETE CASCADE,
    projection_kind   smallint         NOT NULL,
    -- Provenance (GROUP-BY columns) — which witness produced this placement.
    -- NEVER part of identity: a placement is identified by its content, and the
    -- consensus collapses every (source, layer, head, expert) for one
    -- (entity, projection_kind) into a single geodesic mean.
    source_id         bytea            NOT NULL REFERENCES entities(id) ON DELETE CASCADE,
    layer             integer,
    head              integer,
    expert            integer,
    -- The placement itself: a unit 4-vector on S³ stored as a PointZM.
    coord             geometry(PointZM) NOT NULL,
    -- Witness weight (kind_rank × source_trust × tenant_trust), int64 ×1e9 —
    -- the weight this placement carries into the Karcher mean. Mirrors the
    -- attestations evidence weighting discipline.
    weight            bigint           NOT NULL DEFAULT 1000000000 CHECK (weight >= 0),
    observation_count bigint           NOT NULL DEFAULT 1 CHECK (observation_count >= 0),
    observed_at       timestamptz      NOT NULL DEFAULT now(),
    UNIQUE NULLS NOT DISTINCT (entity_id, projection_kind, source_id, layer, head, expert)
);

COMMENT ON TABLE geometry_placement_evidence IS
    'EVIDENCE layer for the GEOMETRY axis: per-witness S³ placements, one row per (entity, projection_kind, source, layer, head, expert). source/layer/head/expert are PROVENANCE / GROUP-BY columns, NEVER identity. coord is a unit PointZM on S³. weight carries the witness''s pull into the Karcher consensus. Full provenance retained for interpretability/audit/embed-species (mirrors attestations).';
COMMENT ON COLUMN geometry_placement_evidence.id IS
    'Content-addressed BLAKE3-128 of canonical (entity_id, projection_kind, source_id, layer, head, expert, coord) bytes. Stable across re-observation; idempotent upsert (RULES R5).';
COMMENT ON COLUMN geometry_placement_evidence.projection_kind IS
    'Which placement view: mirrors physicalities.kind (1=CONTENT, 3=PROJECTION input-direction, 4=PROJECTION_OUTPUT lm_head, ...). Part of identity — distinct projection views consense separately.';
COMMENT ON COLUMN geometry_placement_evidence.layer IS
    'Provenance: model layer that produced this placement (NULL for non-model / single-view sources). GROUP-BY column for interpretability — NEVER identity.';
COMMENT ON COLUMN geometry_placement_evidence.head IS
    'Provenance: attention head (NULL when not applicable). GROUP-BY column — NEVER identity.';
COMMENT ON COLUMN geometry_placement_evidence.expert IS
    'Provenance: MoE expert index (NULL when not applicable). GROUP-BY column — NEVER identity.';
COMMENT ON COLUMN geometry_placement_evidence.coord IS
    'The witness''s S³ placement of the entity: a unit 4-vector as a PointZM (per RULES R1). Structural, not semantic.';
COMMENT ON COLUMN geometry_placement_evidence.weight IS
    'Witness weight (kind_rank × source_trust × tenant_trust), int64 fixed-point ×1e9 — the pull this placement exerts in the weighted Karcher mean.';

SELECT pg_extension_config_dump('geometry_placement_evidence', '');

CREATE INDEX geometry_placement_evidence_entity_btree
    ON geometry_placement_evidence (entity_id);
CREATE INDEX geometry_placement_evidence_entity_kind_btree
    ON geometry_placement_evidence (entity_id, projection_kind);
CREATE INDEX geometry_placement_evidence_source_btree
    ON geometry_placement_evidence (source_id);

/* ── ATTESTATION: the geometry consensus (Karcher mean on S³) ──────────────── */

CREATE TABLE geometry_consensus (
    id                bytea            PRIMARY KEY CHECK (octet_length(id) = 16),
    entity_id         bytea            NOT NULL REFERENCES entities(id) ON DELETE CASCADE,
    projection_kind   smallint         NOT NULL,
    -- The consensus placement: the WEIGHTED KARCHER (Fréchet) MEAN on S³ over
    -- all geometry_placement_evidence for this (entity, projection_kind) —
    -- geodesic, NOT the Euclidean centroid. Always a unit PointZM.
    coord             geometry(PointZM) NOT NULL,
    radius_origin     double precision GENERATED ALWAYS AS (
        sqrt(ST_X(coord)^2 + ST_Y(coord)^2 + ST_Z(coord)^2 + ST_M(coord)^2)
    ) STORED,
    -- Spread of the witnesses around the mean (max geodesic residual, int64
    -- ×1e9) — the geometry analogue of rd/volatility: tight = witnesses agree,
    -- wide = contested placement. NULL until materialized.
    dispersion        bigint           CHECK (dispersion IS NULL OR dispersion >= 0),
    witness_count     bigint           NOT NULL DEFAULT 1 CHECK (witness_count >= 0),
    last_observed_at  timestamptz      NOT NULL,
    UNIQUE (entity_id, projection_kind)
);

COMMENT ON TABLE geometry_consensus IS
    'ATTESTATION layer for the GEOMETRY axis: ONE row per (entity, projection_kind). source/layer/head/expert DROPPED from identity (all witnesses, never identity) — exactly as 13_consensus drops source+context. coord is the WEIGHTED KARCHER (Fréchet) MEAN on S³ over geometry_placement_evidence (geodesic, NOT the Euclidean centroid). This is the frame-invariant structural placement inference reads; per-witness provenance lives in the evidence table.';
COMMENT ON COLUMN geometry_consensus.id IS
    'Content-addressed BLAKE3-128 of (entity_id ‖ projection_kind). Source/layer/head/expert OUT — all are witnesses, never identity. ONE row per (entity, projection_kind) regardless of how many models placed it.';
COMMENT ON COLUMN geometry_consensus.coord IS
    'Consensus S³ placement: the weighted Karcher (geodesic/Fréchet) mean of all witness placements. Structural, not semantic. Unit PointZM.';
COMMENT ON COLUMN geometry_consensus.dispersion IS
    'Geometry analogue of rd/volatility: the witnesses'' geodesic spread around the Karcher mean (int64 ×1e9). Tight = agreement, wide = contested placement. NULL until materialized.';
COMMENT ON COLUMN geometry_consensus.witness_count IS
    'How many placement evidence rows (Σ observation_count across all source/layer/head/expert) the Karcher mean was taken over.';

SELECT pg_extension_config_dump('geometry_consensus', '');

CREATE INDEX geometry_consensus_entity_btree   ON geometry_consensus (entity_id);
CREATE INDEX geometry_consensus_kind_btree     ON geometry_consensus (projection_kind);
CREATE INDEX geometry_consensus_coord_gist     ON geometry_consensus USING gist (coord);

/* geometry_consensus id = BLAKE3-128 of (entity_id ‖ projection_kind).
 * SOURCE / LAYER / HEAD / EXPERT OUT — all are witnesses, never identity.
 * ONE consensus placement per (entity, projection_kind). */
CREATE OR REPLACE FUNCTION geometry_consensus_id(
    p_entity bytea, p_projection_kind smallint)
    RETURNS bytea LANGUAGE sql LAPLACE_IMMUTABLE
    SET search_path = @extschema@, public AS $$
    SELECT public.laplace_hash128_blake3(
        p_entity || int2send(p_projection_kind))
$$;
COMMENT ON FUNCTION geometry_consensus_id(bytea, smallint) IS
    'Geometry-consensus identity: BLAKE3-128 of (entity_id ‖ projection_kind). Provenance (source/layer/head/expert) is NOT in the id — all are witnesses.';
