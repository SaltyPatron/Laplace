# Laplace API runtime environment (Windows / IIS in-process).
# Copy to deploy/windows/laplace-api.env (gitignored) and edit. publish.ps1
# injects these into the generated web.config <aspNetCore><environmentVariables>
# on every deploy, so config lives here, never in code.

# --- substrate backend (Npgsql conn string) ---
# Local Windows PG 18 already has the migrated 'laplace' DB (laplace schema +
# laplace_substrate + recall_session). If your PG uses password auth, append
# ;Password=YOURPASSWORD  (trust auth on 127.0.0.1 needs no password).
# Search Path=laplace,public is appended automatically if omitted (required for chess init).
LAPLACE_DB=Host=localhost;Port=5432;Username=postgres;Database=laplace
# Optional separate chess substrate; defaults to LAPLACE_DB when unset.
# LAPLACE_CHESS_DB=Host=localhost;Port=5432;Username=postgres;Database=laplace

# --- auth / billing (dev posture) ---
LAPLACE_AUTH_MODE=header
LAPLACE_BILLING_STORE=memory
LAPLACE_BILLING_BYPASS=true

# --- misc ---
ASPNETCORE_ENVIRONMENT=Production
LAPLACE_LOG_JSON=false
# IIS in-process controls the HTTP binding (site port), so no ASPNETCORE_URLS.
