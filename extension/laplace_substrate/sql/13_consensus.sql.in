/* 13_consensus.sql.in — materialized cross-witness consensus (S2; ADR 0036 + ADR 0044).
 *
 * `attestations` is the per-witness EVIDENCE layer: one row per
 * (subject, kind, object, source, context). The CONSENSUS is ONE row per
 * (subject, kind, object, context) — SOURCE OUT of identity — carrying the
 * Glicko-2 state accumulated over ALL witnessing sources via the existing
 * laplace_glicko2_accumulate aggregate. Inference reads this directly (a single
 * indexed lookup), not by re-aggregating evidence per query ("excessive joins").
 *
 * K1 (first cut — tunable once we see behaviour): each witness is one Glicko-2
 * observation — a "match" the edge plays against a fixed noise-floor opponent,
 * scored by the witness's normalized strength. More / stronger witnesses ⇒
 * higher consensus μ and tighter rd; a lone weak witness ⇒ small bump, wide rd.
 * The score reuses the evidence rating (which already = kind-tier μ × strength ×
 * source-trust per AttestationFactory); tenant-trust folds in at S5. */

CREATE TABLE consensus (
    id                bytea       PRIMARY KEY CHECK (octet_length(id) = 16),
    subject_id        bytea       NOT NULL REFERENCES entities(id),
    kind_id           bytea       NOT NULL REFERENCES entities(id),
    object_id         bytea                REFERENCES entities(id),
    context_id        bytea                REFERENCES entities(id),
    rating            bigint      NOT NULL,
    rd                bigint      NOT NULL CHECK (rd > 0),
    volatility        bigint      NOT NULL CHECK (volatility > 0),
    witness_count     bigint      NOT NULL DEFAULT 1 CHECK (witness_count >= 0),
    last_observed_at  timestamptz NOT NULL,
    UNIQUE NULLS NOT DISTINCT (subject_id, kind_id, object_id)
);

COMMENT ON TABLE consensus IS
    'Materialized cross-witness Glicko-2 consensus: ONE row per (subject, kind, object) — source AND context (model layer/head) dropped from identity (both are witnesses, never identity). Accumulated over EVERY witnessing source+layer+head from the attestations EVIDENCE layer via laplace_glicko2_accumulate; witness_count = how many witnessed it. This is what inference reads; per-witness provenance (layer/head) lives in attestations.context_id.';

SELECT pg_extension_config_dump('consensus', '');

CREATE INDEX consensus_subject_btree      ON consensus (subject_id);
CREATE INDEX consensus_object_btree       ON consensus (object_id) WHERE object_id IS NOT NULL;
CREATE INDEX consensus_kind_btree         ON consensus (kind_id);
CREATE INDEX consensus_subject_kind_btree ON consensus (subject_id, kind_id);
CREATE INDEX consensus_rating_btree       ON consensus (rating DESC, rd ASC);

/* consensus id = BLAKE3-128 of (subject ‖ kind ‖ (object|zero16)).
 * SOURCE + CONTEXT OUT — both are witnesses (source = which model, context = which layer/head),
 * never identity. NULL object folds to 16 zero bytes. ONE consensus row per relation identity,
 * regardless of which source/layer/head observed it. */
CREATE OR REPLACE FUNCTION consensus_id(
    p_subject bytea, p_kind bytea, p_object bytea)
    RETURNS bytea LANGUAGE sql LAPLACE_IMMUTABLE
    SET search_path = @extschema@, public AS $$
    SELECT public.laplace_hash128_blake3(
        p_subject || p_kind
        || COALESCE(p_object, '\x00000000000000000000000000000000'::bytea))
$$;

/* Rebuild the consensus layer from the evidence (attestations) via Glicko-2
 * accumulation. Batch (TRUNCATE + reinsert) — correct and simple; incremental
 * per-write accumulation can replace it once the writer drives it (the cost is
 * staleness between rebuilds, not correctness). Returns the consensus row count.
 *
 * ARCHITECTURE.md §10 — DERIVED, no knobs beyond M / the trust→φ shape / φ₀:
 *   prior     = neutral (μ=1500, rd=350, σ=0.06)
 *   opponent  = NEUTRAL baseline (μ=1500 — the same line as the prior, so a score
 *               of ½ is "as expected" → μ unchanged, rd tightens; >½ raises μ,
 *               <½ lowers it). Opponent RD = the witness's own opponent_rd (trust
 *               → φ); g(φ) does the weighting natively.
 *   score     = the witness's stored tanh outcome a.score (signed magnitude → win/
 *               loss), used directly — NOT re-derived from a rating.
 *   games     = observation_count: each occurrence is one match, replayed via
 *               generate_series so N occurrences accumulate as N Glicko games
 *               (Glicko-2 within a period is order-invariant, so this is exact).
 *   tau = 0.5. All fixed-point ×1e9. */
CREATE OR REPLACE FUNCTION rebuild_consensus()
    RETURNS bigint LANGUAGE plpgsql VOLATILE
    SET search_path = @extschema@, public AS $$
DECLARE n bigint;
BEGIN
    TRUNCATE consensus;
    INSERT INTO consensus (id, subject_id, kind_id, object_id, context_id,
                           rating, rd, volatility, witness_count, last_observed_at)
    SELECT consensus_id(g.subject_id, g.kind_id, g.object_id),
           g.subject_id, g.kind_id, g.object_id, NULL::bytea,
           (g.acc).rating, (g.acc).rd, (g.acc).volatility,
           g.witness_count, g.last_observed_at
    FROM (
        -- One group per RELATION IDENTITY (subject, kind, object); source AND context
        -- (layer/head) collapse here — every witnessing source+layer+head is a Glicko-2
        -- match for the same relation. witness_count = total GAMES (Σ observation_count)
        -- across all witnesses — the dedup ("~params − dupes"): one consensus row, game
        -- count = how many times the relation was actually observed.
        SELECT a.subject_id, a.kind_id, a.object_id,
               SUM(a.observation_count) AS witness_count,
               MAX(a.last_observed_at)  AS last_observed_at,
               laplace_glicko2_accumulate(
                   1500000000000::bigint, 350000000000::bigint, 60000000::bigint,    -- neutral prior (μ, rd, σ)
                   1500000000000::bigint,                                            -- NEUTRAL opponent μ (the 1500 line)
                   a.opponent_rd,                                                    -- opponent φ from witness trust
                   a.score,                                                          -- stored tanh outcome ∈ (0,1)
                   500000000::bigint                                                 -- tau = 0.5
               )                       AS acc
        FROM attestations a
        -- replay each observation observation_count times: N occurrences = N games
        CROSS JOIN LATERAL generate_series(1, a.observation_count) AS occ
        GROUP BY a.subject_id, a.kind_id, a.object_id
    ) g;
    GET DIAGNOSTICS n = ROW_COUNT;
    RETURN n;
END;
$$;

COMMENT ON FUNCTION rebuild_consensus() IS
    'Materialize the consensus table from the attestations evidence via Glicko-2 accumulation (K1 first-cut mapping). Batch rebuild; returns consensus row count.';

/* ── Permanent inference queries — part of the substrate, not regenerated per session ──────
 * Relatedness/inference is a sorted index scan over consensus effective μ (μ - 2·rd). These
 * are the queries the substrate ships with; call them directly instead of hand-writing SQL. */

/* Top consensus relations by effective μ, ranked. Optional kind filter (e.g. COMPLETES_TO).
 * This IS ranked-μ inference: a single index scan over consensus_rating_btree. */
CREATE OR REPLACE FUNCTION top_relations(p_limit integer DEFAULT 50, p_kind bytea DEFAULT NULL)
    RETURNS TABLE(subject_id bytea, kind_id bytea, object_id bytea, eff_mu numeric, witnesses bigint)
    LANGUAGE sql STABLE SET search_path = @extschema@, public AS $$
    SELECT c.subject_id, c.kind_id, c.object_id,
           round(((c.rating - 2*c.rd) / 1e9)::numeric, 3), c.witness_count
    FROM consensus c
    WHERE c.object_id IS NOT NULL AND (p_kind IS NULL OR c.kind_id = p_kind)
    ORDER BY (c.rating - 2*c.rd) DESC
    LIMIT p_limit
$$;
COMMENT ON FUNCTION top_relations(integer, bytea) IS
    'Top consensus relations by effective μ (μ - 2·rd), optional kind filter. Ranked-μ inference as a sorted index scan.';

/* The completions of a subject (n-gram / entity), ranked by consensus effective μ —
 * "[subject] ⇒ {objects} ORDER BY μ". The generation/lookup primitive (reads consensus,
 * not evidence — no per-query re-aggregation). */
CREATE OR REPLACE FUNCTION completions(p_subject bytea, p_limit integer DEFAULT 40)
    RETURNS TABLE(object_id bytea, kind_id bytea, eff_mu numeric, witnesses bigint)
    LANGUAGE sql STABLE SET search_path = @extschema@, public AS $$
    SELECT c.object_id, c.kind_id, round(((c.rating - 2*c.rd) / 1e9)::numeric, 3), c.witness_count
    FROM consensus c
    WHERE c.subject_id = p_subject AND c.object_id IS NOT NULL
    ORDER BY (c.rating - 2*c.rd) DESC
    LIMIT p_limit
$$;
COMMENT ON FUNCTION completions(bytea, integer) IS
    'Completions of a subject ranked by consensus effective μ — [subject] ⇒ {objects} ORDER BY μ.';

/* Consensus / dedup health: evidence vs consensus row counts + witness fan-in. dedup_ratio =
 * evidence/consensus (how much the per-witness evidence collapsed — the "~params - dupes"). */
CREATE OR REPLACE FUNCTION consensus_stats()
    RETURNS TABLE(evidence_rows bigint, consensus_rows bigint, dedup_ratio numeric,
                  avg_witnesses numeric, max_witnesses bigint)
    LANGUAGE sql STABLE SET search_path = @extschema@, public AS $$
    SELECT (SELECT count(*) FROM attestations),
           (SELECT count(*) FROM consensus),
           round((SELECT count(*) FROM attestations)::numeric
                 / NULLIF((SELECT count(*) FROM consensus), 0), 3),
           (SELECT round(avg(witness_count), 3) FROM consensus),
           (SELECT max(witness_count) FROM consensus)
$$;
COMMENT ON FUNCTION consensus_stats() IS
    'Dedup/consensus health: evidence rows, consensus rows, dedup ratio (evidence/consensus), avg + max witness fan-in.';
