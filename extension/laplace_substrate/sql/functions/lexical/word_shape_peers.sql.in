CREATE OR REPLACE FUNCTION word_shape_peers(
        p_word bytea,
        p_frechet_max double precision DEFAULT 0.02)
    RETURNS bytea[]
    LANGUAGE sql STABLE STRICT PARALLEL SAFE
    SET search_path = @extschema@, public AS $$
    WITH me AS (
        SELECT p.trajectory, p.coord, e.type_id, p.n_constituents,
               word_case_class_surface(p_word) AS case_class
        FROM physicalities p
        JOIN entities e ON e.id = p.entity_id
        WHERE p.entity_id = p_word
          AND p.type = 1
          AND p.trajectory IS NOT NULL
          AND p.coord IS NOT NULL
        ORDER BY p.id
        LIMIT 1
    ),
    -- Drive the candidate set off the GiST KNN index (physicalities_coord_gist) so this
    -- scans a small, index-ordered window instead of hash-joining every physicality that
    -- happens to share type_id/n_constituents (type_id alone is not selective -- it matches
    -- most of the vocabulary, e.g. "word", so pre-joining on it against millions of rows was
    -- the actual cost; type_id/n_constituents/case-class belong as post-filters on a bounded
    -- nearest-neighbor window, not as pre-join predicates).
    nearest AS (
        SELECT p2.entity_id, p2.trajectory, p2.coord, e2.type_id, p2.n_constituents
        FROM me, physicalities p2
        JOIN entities e2 ON e2.id = p2.entity_id
        WHERE p2.type = 1
          AND p2.trajectory IS NOT NULL
          AND p2.coord IS NOT NULL
          AND p2.entity_id <> p_word
        ORDER BY p2.coord <<->> me.coord
        LIMIT 500
    ),
    k AS (
        SELECT n.entity_id,
               public.laplace_frechet_4d(n.trajectory, me.trajectory) AS fr,
               public.laplace_angular_distance_4d(n.coord, me.coord) AS ang
        FROM nearest n, me
        WHERE n.type_id = me.type_id
          AND n.n_constituents = me.n_constituents
          AND entity_exists(n.entity_id)
          AND word_case_class_surface(n.entity_id) = me.case_class
        ORDER BY n.coord <<->> me.coord
        LIMIT 48
    )
    -- Frechet distance is the sole admission gate: it's order-sensitive (a genuine path/shape
    -- metric), unlike angular distance, which is computed off the centroid (average of
    -- constituent points) and is therefore mathematically order-INSENSITIVE -- any anagram
    -- pair (e.g. "cat"/"act") shares an identical centroid regardless of letter order, so
    -- `OR k.ang <= threshold` previously let every anagram slip through as a false "shape
    -- peer" no matter how large (and correctly discriminating) its Frechet distance was.
    -- Angular distance remains a legitimate secondary ORDER BY tie-break among candidates
    -- Frechet has already qualified -- just never a standalone admission criterion.
    SELECT COALESCE(array_agg(k.entity_id ORDER BY k.ang, k.fr), ARRAY[]::bytea[])
    FROM k
    WHERE k.fr <= p_frechet_max
$$;
