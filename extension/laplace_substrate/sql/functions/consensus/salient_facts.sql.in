CREATE OR REPLACE FUNCTION salient_facts(p_word bytea, p_lang bytea DEFAULT NULL,
                                    p_limit int DEFAULT 24)
    RETURNS TABLE(type text, fact text, eff_mu numeric, witnesses bigint)
    LANGUAGE sql STABLE PARALLEL SAFE
    SET search_path = @extschema@, public AS $$
    WITH reltypes AS MATERIALIZED (
        SELECT id FROM entities WHERE type_id = entity_type_id('RelationType')
    ), feat_dynamic AS MATERIALIZED (
        -- Dynamic HAS_FEATURE children (FEAT_case, FEAT_number, ...) carry an
        -- IS_A -> family-root edge in consensus (RelationTypeRegistry.SeedDynamic).
        -- Fenced ONCE here: the SQL wrapper relation_in_family() carries a SET
        -- search_path clause, so the planner can never inline it and its EXISTS
        -- probe would run per candidate row. (relation_type_in_family below is the
        -- C IMMUTABLE static check — cheap per row, unaffected.) Same truth table:
        -- static family via the C check, dynamic membership via this set.
        SELECT c.subject_id AS id FROM consensus c
        WHERE c.type_id = relation_type_id('IS_A')
          AND c.object_id = relation_type_id('HAS_FEATURE')
    ), lang AS (
        -- Resolved ONCE, not per candidate row. When p_lang is supplied COALESCE
        -- short-circuits and word_language() is never evaluated.
        SELECT COALESCE(p_lang, word_language(p_word)) AS l
    ), subj(id) AS (
        SELECT p_word UNION SELECT sn.synset_id FROM senses(p_word) sn
    ), top AS (
        SELECT cc.type_id, cc.object_id, cc.rating, cc.rd, cc.witness_count
        FROM subj s CROSS JOIN LATERAL (
            SELECT c.type_id, c.object_id, c.rating, c.rd, c.witness_count
            FROM v_consensus_unrefuted c
            LEFT JOIN reltypes obj_rt ON obj_rt.id = c.object_id
            WHERE c.subject_id = s.id AND c.object_id IS NOT NULL
              AND c.type_id IN (SELECT id FROM reltypes)
              AND NOT relation_type_in_family(c.type_id, 'HAS_POS')
              AND NOT relation_type_in_family(c.type_id, 'HAS_FEATURE')
              AND c.type_id NOT IN (SELECT id FROM feat_dynamic)
              AND c.type_id NOT IN (
                relation_type_id('HAS_SENSE'), relation_type_id('IS_SENSE_OF'),
                relation_type_id('HAS_LANGUAGE'), relation_type_id('PRECEDES'),
                relation_type_id('FOLLOWS'), relation_type_id('CO_OCCURS_WITH'),
                relation_type_id('OCCURS_IN_CONTEXT'), relation_type_id('HAS_LEX_CATEGORY'),
                relation_type_id('HAS_VERB_FRAME'),
                relation_type_id('IS_LEMMA_OF'), relation_type_id('IS_TRANSLATION_OF'),
                relation_type_id('HAS_EXAMPLE'), relation_type_id('EVOKES_FRAME'),
                relation_type_id('HAS_SYNSET_KEY'), relation_type_id('IS_TYPED_AS'),
                relation_type_id('HAS_NAME_ALIAS'))
              AND obj_rt.id IS NULL
            ORDER BY eff_mu(c.rating, c.rd) DESC LIMIT p_limit * 3
        ) cc
    ), ranked AS (
        -- Rank BEFORE labeling (mirrors evidence_receipt's Issue 52). The old
        -- shape ran realize() + type_label over EVERY row of `top` (dog: 413
        -- rows across 10 subjects) only to ORDER/LIMIT to p_limit afterwards --
        -- ~1.5ms/render x 413 dominated the call (~575ms warm on real data).
        -- Ranking needs only the eff_mu already in `top`, so it runs first over
        -- everything; labeling then runs over a small over-fetched pool
        -- (3x + 8 keeps top-N starvation implausible after the empty/ellipsis
        -- filters below drop rows). Same eff_mu order, same result set.
        SELECT t.type_id, t.object_id, t.rating, t.rd, t.witness_count,
               eff_mu(t.rating, t.rd) AS sort_mu
        FROM top t
        ORDER BY eff_mu(t.rating, t.rd) DESC
        LIMIT p_limit * 3 + 8
    )
    SELECT d.type, d.fact, d.eff_mu, d.witnesses FROM (
        SELECT type_label(r.type_id) AS type,
               realize(r.object_id, (SELECT l FROM lang)) AS fact,
               eff_mu_display(r.rating, r.rd) AS eff_mu, r.witness_count AS witnesses,
               r.sort_mu
        FROM ranked r
    ) d
    WHERE d.fact IS NOT NULL AND d.fact <> ''
      AND right(d.fact, 1) <> U&'\2026' AND right(d.type, 1) <> U&'\2026'
    ORDER BY d.sort_mu DESC
    LIMIT p_limit
$$;
