CREATE OR REPLACE FUNCTION collocates(p_word text, p_limit int DEFAULT 12)
    RETURNS TABLE(next_word text, mu numeric, witnesses bigint)
    LANGUAGE sql STABLE
    SET search_path = @extschema@, public AS $$
    -- Rank + LIMIT on ids first, render the ≤p_limit survivors (define/examples pattern) —
    -- render() was projected over every PRECEDES edge of the word before the cut.
    SELECT render(s.object_id), s.mu, s.witness_count
    FROM (
        SELECT c.object_id, eff_mu_display(c.rating, c.rd) AS mu, c.witness_count,
               eff_mu(c.rating, c.rd) AS er
        FROM v_consensus_unrefuted c
        WHERE c.subject_id = word_id(p_word)
          AND c.type_id = relation_type_id('PRECEDES')
        ORDER BY er DESC
        LIMIT p_limit
    ) s
    ORDER BY s.er DESC
$$;
