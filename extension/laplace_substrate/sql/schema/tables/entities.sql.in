CREATE TABLE IF NOT EXISTS entities (
    id                 bytea            PRIMARY KEY CHECK (octet_length(id) = 16),
    tier               smallint         NOT NULL CHECK (tier >= 0 AND tier < 256),
    type_id            bytea            NOT NULL,
    first_observed_by  bytea,
    created_at         timestamptz      NOT NULL DEFAULT now(),
    highway_mask       bytea            CHECK (highway_mask IS NULL OR octet_length(highway_mask) = 32)
);

-- Storage/statistics tuning (idempotent; applies on install and upgrade). At 100M+ rows the
-- default 10% autovacuum_analyze_scale_factor needs ~15M changes before autoanalyze fires, so
-- planner stats went stale during bulk ingest and mis-costed the descent/apply existence probes.
-- Fire autoanalyze at 2% or 100k changes, whichever comes first.
ALTER TABLE entities SET (autovacuum_analyze_scale_factor = 0.02, autovacuum_analyze_threshold = 100000);
