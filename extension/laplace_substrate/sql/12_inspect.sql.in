/* 12_inspect.sql.in — substrate inspection surface (the glass-box, by hand).
 *
 * Read-only SRFs that expose an entity's three facets — identity, glome
 * physicalities, and the Glicko-2-rated attestation neighborhood — so the
 * substrate can be interrogated directly instead of through ad-hoc inline
 * SQL in the app layer. Pure SQL (no engine call): these are projections
 * over the three core tables, not math. Entity-id resolution from text is
 * the engine's job (TextDecomposer + HashComposer); these take the already
 * content-addressed id and report what the substrate holds about it.
 *
 * STABLE: results depend only on table contents within a statement. */

CREATE OR REPLACE FUNCTION entity_facets(p_id bytea)
    RETURNS TABLE(tier smallint, type_id bytea)
    LANGUAGE sql STABLE
    SET search_path = @extschema@, public AS $$
    SELECT e.tier, e.type_id FROM entities e WHERE e.id = p_id
$$;

COMMENT ON FUNCTION entity_facets(bytea) IS
    'Identity facet of an entity: its tier and type_id. Empty if the id is '
    'not in the substrate (a correctly-resolved id for never-ingested content).';

CREATE OR REPLACE FUNCTION entity_physicalities(p_id bytea)
    RETURNS TABLE(kind smallint, x double precision, y double precision,
                  z double precision, m double precision,
                  radius double precision, n_constituents integer, source_id bytea)
    LANGUAGE sql STABLE
    SET search_path = @extschema@, public AS $$
    SELECT p.kind, ST_X(p.coord), ST_Y(p.coord), ST_Z(p.coord), ST_M(p.coord),
           p.radius_origin, p.n_constituents, p.source_id
    FROM physicalities p
    WHERE p.entity_id = p_id
    ORDER BY p.kind, p.source_id
$$;

COMMENT ON FUNCTION entity_physicalities(bytea) IS
    'Glome facet: every per-source 4D physicality on the entity (CONTENT / '
    'BUILDING_BLOCK / PROJECTION), with radius-from-origin and constituent count.';

CREATE OR REPLACE FUNCTION attestations_out(p_id bytea, p_limit integer DEFAULT 40)
    RETURNS TABLE(kind_id bytea, object_id bytea, source_id bytea, context_id bytea,
                  outcome smallint, observation_count bigint)
    LANGUAGE sql STABLE
    SET search_path = @extschema@, public AS $$
    SELECT a.kind_id, a.object_id, a.source_id, a.context_id,
           a.outcome, a.observation_count
    FROM attestations a
    WHERE a.subject_id = p_id
    ORDER BY a.observation_count DESC, a.outcome DESC
    LIMIT p_limit
$$;

COMMENT ON FUNCTION attestations_out(bytea, integer) IS
    'Outgoing EVIDENCE (provenance) neighborhood: who witnessed relations where the entity is the '
    'subject — source, circuit context (layer/head), outcome class (0=refute/1=draw/2=confirm), '
    'games. Evidence carries no values; for relation STRENGTH use the consensus reads '
    '(consensus_out/completions/top_relations).';

CREATE OR REPLACE FUNCTION attestations_in(p_id bytea, p_limit integer DEFAULT 40)
    RETURNS TABLE(subject_id bytea, kind_id bytea, source_id bytea, context_id bytea,
                  outcome smallint, observation_count bigint)
    LANGUAGE sql STABLE
    SET search_path = @extschema@, public AS $$
    SELECT a.subject_id, a.kind_id, a.source_id, a.context_id,
           a.outcome, a.observation_count
    FROM attestations a
    WHERE a.object_id = p_id
    ORDER BY a.observation_count DESC, a.outcome DESC
    LIMIT p_limit
$$;

COMMENT ON FUNCTION attestations_in(bytea, integer) IS
    'Incoming EVIDENCE (provenance) neighborhood: who witnessed relations where the entity is the '
    'object — source, circuit context, outcome class, games. Evidence carries no values; for '
    'strength use the consensus reads.';

/* ── READBACK + RESOLUTION: the substrate answers in its own voice ─────────────────────────
 *
 * Content-addressing is one-way (id = BLAKE3 of content / of the merkle of constituents),
 * so id→content is reconstructed from what the substrate already stores:
 *   composites — the Content physicality trajectory, whose mantissa-packed vertices ARE the
 *                ordered constituent ids (public.laplace_mantissa_unpack, laplace_geom);
 *   codepoints — id = BLAKE3-128(UTF-8 bytes of the codepoint) (engine unicode_seed.cpp),
 *                derivable wholly in SQL: the codepoint_render map is the perf-cache
 *                principle materialized in-DB (resolution index = lawful app plumbing);
 *   meta       — kinds/types/sources are entities derived from canonical name strings
 *                (BLAKE3 of the name); canonical_names is their reverse map, seeded by the
 *                converging migration and registered at ingest for dynamic families.
 * These are PERMANENT substrate functions — retrieval never hand-writes inline SQL. */

/* canonical name → entity id. The forward resolution primitive. */
CREATE FUNCTION canonical_id(p_name text) RETURNS bytea
    LANGUAGE sql IMMUTABLE STRICT AS $$
    SELECT public.laplace_hash128_blake3(convert_to(p_name, 'UTF8'))
$$;
COMMENT ON FUNCTION canonical_id(text) IS
    'BLAKE3-128 of a canonical name string — the id of the meta entity (kind/type/source) it names.';

/* Reverse map: meta entity id → canonical name. */
CREATE TABLE canonical_names (
    id   bytea PRIMARY KEY CHECK (octet_length(id) = 16),
    name text  NOT NULL
);
SELECT pg_extension_config_dump('canonical_names', '');
COMMENT ON TABLE canonical_names IS
    'Reverse resolution map for canonical-named meta entities (kinds/types/sources/physicality '
    'kinds). App plumbing, not consensus: rendering surface only. Writers register names at '
    'ingest via register_canonical.';

CREATE FUNCTION register_canonical(p_name text) RETURNS bytea
    LANGUAGE sql AS $$
    INSERT INTO canonical_names (id, name)
    VALUES (canonical_id(p_name), p_name)
    ON CONFLICT (id) DO NOTHING;
    SELECT canonical_id(p_name)
$$;
COMMENT ON FUNCTION register_canonical(text) IS
    'Idempotently record name→id in canonical_names and return the id. Called by writers for '
    'every canonical-named entity, including dynamic kind families.';

/* Codepoint leaf render map: id = BLAKE3-128(UTF-8(cp)) for every Unicode scalar value.
 * Derived in-DB from the same law the engine perfcache uses (unicode_seed.cpp) — no file,
 * no managed dictionary, one build, indexed lookups thereafter. */
CREATE TABLE codepoint_render (
    id bytea   PRIMARY KEY CHECK (octet_length(id) = 16),
    cp integer NOT NULL
);
SELECT pg_extension_config_dump('codepoint_render', '');
COMMENT ON TABLE codepoint_render IS
    'id → codepoint for all Unicode scalar values (U+0001..U+10FFFF minus surrogates; U+0000 '
    'unrepresentable in PG text). The perf-cache principle materialized in-DB for readback.';

CREATE FUNCTION build_codepoint_render() RETURNS bigint
    LANGUAGE sql AS $$
    INSERT INTO codepoint_render (id, cp)
    SELECT canonical_id(chr(g.cp)), g.cp
    FROM generate_series(1, 1114111) AS g(cp)
    WHERE g.cp NOT BETWEEN 55296 AND 57343
    ON CONFLICT (id) DO NOTHING;
    SELECT count(*) FROM codepoint_render
$$;
COMMENT ON FUNCTION build_codepoint_render() IS
    'Idempotently derive the full codepoint render map (~1.11M rows) in SQL. chr() encodes '
    'UTF-8 in a UTF8 database, so canonical_id(chr(cp)) IS the engine''s codepoint id.';

/* Ordered constituent ids of an entity, decoded from its Content physicality trajectory. */
CREATE FUNCTION constituents(p_id bytea)
    RETURNS TABLE(ordinal integer, child_id bytea)
    LANGUAGE sql STABLE
    SET search_path = @extschema@, public AS $$
    SELECT u.ordinal, u.entity_id
    FROM (
        /* Pick ONE Content physicality row FIRST (LIMIT before the SRF —
         * ST_DumpPoints in a limited subquery would truncate to one vertex). */
        SELECT p.trajectory AS traj
        FROM physicalities p
        WHERE p.entity_id = p_id
          AND p.kind = 1                 -- Content (PhysicalityKind.Content)
          AND p.trajectory IS NOT NULL
        ORDER BY p.source_id             -- deterministic; content law: identical across sources
        LIMIT 1
    ) t
    CROSS JOIN LATERAL public.ST_DumpPoints(t.traj) AS dp
    CROSS JOIN LATERAL public.laplace_mantissa_unpack(dp.geom) AS u
    ORDER BY 1
$$;
COMMENT ON FUNCTION constituents(bytea) IS
    'Ordered constituent ids of an entity, recovered from the mantissa-packed vertices of its '
    'Content trajectory. Empty for leaves (codepoints) and entities with no Content physicality.';

/* Recursive readback: any content entity id → its text. */
CREATE FUNCTION render_text(p_id bytea, p_max_depth integer DEFAULT 32)
    RETURNS text
    LANGUAGE sql STABLE
    SET search_path = @extschema@, public AS $$
    WITH RECURSIVE walk(id, path_ord, depth) AS (
        SELECT p_id, ARRAY[]::integer[], 0
        UNION ALL
        SELECT c.child_id, w.path_ord || c.ordinal, w.depth + 1
        FROM walk w
        CROSS JOIN LATERAL constituents(w.id) c
        WHERE w.depth < p_max_depth
          AND NOT EXISTS (SELECT 1 FROM codepoint_render r WHERE r.id = w.id)
    )
    SELECT string_agg(chr(r.cp), '' ORDER BY w.path_ord)
    FROM walk w
    JOIN codepoint_render r ON r.id = w.id
$$;
COMMENT ON FUNCTION render_text(bytea, integer) IS
    'Reconstruct the text of a content entity by recursive constituent descent to tier-0 '
    'codepoints (depth-first order). NULL when the id resolves to no codepoint leaves.';

/* Universal render: meta name, codepoint, content text, hex fallback — in that order. */
CREATE FUNCTION render(p_id bytea) RETURNS text
    LANGUAGE sql STABLE
    SET search_path = @extschema@, public AS $$
    SELECT COALESCE(
        (SELECT n.name FROM canonical_names n WHERE n.id = p_id),
        (SELECT chr(r.cp) FROM codepoint_render r WHERE r.id = p_id),
        render_text(p_id),
        encode(p_id, 'hex') || '…')
$$;
COMMENT ON FUNCTION render(bytea) IS
    'Render ANY entity id readable: canonical meta name, codepoint character, reconstructed '
    'content text, or hex as last resort.';

/* Readable consensus read — the inference surface in the substrate's own voice. */
CREATE FUNCTION consensus_out_readable(p_id bytea, p_limit integer DEFAULT 40)
    RETURNS TABLE(kind text, object text, eff_mu numeric, witnesses bigint)
    LANGUAGE sql STABLE
    SET search_path = @extschema@, public AS $$
    SELECT render(c.kind_id), render(c.object_id),
           round(((c.rating - 2*c.rd) / 1e9)::numeric, 3), c.witness_count
    FROM consensus c
    WHERE c.subject_id = p_id
    ORDER BY (c.rating - 2*c.rd) DESC
    LIMIT p_limit
$$;
COMMENT ON FUNCTION consensus_out_readable(bytea, integer) IS
    'consensus_out with every id rendered readable: [kind] → object, signed effective μ, witnesses.';
