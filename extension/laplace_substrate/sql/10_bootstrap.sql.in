/* 10_bootstrap.sql.in -- substrate-canonical seeding (per ADR 0042 + ADR 0044).
 *
 * Runs at extension install AFTER tables exist (modules 02-05) but BEFORE any
 * decomposer runs. Seeds the substrate's built-in entities required by ADR
 * 0042 stages 0-3.5:
 *
 *   Stage 0  -- meta-types: Type, Kind, PhysicalityKind, Source, SubstrateCanonical.
 *   Stage 1  -- SubstrateCanonical source entity.
 *   Stage 2  -- PhysicalityKind enum entities: CONTENT, BUILDING_BLOCK, PROJECTION.
 *   Stage 3  -- modality-agnostic attestation-kind vocabulary
 *               + kind-value-tier entities (T1..T11 per ADR 0044 Part A).
 *   Stage 3.5 -- 10 source-trust-class entities (per ADR 0044 Part B).
 *
 * All bootstrap rows are content-addressed by BLAKE3-128 of a canonical
 * name string of the form "substrate/<category>/<Name>/v1". Same substrate
 * version on any machine produces byte-identical bootstrap rows.
 *
 * Self-reference: the Type meta-type's type_id points at itself. We seed
 * Type FIRST (its id derived from its canonical name) then reference that
 * id from every subsequent row. */

DO $bootstrap$
DECLARE
    /* Stage 0 -- meta-type ids (content-addressed; computed via the
     * laplace_hash128_blake3 SQL wrapper). */
    type_id              bytea;
    kind_id              bytea;
    physicality_kind_id  bytea;
    source_id            bytea;
    subscan_id           bytea;  -- SubstrateCanonical source entity

    /* PhysicalityKind enum entity ids (Stage 2). */
    pk_content_id        bytea;
    pk_buildblock_id     bytea;
    pk_projection_id     bytea;
    pk_projection_out_id bytea;

    /* Universal text-tier type entities (used by TextEntityBuilder from ANY
     * text-using decomposer — Unicode T0 seed, the model decomposer's tokenizer pass,
     * future ladder sources). Substrate-canonical: same id everywhere. */
    type_codepoint_id    bytea;
    type_grapheme_id     bytea;
    type_word_id         bytea;
    type_sentence_id     bytea;
    type_document_id     bytea;

    /* Kind-value-tier entity ids (ADR 0044 Part A; T1..T11). */
    tier_t1_id  bytea;  tier_t2_id  bytea;  tier_t3_id  bytea;
    tier_t4_id  bytea;  tier_t5_id  bytea;  tier_t6_id  bytea;
    tier_t7_id  bytea;  tier_t8_id  bytea;  tier_t9_id  bytea;
    tier_t10_id bytea;  tier_t11_id bytea;

    /* Source-trust-class entity ids (ADR 0044 Part B; 10 tiers). */
    tc_mandate_id        bytea;
    tc_standards_id      bytea;
    tc_academic_id       bytea;
    tc_academic_user_id  bytea;
    tc_corpus_id         bytea;
    tc_user_curated_id   bytea;
    tc_ai_probe_id       bytea;
    tc_app_derived_id    bytea;
    tc_user_prompt_id    bytea;
    tc_adversarial_id    bytea;

    /* Modality-agnostic kind ids (Stage 3 vocabulary; bootstrap subset --
     * decomposers add their domain-specific kinds at first run). */
    kind_is_a_id              bytea;
    kind_has_part_id          bytea;
    kind_co_occurs_with_id    bytea;
    kind_follows_id           bytea;
    kind_precedes_id          bytea;
    kind_occurs_in_context_id bytea;
    kind_has_language_id      bytea;
    kind_is_translation_of_id bytea;
    kind_depicts_id           bytea;
    kind_captions_id          bytea;
    kind_transcribes_as_id    bytea;
    kind_is_lossy_enc_id      bytea;
    kind_has_variant_of_id    bytea;
    kind_is_replaced_by_id    bytea;
    kind_has_trust_class_id   bytea;
    kind_has_kind_tier_id     bytea;
    kind_is_alias_of_id       bytea;

    /* High tier reserved for abstract meta-entities so they don't collide
     * with content tiers (T0 codepoints through T255 in normal usage). */
    META_TIER  CONSTANT smallint := 250;
    KIND_TIER  CONSTANT smallint := 248;
    TRUST_TIER CONSTANT smallint := 247;

BEGIN
    /* === Stage 0: meta-types =========================================== */

    /* Compute ids by hashing the canonical name string. The Type meta-type
     * is self-referential: we compute its id first, then insert the row
     * with type_id = itself. */

    type_id             := public.laplace_hash128_blake3('substrate/type/Type/v1'::bytea);
    kind_id             := public.laplace_hash128_blake3('substrate/type/Kind/v1'::bytea);
    physicality_kind_id := public.laplace_hash128_blake3('substrate/type/PhysicalityKind/v1'::bytea);
    source_id           := public.laplace_hash128_blake3('substrate/type/Source/v1'::bytea);

    /* Insert Type (self-typed). FK constraints to entities(id) are deferred
     * until after bootstrap completes (see end of this block). */
    INSERT INTO entities (id, tier, type_id) VALUES
        (type_id,             META_TIER, type_id),
        (kind_id,             META_TIER, type_id),
        (physicality_kind_id, META_TIER, type_id),
        (source_id,           META_TIER, type_id);

    /* === Stage 1: substrate-canonical Source entity ==================== */

    subscan_id := public.laplace_hash128_blake3('substrate/source/SubstrateCanonical/v1'::bytea);
    INSERT INTO entities (id, tier, type_id, first_observed_by) VALUES
        (subscan_id, META_TIER, source_id, NULL);

    /* === Stage 2: PhysicalityKind enum entities ======================== */

    pk_content_id    := public.laplace_hash128_blake3('substrate/physicality_kind/CONTENT/v1'::bytea);
    pk_buildblock_id := public.laplace_hash128_blake3('substrate/physicality_kind/BUILDING_BLOCK/v1'::bytea);
    pk_projection_id := public.laplace_hash128_blake3('substrate/physicality_kind/PROJECTION/v1'::bytea);

    pk_projection_out_id := public.laplace_hash128_blake3('substrate/physicality_kind/PROJECTION_OUTPUT/v1'::bytea);

    INSERT INTO entities (id, tier, type_id, first_observed_by) VALUES
        (pk_content_id,        META_TIER, physicality_kind_id, subscan_id),
        (pk_buildblock_id,     META_TIER, physicality_kind_id, subscan_id),
        (pk_projection_id,     META_TIER, physicality_kind_id, subscan_id),
        (pk_projection_out_id, META_TIER, physicality_kind_id, subscan_id);

    /* === Stage 2.5: substrate-canonical text-tier type entities ===========
     *
     * Per GLOSSARY tier ladder and ADR 0047 TextDecomposer: every
     * text-using decomposer (UnicodeDecomposer at seed time; the model
     * decomposer's tokenizer pass; future linguistic-ladder sources; the prompt
     * ingest path) emits entities at tiers 0..6 with the per-tier type IDs
     * resolved by TextEntityBuilder.TierTypeId. The tier-type entities
     * themselves must exist in `entities` before any tier-N entity
     * referencing them is inserted (entities_type_fk).
     *
     * Codepoint is also emitted at runtime by UnicodeDecomposer's
     * InitializeAsync (idempotent under ON CONFLICT DO NOTHING). The
     * higher tiers (Grapheme/Word/Sentence/Document) have no runtime
     * bootstrap path — they're substrate canon. */

    type_codepoint_id := public.laplace_hash128_blake3('substrate/type/Codepoint/v1'::bytea);
    type_grapheme_id  := public.laplace_hash128_blake3('substrate/type/Grapheme/v1'::bytea);
    type_word_id      := public.laplace_hash128_blake3('substrate/type/Word/v1'::bytea);
    type_sentence_id  := public.laplace_hash128_blake3('substrate/type/Sentence/v1'::bytea);
    type_document_id  := public.laplace_hash128_blake3('substrate/type/Document/v1'::bytea);

    INSERT INTO entities (id, tier, type_id, first_observed_by) VALUES
        (type_codepoint_id, META_TIER, type_id, subscan_id),
        (type_grapheme_id,  META_TIER, type_id, subscan_id),
        (type_word_id,      META_TIER, type_id, subscan_id),
        (type_sentence_id,  META_TIER, type_id, subscan_id),
        (type_document_id,  META_TIER, type_id, subscan_id);

    /* === Stage 3.5: source-trust-class entities (ADR 0044 Part B) ====== *
     * We seed these BEFORE attestation kinds because the kind-tier entities
     * carry meta-attestations sourced to SubstrateCanonical, which itself
     * needs HAS_TRUST_CLASS pointing at TrustClass_SubstrateMandate. Stage
     * order: trust classes first, then kind tiers, then kinds, then the
     * meta-attestations binding them. */

    tc_mandate_id       := public.laplace_hash128_blake3('substrate/trust_class/SubstrateMandate/v1'::bytea);
    tc_standards_id     := public.laplace_hash128_blake3('substrate/trust_class/StandardsDerived/v1'::bytea);
    tc_academic_id      := public.laplace_hash128_blake3('substrate/trust_class/AcademicCurated/v1'::bytea);
    tc_academic_user_id := public.laplace_hash128_blake3('substrate/trust_class/AcademicCuratedWithUserInput/v1'::bytea);
    tc_corpus_id        := public.laplace_hash128_blake3('substrate/trust_class/StructuredCorpus/v1'::bytea);
    tc_user_curated_id  := public.laplace_hash128_blake3('substrate/trust_class/UserCuratedResource/v1'::bytea);
    tc_ai_probe_id      := public.laplace_hash128_blake3('substrate/trust_class/AIModelProbe/v1'::bytea);
    tc_app_derived_id   := public.laplace_hash128_blake3('substrate/trust_class/AppDerived/v1'::bytea);
    tc_user_prompt_id   := public.laplace_hash128_blake3('substrate/trust_class/UserPromptContent/v1'::bytea);
    tc_adversarial_id   := public.laplace_hash128_blake3('substrate/trust_class/AdversarialUntrusted/v1'::bytea);

    INSERT INTO entities (id, tier, type_id, first_observed_by) VALUES
        (tc_mandate_id,       TRUST_TIER, type_id, subscan_id),
        (tc_standards_id,     TRUST_TIER, type_id, subscan_id),
        (tc_academic_id,      TRUST_TIER, type_id, subscan_id),
        (tc_academic_user_id, TRUST_TIER, type_id, subscan_id),
        (tc_corpus_id,        TRUST_TIER, type_id, subscan_id),
        (tc_user_curated_id,  TRUST_TIER, type_id, subscan_id),
        (tc_ai_probe_id,      TRUST_TIER, type_id, subscan_id),
        (tc_app_derived_id,   TRUST_TIER, type_id, subscan_id),
        (tc_user_prompt_id,   TRUST_TIER, type_id, subscan_id),
        (tc_adversarial_id,   TRUST_TIER, type_id, subscan_id);

    /* === Stage 3: kind-value-tier entities (ADR 0044 Part A) =========== */

    tier_t1_id  := public.laplace_hash128_blake3('substrate/kind_tier/T1_Mandate/v1'::bytea);
    tier_t2_id  := public.laplace_hash128_blake3('substrate/kind_tier/T2_StandardsStructural/v1'::bytea);
    tier_t3_id  := public.laplace_hash128_blake3('substrate/kind_tier/T3_Taxonomic/v1'::bytea);
    tier_t4_id  := public.laplace_hash128_blake3('substrate/kind_tier/T4_Partitive/v1'::bytea);
    tier_t5_id  := public.laplace_hash128_blake3('substrate/kind_tier/T5_Causal/v1'::bytea);
    tier_t6_id  := public.laplace_hash128_blake3('substrate/kind_tier/T6_Equivalence/v1'::bytea);
    tier_t7_id  := public.laplace_hash128_blake3('substrate/kind_tier/T7_Oppositional/v1'::bytea);
    tier_t8_id  := public.laplace_hash128_blake3('substrate/kind_tier/T8_Associative/v1'::bytea);
    tier_t9_id  := public.laplace_hash128_blake3('substrate/kind_tier/T9_TensorCalculation/v1'::bytea);
    tier_t10_id := public.laplace_hash128_blake3('substrate/kind_tier/T10_ScalarValued/v1'::bytea);
    tier_t11_id := public.laplace_hash128_blake3('substrate/kind_tier/T11_Probationary/v1'::bytea);

    INSERT INTO entities (id, tier, type_id, first_observed_by) VALUES
        (tier_t1_id,  KIND_TIER, type_id, subscan_id),
        (tier_t2_id,  KIND_TIER, type_id, subscan_id),
        (tier_t3_id,  KIND_TIER, type_id, subscan_id),
        (tier_t4_id,  KIND_TIER, type_id, subscan_id),
        (tier_t5_id,  KIND_TIER, type_id, subscan_id),
        (tier_t6_id,  KIND_TIER, type_id, subscan_id),
        (tier_t7_id,  KIND_TIER, type_id, subscan_id),
        (tier_t8_id,  KIND_TIER, type_id, subscan_id),
        (tier_t9_id,  KIND_TIER, type_id, subscan_id),
        (tier_t10_id, KIND_TIER, type_id, subscan_id),
        (tier_t11_id, KIND_TIER, type_id, subscan_id);

    /* === Stage 3: modality-agnostic attestation kinds ================== */

    kind_is_a_id              := public.laplace_hash128_blake3('substrate/kind/IS_A/v1'::bytea);
    kind_has_part_id          := public.laplace_hash128_blake3('substrate/kind/HAS_PART/v1'::bytea);
    kind_co_occurs_with_id    := public.laplace_hash128_blake3('substrate/kind/CO_OCCURS_WITH/v1'::bytea);
    kind_follows_id           := public.laplace_hash128_blake3('substrate/kind/FOLLOWS/v1'::bytea);
    kind_precedes_id          := public.laplace_hash128_blake3('substrate/kind/PRECEDES/v1'::bytea);
    kind_occurs_in_context_id := public.laplace_hash128_blake3('substrate/kind/OCCURS_IN_CONTEXT/v1'::bytea);
    kind_has_language_id      := public.laplace_hash128_blake3('substrate/kind/HAS_LANGUAGE/v1'::bytea);
    kind_is_translation_of_id := public.laplace_hash128_blake3('substrate/kind/IS_TRANSLATION_OF/v1'::bytea);
    kind_depicts_id           := public.laplace_hash128_blake3('substrate/kind/DEPICTS/v1'::bytea);
    kind_captions_id          := public.laplace_hash128_blake3('substrate/kind/CAPTIONS/v1'::bytea);
    kind_transcribes_as_id    := public.laplace_hash128_blake3('substrate/kind/TRANSCRIBES_AS/v1'::bytea);
    kind_is_lossy_enc_id      := public.laplace_hash128_blake3('substrate/kind/IS_LOSSY_ENCODING_OF/v1'::bytea);
    kind_has_variant_of_id    := public.laplace_hash128_blake3('substrate/kind/HAS_VARIANT_OF/v1'::bytea);
    kind_is_replaced_by_id    := public.laplace_hash128_blake3('substrate/kind/IS_REPLACED_BY/v1'::bytea);
    kind_has_trust_class_id   := public.laplace_hash128_blake3('substrate/kind/HAS_TRUST_CLASS/v1'::bytea);
    kind_has_kind_tier_id     := public.laplace_hash128_blake3('substrate/kind/HAS_KIND_VALUE_TIER/v1'::bytea);
    kind_is_alias_of_id       := public.laplace_hash128_blake3('substrate/kind/IS_ALIAS_OF/v1'::bytea);

    INSERT INTO entities (id, tier, type_id, first_observed_by) VALUES
        (kind_is_a_id,              KIND_TIER, kind_id, subscan_id),
        (kind_has_part_id,          KIND_TIER, kind_id, subscan_id),
        (kind_co_occurs_with_id,    KIND_TIER, kind_id, subscan_id),
        (kind_follows_id,           KIND_TIER, kind_id, subscan_id),
        (kind_precedes_id,          KIND_TIER, kind_id, subscan_id),
        (kind_occurs_in_context_id, KIND_TIER, kind_id, subscan_id),
        (kind_has_language_id,      KIND_TIER, kind_id, subscan_id),
        (kind_is_translation_of_id, KIND_TIER, kind_id, subscan_id),
        (kind_depicts_id,           KIND_TIER, kind_id, subscan_id),
        (kind_captions_id,          KIND_TIER, kind_id, subscan_id),
        (kind_transcribes_as_id,    KIND_TIER, kind_id, subscan_id),
        (kind_is_lossy_enc_id,      KIND_TIER, kind_id, subscan_id),
        (kind_has_variant_of_id,    KIND_TIER, kind_id, subscan_id),
        (kind_is_replaced_by_id,    KIND_TIER, kind_id, subscan_id),
        (kind_has_trust_class_id,   KIND_TIER, kind_id, subscan_id),
        (kind_has_kind_tier_id,     KIND_TIER, kind_id, subscan_id),
        (kind_is_alias_of_id,       KIND_TIER, kind_id, subscan_id);

    /* === Meta-attestations binding it all together ===================== *
     * SubstrateCanonical HAS_TRUST_CLASS SubstrateMandate.
     * Each kind entity HAS_KIND_VALUE_TIER <its tier entity>.
     *
     * Attestation rating/rd/volatility uses T1 prior x SubstrateMandate
     * weight (per ADR 0044): rating=2500e9, rd=30e9, volatility=1e6
     * (T1 Mandate: rating 2500, RD 30, volatility 0.001 * 1e9 = 1e6;
     * trust class SubstrateMandate weight 1.0). int64 fixed-point at
     * scale 1e9 per ADR 0004.
     *
     * Attestation ids are computed via the laplace_hash128_merkle wrapper
     * over (subject_id, kind_id, object_id, source_id, context_id) so the
     * id IS the content. */

    /* SubstrateCanonical HAS_TRUST_CLASS TrustClass_SubstrateMandate */
    INSERT INTO attestations (
        id, subject_id, kind_id, object_id, source_id, context_id,
        rating, rd, volatility, last_observed_at, observation_count
    ) VALUES (
        public.laplace_hash128_merkle(0::smallint, ARRAY[
            subscan_id, kind_has_trust_class_id, tc_mandate_id, subscan_id, '\x00000000000000000000000000000000'::bytea
        ]),
        subscan_id, kind_has_trust_class_id, tc_mandate_id, subscan_id, NULL,
        2500000000000, 30000000000, 1000000, now(), 1
    );

    /* Each tier entity carries its own substrate-mandate attestation
     * declaring "HAS_KIND_VALUE_TIER IS_A T1_Mandate" (self-classifying
     * the tier-T1 vocabulary as mandate-class itself). Done as part of
     * the install bootstrap; queried at runtime by Glicko-2 initialization
     * to derive priors. */

    /* HAS_KIND_VALUE_TIER kind entity declares itself T2_StandardsStructural
     * (it's substrate-asserted but not invariant -- decomposers may add
     * domain-specific tiers as overrides). */
    INSERT INTO attestations (
        id, subject_id, kind_id, object_id, source_id, context_id,
        rating, rd, volatility, last_observed_at, observation_count
    ) VALUES (
        public.laplace_hash128_merkle(0::smallint, ARRAY[
            kind_has_kind_tier_id, kind_is_a_id, tier_t2_id, subscan_id, '\x00000000000000000000000000000000'::bytea
        ]),
        kind_has_kind_tier_id, kind_is_a_id, tier_t2_id, subscan_id, NULL,
        2300000000000, 60000000000, 5000000, now(), 1
    );

    /* === Deferred FK constraints (added now that bootstrap rows exist) = */

    ALTER TABLE entities ADD CONSTRAINT entities_type_fk
        FOREIGN KEY (type_id) REFERENCES entities(id);
    ALTER TABLE entities ADD CONSTRAINT entities_first_observed_fk
        FOREIGN KEY (first_observed_by) REFERENCES entities(id);
END $bootstrap$;
