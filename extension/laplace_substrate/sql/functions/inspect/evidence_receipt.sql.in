CREATE OR REPLACE FUNCTION evidence_receipt(p_id bytea, p_limit integer DEFAULT 25)
    RETURNS TABLE(
        type_id bytea,
        object_id bytea,
        type_label text,
        object_label text,
        eff_mu numeric,
        witness_count bigint,
        source_labels text)
    LANGUAGE sql STABLE
    SET search_path = @extschema@, public AS $$
    WITH subj(id) AS (
        SELECT p_id
        UNION
        SELECT sn.synset_id FROM senses(p_id) sn
    ), feat_dynamic AS MATERIALIZED (
        -- Dynamic HAS_FEATURE children fenced once; relation_in_family() never
        -- inlines (SET search_path), so calling it per attestation row ran its
        -- EXISTS probe per row. Same truth table: static family via the C check
        -- below, dynamic membership via this set.
        SELECT c.subject_id AS id FROM consensus c
        WHERE c.type_id = relation_type_id('IS_A')
          AND c.object_id = relation_type_id('HAS_FEATURE')
    ), filtered AS (
        SELECT a.type_id, a.object_id, a.source_id,
               sum(a.observation_count) AS obs
        FROM attestations a
        WHERE a.subject_id IN (SELECT id FROM subj)
          AND a.object_id IS NOT NULL
          AND EXISTS (
              SELECT 1 FROM entities et
              WHERE et.id = a.type_id AND et.type_id = entity_type_id('RelationType'))
          AND NOT relation_type_in_family(a.type_id, 'HAS_POS')
          AND NOT relation_type_in_family(a.type_id, 'HAS_FEATURE')
          AND a.type_id NOT IN (SELECT id FROM feat_dynamic)
          AND a.type_id NOT IN (
              relation_type_id('HAS_SENSE'), relation_type_id('IS_SENSE_OF'),
              relation_type_id('HAS_LANGUAGE'), relation_type_id('PRECEDES'),
              relation_type_id('FOLLOWS'), relation_type_id('CO_OCCURS_WITH'),
              relation_type_id('OCCURS_IN_CONTEXT'), relation_type_id('HAS_LEX_CATEGORY'),
              relation_type_id('HAS_VERB_FRAME'),
              relation_type_id('IS_LEMMA_OF'), relation_type_id('IS_TRANSLATION_OF'),
              relation_type_id('HAS_EXAMPLE'), relation_type_id('EVOKES_FRAME'),
              relation_type_id('HAS_SYNSET_KEY'), relation_type_id('IS_TYPED_AS'),
              relation_type_id('HAS_NAME_ALIAS'))
          AND NOT EXISTS (
              SELECT 1 FROM entities et
              WHERE et.id = a.object_id AND et.type_id = entity_type_id('RelationType'))
          AND NOT (
              a.type_id = relation_type_id('IS_SYNONYM_OF')
              AND a.object_id IN (SELECT id FROM subj))
        GROUP BY a.type_id, a.object_id, a.source_id
    ), src_labels AS MATERIALIZED (
        -- Label each DISTINCT source ONCE (sources number in the dozens), fenced
        -- so render() cannot be pushed back down to run per (type, object, source)
        -- group (~3,129 renders for one entity before this map existed). The
        -- string_agg below keeps the exact DISTINCT + ORDER BY label semantics of
        -- the old inline expression, so output is byte-identical.
        SELECT s.source_id,
               regexp_replace(render(s.source_id),
                   '^substrate/source/([^/]+)(?:/v[0-9]+)?$', '\1') AS label
        FROM (SELECT DISTINCT f.source_id FROM filtered f) s
    ), folded AS (
        SELECT f.type_id, f.object_id,
               sum(f.obs) AS witness_count,
               string_agg(DISTINCT sl.label, ', ' ORDER BY sl.label) AS source_labels
        FROM filtered f
        JOIN src_labels sl ON sl.source_id = f.source_id
        GROUP BY f.type_id, f.object_id
    ), ranked AS (
        -- Issue 52: rank BEFORE labeling. The old shape labeled every folded claim
        -- (type_label + _realize_synset_lemma/render_text, ~6ms/row — 3,129 labels
        -- to return 3 rows, >25s cold) and only then ordered/limited. Ranking needs
        -- only the indexed consensus probe, so it runs first over everything; labels
        -- run over a small over-fetched pool (labels can drop rows via the ellipsis/
        -- empty filters below — 3x+8 makes top-N starvation implausible while
        -- keeping labeling O(pool), not O(claims)).
        SELECT fo.type_id, fo.object_id, fo.witness_count, fo.source_labels,
               COALESCE(cm.mu_raw, 0)  AS mu_raw,
               COALESCE(cm.mu_disp, 0) AS eff_mu_disp
        FROM folded fo
        LEFT JOIN LATERAL (
            SELECT eff_mu(c.rating, c.rd) AS mu_raw,
                   eff_mu_display(c.rating, c.rd) AS mu_disp
            FROM consensus c
            WHERE c.subject_id IN (SELECT id FROM subj)
              AND c.type_id = fo.type_id
              AND c.object_id = fo.object_id
            ORDER BY eff_mu(c.rating, c.rd) DESC
            LIMIT 1
        ) cm ON true
        WHERE fo.source_labels IS NOT NULL AND fo.source_labels <> ''
        ORDER BY edge_rank(fo.type_id, COALESCE(cm.mu_raw, 0)) DESC,
                 fo.witness_count DESC
        LIMIT GREATEST(1, p_limit) * 3 + 8
    ), ordered AS (
        SELECT rk.*, row_number() OVER (
                   ORDER BY edge_rank(rk.type_id, rk.mu_raw) DESC,
                            rk.witness_count DESC) AS ord
        FROM ranked rk
    ), labels AS (
        -- Full-mesh labels via ONE realize_batch (was: a shorter hand-rolled
        -- synset-lemma -> render -> HEX ladder per row). Gains the
        -- HAS_NAME/translation/canonical/gloss arms; hex stays the genuine
        -- last resort so every claim still shows. Approved behavior change.
        SELECT realize_batch(array_agg(o.object_id ORDER BY o.ord),
                             word_language(p_id)) AS l
        FROM ordered o
    ), labeled AS (
        SELECT o.type_id, o.object_id, o.witness_count, o.source_labels,
               o.mu_raw, o.eff_mu_disp,
               type_label(o.type_id) AS rel,
               COALESCE(NULLIF(labels.l[o.ord], ''),
                        left(encode(o.object_id, 'hex'), 16)) AS obj
        FROM ordered o, labels
    )
    SELECT lb.type_id, lb.object_id, lb.rel, lb.obj,
           lb.eff_mu_disp,
           lb.witness_count,
           lb.source_labels
    FROM labeled lb
    WHERE lb.obj IS NOT NULL AND lb.obj <> ''
      AND right(lb.obj, 1) <> U&'\2026'
      AND right(lb.rel, 1) <> U&'\2026'
    ORDER BY edge_rank(lb.type_id, lb.mu_raw) DESC,
             lb.witness_count DESC
    LIMIT GREATEST(1, p_limit)
$$;
