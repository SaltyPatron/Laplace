CREATE FUNCTION @extschema@.laplace_mantissa_pack(
        entity_id  bytea,
        ordinal    integer,
        run_length integer,
        flags      bigint)
    RETURNS geometry
    AS 'MODULE_PATHNAME', 'pg_laplace_mantissa_pack'
    LANGUAGE C LAPLACE_IMMUTABLE_STRICT;

CREATE FUNCTION @extschema@.laplace_mantissa_unpack(vertex geometry,
        OUT entity_id  bytea,
        OUT ordinal    integer,
        OUT run_length integer,
        OUT flags      bigint)
    AS 'MODULE_PATHNAME', 'pg_laplace_mantissa_unpack'
    LANGUAGE C LAPLACE_IMMUTABLE_STRICT;

-- One C loop over a whole stored trajectory (vs ST_DumpPoints + per-vertex
-- unpack laterals). Output rows are bit-identical to that lateral.
CREATE FUNCTION @extschema@.laplace_trajectory_constituents(traj geometry,
        OUT ordinal    integer,
        OUT entity_id  bytea,
        OUT run_length integer,
        OUT flags      bigint)
    RETURNS SETOF record
    AS 'MODULE_PATHNAME', 'pg_laplace_trajectory_constituents'
    LANGUAGE C LAPLACE_IMMUTABLE_STRICT ROWS 16;

-- Native bytea[] of a trajectory's DISTINCT constituent entity-ids: the content-addressed key for
-- the reverse lookup (which trajectories contain an entity) via a GIN @> index, no SQL array_agg.
-- From a containing trajectory you then read precedes/follows (the witnessed word order) directly.
CREATE FUNCTION @extschema@.laplace_trajectory_constituent_ids(traj geometry)
    RETURNS bytea[]
    AS 'MODULE_PATHNAME', 'pg_laplace_trajectory_constituent_ids'
    LANGUAGE C LAPLACE_IMMUTABLE_STRICT;

-- Vertex flag-word field decode (mantissa.h is the single source of the layout).
-- vertex_atom returns NULL when the vertex carries no inline T0 atom.
CREATE FUNCTION @extschema@.laplace_vertex_atom(flags bigint) RETURNS integer
    AS 'MODULE_PATHNAME', 'pg_laplace_vertex_atom'
    LANGUAGE C LAPLACE_IMMUTABLE_STRICT;

CREATE FUNCTION @extschema@.laplace_vertex_tier(flags bigint) RETURNS smallint
    AS 'MODULE_PATHNAME', 'pg_laplace_vertex_tier'
    LANGUAGE C LAPLACE_IMMUTABLE_STRICT;
