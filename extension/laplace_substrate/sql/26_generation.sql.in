-- ── generation surface ────────────────────────────────────────────────────────
-- Stride-continuation generation over witnessed content trajectories.
-- SINGLE SOURCE: physicalities.trajectory — each vertex mantissa-encodes its
-- entity id, so the geometry IS the sequence. The kernel (trajectory_walk.c)
-- builds a backend-cached trajectory stream straight from the trajectories (edge scan +
-- constituency walk to the token floor), then a suffix array; longest-context
-- stride descent is binary search; weighted selection is seeded, so (stream, prompt, seed)
-- reproduces its output exactly. When the witnessed stream is silent at every
-- order, the COMPLETES_TO consensus is the floor (steps marked stride_used = 0).
--
-- The separator rule (word stride): whitespace tokens are witnessed content
-- (round-trip law) but are NOT units of order — the stream excludes them, so
-- contexts, pairs, and gap distances count in content-bearing strides. Display
-- re-inserts separators (SubstrateClient.cs is the single separator authority).
--
-- There is no content_index table, no constituency_edge table, no content_pairs
-- cache — those were derived disk copies of the trajectories and are retired.

-- refresh-safe retirement of the derived copies (live DBs converge on refresh;
-- retired objects may be extension MEMBERS there — membership drops first)
DO $do$
DECLARE
    obj text;
BEGIN
    FOREACH obj IN ARRAY ARRAY[
        'TABLE @extschema@.content_pairs',
        'PROCEDURE @extschema@.rebuild_content_index(int)',
        'PROCEDURE @extschema@.rebuild_content_index_deep()',
        'PROCEDURE @extschema@.rebuild_content_pairs(int)']
    LOOP
        BEGIN
            EXECUTE format('ALTER EXTENSION %I DROP %s', 'laplace_substrate', obj);
        EXCEPTION WHEN OTHERS THEN
            NULL;  -- not a member / does not exist: already converged
        END;
    END LOOP;
    EXECUTE 'DROP TABLE IF EXISTS @extschema@.content_pairs';
    EXECUTE 'DROP TABLE IF EXISTS @extschema@.content_index';
    EXECUTE 'DROP TABLE IF EXISTS @extschema@.constituency_edge';
    EXECUTE 'DROP PROCEDURE IF EXISTS @extschema@.rebuild_content_index(int)';
    EXECUTE 'DROP PROCEDURE IF EXISTS @extschema@.rebuild_content_index_deep()';
    EXECUTE 'DROP PROCEDURE IF EXISTS @extschema@.rebuild_content_pairs(int)';
    -- retired foundry-export experiments: the export reads consensus (foundry_vocab +
    -- entity_relation_plane), it does not re-fold trajectories at export time.
    EXECUTE 'DROP FUNCTION IF EXISTS @extschema@.entity_trajectory_plane(bytea[], int, int)';
    EXECUTE 'DROP FUNCTION IF EXISTS @extschema@.cooccurrence_scan(int, bytea[])';
END $do$;

-- trajectory-stream observability + warm verb: building the stream IS the warm-up; the
-- stats are the receipt (sequences walked, word-stride positions, distinct entities,
-- separators excluded, and the invalidation probe state).
CREATE OR REPLACE FUNCTION stream_stats(
        OUT sequences bigint, OUT positions bigint, OUT distinct_entities int,
        OUT separators bigint, OUT trajectories bigint, OUT last_witnessed timestamptz)
    AS 'MODULE_PATHNAME', 'pg_laplace_stream_stats'
    LANGUAGE C VOLATILE;

-- Trajectory pairs straight from the trajectory stream (word-stride by
-- construction): one walk, sliding window, in-memory hash aggregation —
-- engine computes, SQL orchestrates.
-- Native trajectory-pair scan: the GENERATION co-occurrence surface (relation_plane
-- 'traj', trajectory_cooccurrence). The foundry's order ladder does NOT use this — it
-- reads the trajectories set-based in SQL (entity_trajectory_plane). One walk over the
-- per-backend stream, in-memory hash aggregation.
CREATE OR REPLACE FUNCTION cooccurrence_scan(p_max_gap int)
    RETURNS TABLE(gap int, subject_id bytea, object_id bytea, cnt bigint)
    AS 'MODULE_PATHNAME', 'pg_laplace_cooccurrence_scan'
    LANGUAGE C STRICT VOLATILE;

-- Trajectory pair surface for the foundry: forward co-occurrence counts within
-- a window over witnessed content sequences, with per-subject totals so callers
-- form conditional frequencies — the "followed by N% of the time" distribution.
-- p_window=1 is strict continuation; larger windows give the forward co-occurrence
-- surface.
CREATE OR REPLACE FUNCTION trajectory_cooccurrence(p_window int DEFAULT 1)
    RETURNS TABLE(subject_id bytea, object_id bytea, cnt bigint, subject_total bigint)
    LANGUAGE sql VOLATILE
    SET search_path = @extschema@, public AS $$
    WITH pairs AS (
        SELECT s.subject_id AS s, s.object_id AS o, sum(s.cnt) AS c
        FROM cooccurrence_scan(p_window) s
        GROUP BY s.subject_id, s.object_id
    ), totals AS (
        SELECT s, sum(c) AS t FROM pairs GROUP BY s
    )
    SELECT p.s, p.o, p.c::bigint, t.t::bigint FROM pairs p JOIN totals t USING (s)
$$;

-- The order ladder, one pass: pair counts BY GAP (exact forward word-stride
-- distance within a witnessed sequence) up to p_max_gap, with per-(subject,gap)
-- totals. The foundry pours gap g into layer g of the mold — depth in the cast
-- model is bought with sequential order from the trajectories.
CREATE OR REPLACE FUNCTION trajectory_cooccurrence_by_stride(p_max_gap int DEFAULT 8)
    RETURNS TABLE(subject_id bytea, object_id bytea, gap int, cnt bigint, subject_total bigint)
    LANGUAGE sql VOLATILE
    SET search_path = @extschema@, public AS $$
    SELECT s.subject_id, s.object_id, s.gap, s.cnt,
           sum(s.cnt) OVER (PARTITION BY s.subject_id, s.gap)::bigint
    FROM cooccurrence_scan(p_max_gap) s
$$;

-- ── the generic plane surface ───────────────────────────────────────────────────
-- ONE read surface for entity→entity strength, whatever the source: adjudicated
-- consensus arenas, or readings of the content trajectories (which carry
-- precedes/follows/co-occurs at every gap without new records). Everything that
-- consumes planes — the foundry, audits, walk views — reads THIS, so sources are
-- interchangeable, combinations are plain SQL, and the surface is regress-pinnable.
--
--   relation_plane('consensus', 'SIMILAR_TO')   eff-μ RELATIVE TO NEUTRAL, in μ units
--                                               (signed: refuted < 0 < confirmed)
--   relation_plane('traj', 'next')              P(object follows subject), gap 1
--   relation_plane('traj', 'gap', 3)            P(object at exact distance 3 | subject)
--   relation_plane('traj', 'window', 4)         P(object within 4 ahead | subject)
--
-- Trajectory families read the trajectory stream (word stride) via the native scan.
CREATE OR REPLACE FUNCTION relation_plane(p_family text, p_name text, p_arg int DEFAULT NULL)
    RETURNS TABLE(subject_id bytea, object_id bytea, w double precision)
    LANGUAGE plpgsql VOLATILE
    SET search_path = @extschema@, public AS $$
DECLARE
    g int;
BEGIN
    IF p_family = 'consensus' THEN
        RETURN QUERY
        SELECT c.subject_id, c.object_id,
               (eff_mu(c.rating, c.rd) - glicko2_neutral_mu())::double precision / 1e9
        FROM consensus c
        WHERE c.type_id = relation_type_id(p_name) AND c.object_id IS NOT NULL;
        RETURN;
    END IF;

    IF p_family <> 'traj' THEN
        RAISE EXCEPTION 'relation_plane: unknown family % (consensus | traj)', p_family;
    END IF;

    g := CASE p_name
             WHEN 'next'   THEN 1
             WHEN 'gap'    THEN COALESCE(p_arg, 1)
             WHEN 'window' THEN COALESCE(p_arg, 4)
             ELSE NULL
         END;
    IF g IS NULL THEN
        RAISE EXCEPTION 'relation_plane: unknown traj plane % (next | gap | window)', p_name;
    END IF;

    IF p_name = 'window' THEN
        RETURN QUERY
        SELECT t.subject_id, t.object_id, t.cnt::double precision / t.subject_total
        FROM trajectory_cooccurrence(g) t;
        RETURN;
    END IF;

    RETURN QUERY
    SELECT t.subject_id, t.object_id, t.cnt::double precision / t.subject_total
    FROM trajectory_cooccurrence_by_stride(g) t WHERE t.gap = g;
END;
$$;

-- Vocab-bounded entity→entity consensus plane: ONLY the vocab×vocab edges of the
-- given relation types, degree-capped per subject by |eff-μ|, computed server-side
-- via the (subject_id, type_id) index — no full-type scan, no row streaming to the
-- client. The foundry passes its vocab entity set + the relation names for a role
-- (similarity / relation / completion / co-occurrence) and gets back exactly the
-- intra-vocab adjacency it pours, already capped. PARALLEL SAFE so PG fans it out.
CREATE OR REPLACE FUNCTION entity_relation_plane(
        p_vocab bytea[], p_rel_names text[], p_degree_cap int DEFAULT 48)
    RETURNS TABLE(subject_id bytea, object_id bytea, w double precision)
    LANGUAGE sql STABLE PARALLEL SAFE
    SET search_path = @extschema@, public AS $$
    WITH v(id) AS (SELECT DISTINCT u FROM unnest(p_vocab) AS u),
         t(tid) AS (SELECT relation_type_id(n) FROM unnest(p_rel_names) AS n),
         edges AS (
             SELECT c.subject_id, c.object_id,
                    (eff_mu(c.rating, c.rd) - glicko2_neutral_mu())::double precision / 1e9 AS w
             FROM v
             JOIN consensus c ON c.subject_id = v.id
             JOIN t           ON t.tid = c.type_id
             WHERE c.object_id IS NOT NULL
               AND EXISTS (SELECT 1 FROM v vo WHERE vo.id = c.object_id)
         ),
         capped AS (
             SELECT e.subject_id, e.object_id, e.w,
                    row_number() OVER (PARTITION BY e.subject_id
                                       ORDER BY abs(e.w) DESC, e.object_id) AS rn
             FROM edges e
         )
    SELECT c.subject_id, c.object_id, c.w FROM capped c WHERE c.rn <= p_degree_cap
$$;

-- WITHIN-LAYER plane (the export's data source done right): the rated adjacency among the
-- vocab for ONE layer = one rank band. Stays inside the layer (the ranks ARE the layers):
--   * relation_rank IS NOT NULL  -> a relation in the banked law (drops unnamed/unregistered types)
--   * relation_rank BETWEEN lo,hi -> the layer's rank band (e.g. 0.45..0.85 = the semantic layers)
--   * object in the vocab          -> the claim points at CONTENT, not a schema anchor (drops HAS_POS
--                                     etc. whose object is a grammatical anchor)
-- weight w = eff_mu (the adjudicated rating; positive affinity), degree-capped by rank*eff_mu.
-- The export transcribes one of these per rank into the container's per-layer slots — no flatten,
-- no metadata, no learning. See memory attestations-are-tensors / layering-data-class-law.
CREATE OR REPLACE FUNCTION consensus_layer_plane(
        p_vocab bytea[], p_rank_lo float8, p_rank_hi float8, p_degree_cap int DEFAULT 48)
    RETURNS TABLE(subject_id bytea, object_id bytea, w double precision, layer_rank double precision)
    LANGUAGE sql STABLE PARALLEL SAFE
    SET search_path = @extschema@, public AS $$
    WITH v(id) AS (SELECT DISTINCT u FROM unnest(p_vocab) AS u),
         edges AS (
             SELECT c.subject_id, c.object_id,
                    (eff_mu(c.rating, c.rd))::float8 / 1e9 AS w,
                    relation_rank(c.type_id) AS rk
             FROM v
             JOIN consensus c ON c.subject_id = v.id
             WHERE c.object_id IS NOT NULL
               AND EXISTS (SELECT 1 FROM v vo WHERE vo.id = c.object_id)
               AND relation_rank(c.type_id) IS NOT NULL
               AND relation_rank(c.type_id) BETWEEN p_rank_lo AND p_rank_hi
         ),
         capped AS (
             SELECT e.subject_id, e.object_id, e.w, e.rk,
                    row_number() OVER (PARTITION BY e.subject_id ORDER BY e.rk * e.w DESC, e.object_id) AS rn
             FROM edges e
         )
    SELECT c.subject_id, c.object_id, c.w, c.rk FROM capped c WHERE c.rn <= p_degree_cap
$$;

-- FAITHFUL adjacency (the generative mold's transcription source): the rank-weighted rated
-- CONTENT adjacency among the vocab. Each X→Y edge weight is the SUM over every relation type
-- of relation_rank(type_id) · eff_mu — the rank read PER EDGE from the banked relation law
-- (engine/manifest/relation_types.toml is the single source; relation_rank() wraps the native
-- lookup), NEVER a hand-typed band weight in the caller. There is NO rank-band slicing: the
-- FULL ladder contributes, each relation by its OWN authority, so mandate>taxonomic>…>probationary
-- falls out of the data, not out of magic numbers. Content objects only — object must be IN the
-- vocab (a tier-2 wordform), which structurally drops schema/metadata claims like HAS_POS (whose
-- object is a grammatical anchor, not in the vocab). relation_rank IS NOT NULL drops unnamed/
-- unregistered types. Degree-capped per subject by the summed weight.
-- The generator writes lm_head = A, embed = I; in the cast, logits[Y] = √dim·lm_head[Y,X], and
-- the mold pre-divides A by √dim, so logits[Y] = A[Y,X] EXACTLY — the rank-weighted rating
-- looked up, the GEMM literally is the lookup. No SVD, no gains, no learning.
CREATE OR REPLACE FUNCTION consensus_adjacency(
        p_vocab bytea[], p_degree_cap int DEFAULT 64)
    RETURNS TABLE(subject_id bytea, object_id bytea, w double precision)
    LANGUAGE sql STABLE PARALLEL SAFE
    SET search_path = @extschema@, public AS $$
    WITH v(id) AS (SELECT DISTINCT u FROM unnest(p_vocab) AS u),
         edges AS (
             -- BOTH endpoints joined to the vocab set (hash join, O(edges)) — never an
             -- EXISTS-over-unnest, which is a per-edge linear scan of the array (O(edges·vocab),
             -- the hang at large vocab). subject ∈ vocab AND object ∈ vocab keeps the adjacency
             -- inside the token set and drops schema/metadata objects (HAS_POS' anchor ∉ vocab).
             SELECT c.subject_id, c.object_id,
                    sum(relation_rank(c.type_id) * (eff_mu(c.rating, c.rd))::float8 / 1e9) AS w
             FROM v
             JOIN consensus c ON c.subject_id = v.id
             JOIN v vo        ON vo.id = c.object_id
             WHERE relation_rank(c.type_id) IS NOT NULL
             GROUP BY c.subject_id, c.object_id
         ),
         capped AS (
             SELECT e.subject_id, e.object_id, e.w,
                    row_number() OVER (PARTITION BY e.subject_id ORDER BY e.w DESC, e.object_id) AS rn
             FROM edges e
             WHERE e.w > 0
         )
    SELECT c.subject_id, c.object_id, c.w FROM capped c WHERE c.rn <= p_degree_cap
$$;

-- The foundry's TOKEN LIST: a COHERENT, self-defining vocabulary of single UAX29
-- wordforms (entities.tier = 2 — never multi-word lexical entries, Unicode-name blobs, or
-- id junk). Two parts so the vocab can represent its own members:
--   seeds   = the most FREQUENT single words (forward-sequence/PRECEDES degree = the
--             tokenizer's frequency axis) — the words that actually tile text.
--   closure = the single words those seeds DEFINE / RELATE to (IS_A, IS_SYNONYM_OF,
--             RELATED_TO, HAS_PART, DERIVATIONALLY_RELATED, coordinate terms) — so if `dog`
--             is in, `animal / canine / domestic / …` are in too (no top-k that can't
--             define its own tokens). weight = frequency (the SPM score). Set-based; the
--             CLI calls THIS, never ad-hoc SQL.
CREATE OR REPLACE FUNCTION foundry_vocab(p_size int)
    RETURNS TABLE(entity_id bytea, surface text, weight bigint)
    LANGUAGE sql STABLE PARALLEL SAFE
    SET search_path = @extschema@, public AS $$
    WITH freq AS (
        SELECT c.subject_id AS id, count(*) AS d
        FROM consensus c
        WHERE c.type_id = relation_type_id('PRECEDES') AND c.object_id IS NOT NULL
        GROUP BY c.subject_id
    ),
    seeds AS (
        SELECT f.id, f.d
        FROM freq f JOIN entities e ON e.id = f.id AND e.tier = 2
        ORDER BY f.d DESC LIMIT p_size
    ),
    closure AS (
        SELECT DISTINCT c.object_id AS id
        FROM consensus c
        JOIN seeds s ON s.id = c.subject_id
        JOIN entities e ON e.id = c.object_id AND e.tier = 2
        WHERE c.object_id IS NOT NULL
          AND c.type_id IN (
              relation_type_id('IS_A'), relation_type_id('IS_SYNONYM_OF'),
              relation_type_id('RELATED_TO'), relation_type_id('HAS_PART'),
              relation_type_id('DERIVATIONALLY_RELATED'), relation_type_id('IS_COORDINATE_TERM_WITH'))
    ),
    ids AS (SELECT id FROM seeds UNION SELECT id FROM closure),
    named AS (
        SELECT i.id, render_text(i.id, 64) AS s, COALESCE(f.d, 0) AS d
        FROM ids i LEFT JOIN freq f ON f.id = i.id
    ),
    clean AS (
        SELECT DISTINCT ON (n.s) n.id, n.s, n.d
        FROM named n
        WHERE n.s IS NOT NULL AND btrim(n.s) <> '' AND NOT is_all_whitespace(n.s)
          AND position(' ' IN n.s) = 0 AND char_length(n.s) <= 40
        ORDER BY n.s, n.d DESC
    )
    SELECT c.id, c.s, c.d FROM clean c ORDER BY c.d DESC LIMIT p_size
$$;

-- native crawl kernel (the heavy lifter): BFS over consensus from the seed ids
-- along the strongest-affirmed edges, O(1) HTAB dedup, index-driven per-node
-- fanout. Returns tier-2 word ids ranked by path relevance (product of edge
-- strengths). Implemented in foundry_crawl.c — SQL never walks the graph itself.
CREATE OR REPLACE FUNCTION foundry_crawl(
        p_seeds bytea[], p_budget int DEFAULT 32000, p_hops int DEFAULT 3, p_fanout int DEFAULT 64,
        p_rel_types bytea[] DEFAULT NULL)
    RETURNS TABLE(entity_id bytea, weight bigint)
    AS 'MODULE_PATHNAME', 'pg_laplace_foundry_crawl'
    LANGUAGE C VOLATILE;

-- SEEDED CRAWL vocab (thin orchestrator over foundry_crawl): pick a few words;
-- the substrate crawls the consensus OUTWARD from them and returns the connected
-- word neighborhood — that IS the token list (focused on the seeds, self-defining,
-- NOT a global top-N). SQL only resolves seed text→id, renders the returned ids
-- (render_text_batch — also native), dedups by surface, and trims to budget; the
-- graph walk and the rendering are both C. Bounded by p_hops + per-node fanout so
-- it runs in the seeds' time, not the whole graph's. Single UAX29 wordforms (tier 2).
CREATE OR REPLACE FUNCTION foundry_vocab_crawl(
        p_seeds text[], p_max int DEFAULT 32000, p_hops int DEFAULT 3, p_fanout int DEFAULT 64)
    RETURNS TABLE(entity_id bytea, surface text, weight bigint)
    LANGUAGE sql VOLATILE
    SET search_path = @extschema@, public AS $$
    WITH seed_ids AS (
        SELECT coalesce(array_agg(wid), '{}'::bytea[]) AS ids
        FROM (SELECT word_id(s) AS wid FROM unnest(p_seeds) AS s) q
        WHERE wid IS NOT NULL
    ),
    -- the SEMANTIC / definitional edge set: what a word IS, MEANS, RELATES TO and
    -- is BUILT FROM — never PRECEDES/co-occurrence (that is the stop-word axis) and
    -- never the Unicode/language metadata relations. This is the "walk the trees,
    -- include the tokens it references and relates to" set.
    -- the clean WordNet/lexical edge set: hypernymy, synonymy, meronymy,
    -- derivation, sense bridges. ConceptNet RELATED_TO / HAS_DOMAIN_TOPIC are
    -- deliberately OUT — at depth they drag in high-frequency function words
    -- (the stop-word axis); the lexical relations stay on the seeds' meaning.
    rel_types AS (
        SELECT array_agg(relation_type_id(n)) AS ids
        FROM unnest(ARRAY[
            'IS_A','IS_SYNONYM_OF','IS_COORDINATE_TERM_WITH','IS_ANTONYM_OF',
            'HAS_PART','PART_OF','MEMBER_OF','HAS_MEMBER','DERIVATIONALLY_RELATED',
            'FORM_OF','HAS_HYPONYM','IS_HYPERNYM_OF','SIMILAR_TO','PERTAINS_TO',
            'HAS_SENSE','IS_SENSE_OF'
        ]) AS n
    ),
    crawled AS (
        SELECT c.entity_id, c.weight,
               row_number() OVER (ORDER BY c.weight DESC, c.entity_id) AS rn
        FROM seed_ids si, rel_types rt
        CROSS JOIN LATERAL foundry_crawl(si.ids, p_max, p_hops, p_fanout, rt.ids) c
    ),
    -- SEQUENCE GLUE (scaffold): the highest-PRECEDES single wordforms. A lexical-only
    -- crawl has no SEQUENCE coverage — the words that actually follow content words in
    -- text (dog → and/the/he/growls/look) are function/common words the crawl excludes,
    -- so without these the model has nothing to complete TO and cannot form sentences.
    -- Reserved to a quarter of the budget and ranked BELOW the crawl, so the vocab stays
    -- topic-first but can still sequence. (PRECEDES is the generation axis; it earns its
    -- place here even though it is the stop-word axis for SELECTION.)
    scaffold AS (
        SELECT f.id AS entity_id, f.d::bigint AS weight,
               row_number() OVER (ORDER BY f.d DESC) AS rn
        FROM (
            SELECT c.subject_id AS id, count(*) AS d
            FROM consensus c
            JOIN entities e ON e.id = c.subject_id AND e.tier = 2
            WHERE c.type_id = relation_type_id('PRECEDES') AND c.object_id IS NOT NULL
            GROUP BY c.subject_id
        ) f
    ),
    picked AS (
        SELECT entity_id, weight, 1 AS pri FROM crawled  WHERE rn <= p_max - p_max / 4
        UNION ALL
        SELECT entity_id, weight, 0 AS pri FROM scaffold WHERE rn <= p_max / 4
    ),
    uniq AS (
        SELECT DISTINCT ON (entity_id) entity_id, weight, pri
        FROM picked ORDER BY entity_id, pri DESC, weight DESC
    ),
    ids_arr AS (
        SELECT array_agg(entity_id ORDER BY pri DESC, weight DESC) AS ids,
               array_agg(weight     ORDER BY pri DESC, weight DESC) AS ws,
               array_agg(pri        ORDER BY pri DESC, weight DESC) AS prs
        FROM uniq
    ),
    rendered AS (
        SELECT u.entity_id, u.s, a.ws[u.ord::int] AS weight, a.prs[u.ord::int] AS pri
        FROM ids_arr a
        CROSS JOIN LATERAL unnest(a.ids, render_text_batch(a.ids, 8))
                   WITH ORDINALITY AS u(entity_id, s, ord)
        WHERE a.ids IS NOT NULL AND cardinality(a.ids) > 0
    ),
    clean AS (
        SELECT DISTINCT ON (n.s) n.entity_id, n.s, n.weight, n.pri
        FROM rendered n
        WHERE n.s IS NOT NULL AND btrim(n.s) <> '' AND NOT is_all_whitespace(n.s)
          AND position(' ' IN n.s) = 0 AND char_length(n.s) <= 40
          AND n.s ~ '[[:alpha:]]'          -- must carry a letter (no pure punctuation)
          AND n.s !~ '^i[0-9]+$'           -- drop bare ILI concept ids (i46531) — not words
        ORDER BY n.s, n.pri DESC, n.weight DESC
    )
    SELECT c.entity_id, c.s, c.weight FROM clean c ORDER BY c.pri DESC, c.weight DESC LIMIT p_max
$$;

-- native kernel ----------------------------------------------------------------
-- stride_used: the witnessed order that produced the step; 0 = the step came from
-- the COMPLETES_TO consensus floor (no witnessed continuation at any order).
CREATE OR REPLACE FUNCTION walk_continuations(
        p_ctx bytea[], p_steps int DEFAULT 24, p_max_stride int DEFAULT 5,
        p_spread float8 DEFAULT 0.7, p_breadth int DEFAULT 10,
        p_seed bigint DEFAULT NULL)
    RETURNS TABLE(step int, entity bytea, stride_used int, sep_entity bytea)
    AS 'MODULE_PATHNAME', 'pg_laplace_walk_continuations'
    LANGUAGE C VOLATILE;

CREATE OR REPLACE FUNCTION stream_reset() RETURNS boolean
    AS 'MODULE_PATHNAME', 'pg_laplace_stream_reset'
    LANGUAGE C VOLATILE;

-- endpoint surface: prompt text in, rendered tokens out (the signature
-- SubstrateClient.GenerateNgramStreamAsync calls)
CREATE OR REPLACE FUNCTION walk_text(
        p_prompt text, p_steps int DEFAULT 24, p_max_stride int DEFAULT 5,
        p_spread float8 DEFAULT 0.7, p_breadth int DEFAULT 10,
        p_seed bigint DEFAULT NULL)
    RETURNS TABLE(step int, entity text, stride_used int)
    LANGUAGE sql VOLATILE
    SET search_path = @extschema@, public AS $$
    WITH ctx AS (
        SELECT array_agg(id ORDER BY ord) AS ids
        FROM prompt_state(p_prompt) WHERE id IS NOT NULL
    )
    -- the kernel is deterministic given a seed; entropy is the caller's choice,
    -- so an unseeded call draws one here instead of repeating a constant stream.
    -- entity carries the word PLUS its witnessed trailing separator (omniglottal spacing:
    -- Latin space / 。、 / U+3000 / nothing for CJK) — reconstruct text with NO delimiter.
    SELECT g.step,
           render_text(g.entity, 64) || COALESCE(render_text(g.sep_entity, 8), ''),
           g.stride_used
    FROM ctx, walk_continuations(ctx.ids, p_steps, p_max_stride, p_spread, p_breadth,
                              COALESCE(p_seed, (floor(random() * 9e18))::bigint)) g
    WHERE ctx.ids IS NOT NULL
$$;

-- THE generation surface: prompt in, clean witnessed-spacing text out (omniglottal,
-- no detok rules — spacing is the witnessed separators). One call.
CREATE OR REPLACE FUNCTION generate(
        p_prompt text, p_steps int DEFAULT 40, p_max_stride int DEFAULT 5,
        p_spread float8 DEFAULT 0.7, p_breadth int DEFAULT 12,
        p_seed bigint DEFAULT NULL)
    RETURNS text
    LANGUAGE sql VOLATILE
    SET search_path = @extschema@, public AS $$
    SELECT btrim(string_agg(entity, '' ORDER BY step))
    FROM walk_text(p_prompt, p_steps, p_max_stride, p_spread, p_breadth, p_seed)
$$;

-- legacy shim: ranked-μ SQL walk removed; delegate to native stride kernel
CREATE OR REPLACE FUNCTION continue_text(
        p_prompt text, p_steps int DEFAULT 16, p_window int DEFAULT 3,
        p_spread double precision DEFAULT 0.6, p_breadth int DEFAULT 8,
        p_stop text[] DEFAULT '{}', p_boost double precision DEFAULT 0,
        p_require_pos boolean DEFAULT true)
    RETURNS TABLE(step int, entity text, mu numeric)
    LANGUAGE sql VOLATILE
    SET search_path = @extschema@, public AS $$
    SELECT g.step, g.entity, NULL::numeric AS mu
    FROM walk_text(p_prompt, p_steps, GREATEST(p_window, 1), p_spread, p_breadth) g
$$;

-- variant synthesis over witnessed constituency ----------------------------------
-- A content trajectory is a witnessed WHOLE. respell_variant walks a witnessed
-- instance in trajectory order and substitutes COMPOSITE constituents with
-- elected peers. Tokens (tier <= 2) are the floor — never opened, never
-- respelled. Novelty arises only at substitution points, and every substitution
-- is justified by adjudicated testimony; every emitted fragment stays a
-- witnessed whole.
-- Peer election is CONSENSUS-FIRST (Glicko-2 replaces nearest neighbor): a peer
-- is an entity of the same node type co-witnessed in the same typed relation
-- contexts, scored by the weaker of the two adjudicated eff_mu ratings — so
-- uncertain testimony (high RD) cannot elect a peer. Geometry (coord KNN +
-- Fréchet over trajectories) is only the fallback for thinly-witnessed entities.
CREATE OR REPLACE FUNCTION consensus_peer(p_id bytea, p_k int DEFAULT 6)
    RETURNS bytea
    AS 'MODULE_PATHNAME', 'pg_laplace_consensus_peer'
    LANGUAGE C STABLE;

CREATE OR REPLACE FUNCTION variant_walk(p_id bytea, p_swap float8 DEFAULT 0.3,
                          p_k int DEFAULT 6, p_depth int DEFAULT 4)
    RETURNS text
    AS 'MODULE_PATHNAME', 'pg_laplace_variant_walk'
    LANGUAGE C VOLATILE;

CREATE OR REPLACE FUNCTION respell_variant(p_node_type text, p_modality text DEFAULT 'c-sharp',
                     p_substitution_rate float8 DEFAULT 0.3, p_k int DEFAULT 6, p_depth int DEFAULT 4)
    RETURNS text
    AS 'MODULE_PATHNAME', 'pg_laplace_respell_variant'
    LANGUAGE C VOLATILE;
