CREATE OR REPLACE FUNCTION usage_overlap(p_x bytea, p_y bytea)
    RETURNS bigint
    LANGUAGE sql STABLE PARALLEL SAFE STRICT
    SET search_path = @extschema@, public AS $$
    -- Pillar 5 (2026-07-20): shared-usage is read from the GEOMETRY. The usage
    -- neighbourhood of a point is the adjacent content constituent in every
    -- trajectory containing it -- the same knowledge PRECEDES materialised as
    -- redundant attestations (Pillar 3a, e5e1b42). BIDIRECTIONAL, as the
    -- consensus form was: the trajectory holds the exact sequence, so both
    -- directions are readable and the measure is never truncated to fit the walk.
    WITH xn(n) AS (
        SELECT neighbour_id FROM geometry_neighbours(p_x, 200, 8)
    ), yn(n) AS (
        SELECT neighbour_id FROM geometry_neighbours(p_y, 200, 8)
    )
    SELECT count(*)::bigint FROM xn JOIN yn USING (n)
$$;
