DO $idem$ BEGIN
    CREATE TYPE intent_preflight_result AS (
        entity_exists bytea,
        phys_exists   bytea,
        att_exists    bytea
    );
EXCEPTION WHEN duplicate_object THEN NULL;
END $idem$;

CREATE OR REPLACE FUNCTION intent_preflight(
    entity_ids bytea[],
    phys_ids   bytea[],
    att_ids    bytea[])
    RETURNS intent_preflight_result
    AS 'MODULE_PATHNAME', 'pg_laplace_intent_preflight'
    LANGUAGE C STABLE;
