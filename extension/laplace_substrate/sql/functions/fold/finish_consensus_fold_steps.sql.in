CREATE OR REPLACE PROCEDURE finish_consensus_fold_steps(INOUT p_total bigint DEFAULT 0)
    LANGUAGE plpgsql AS $$
DECLARE
    nparts  integer;
    p       integer;
    lane    text;
    rel     record;
    n_round bigint;
    resume  boolean;
    fresh   boolean;
    t0      timestamptz := clock_timestamp();
BEGIN
    p_total := 0;
    PERFORM set_config('search_path', '@extschema@, public', true);
    IF EXISTS (
        SELECT 1 FROM pg_class c JOIN pg_namespace ns ON ns.oid = c.relnamespace
        WHERE ns.nspname = current_schema() AND c.relkind = 'r'
          AND c.relname ~ '^consensus_walk_staging_\d+$')
    THEN
        RAISE EXCEPTION 'finish_consensus_fold_steps: walk journal staged — the walk fold is minutes, use finish_consensus_fold()';
    END IF;
    resume := to_regclass(current_schema() || '.consensus_next') IS NOT NULL;
    SELECT max(substring(c.relname FROM '_(\d+)$')::int) + 1 INTO nparts
    FROM pg_class c JOIN pg_namespace ns ON ns.oid = c.relnamespace
    WHERE ns.nspname = current_schema() AND c.relkind = 'r'
      AND c.relname ~ '^consensus_period_staging_e\d{4}_\d+$';
    IF nparts IS NULL AND NOT resume THEN
        RAISE EXCEPTION 'finish_consensus_fold_steps: nothing staged and no fold in progress';
    END IF;

    IF NOT resume THEN
        IF EXISTS (
            SELECT 1
            FROM pg_class c JOIN pg_namespace ns ON ns.oid = c.relnamespace
            WHERE ns.nspname = current_schema() AND c.relkind = 'r'
              AND c.relname ~ '^consensus_period_staging_e\d{4}_\d+$'
            GROUP BY substring(c.relname FROM 'e(\d{4})_')
            HAVING count(*) <> nparts
                OR max(substring(c.relname FROM '_(\d+)$')::int) + 1 <> nparts)
        THEN
            RAISE EXCEPTION 'finish_consensus_fold_steps: staged epochs disagree on the partition fan-out';
        END IF;
        CREATE TABLE consensus_next (
            id               bytea,
            subject_id       bytea,
            type_id          bytea,
            object_id        bytea,
            rating           bigint,
            rd               bigint,
            volatility       bigint,
            witness_count    bigint,
            last_observed_at timestamptz
        );
        COMMIT;
        PERFORM set_config('search_path', '@extschema@, public', true);
    END IF;

    SELECT NOT EXISTS (SELECT 1 FROM consensus LIMIT 1) INTO fresh;
    lane := COALESCE(NULLIF(current_setting('laplace.fold_lane', true), ''), 'engine');

    IF nparts IS NOT NULL THEN
        FOR p IN 0 .. nparts - 1 LOOP
            EXECUTE 'SET LOCAL session_replication_role = replica';
            n_round := consensus_fold_one_partition(p, nparts, fresh, lane);
            IF n_round > 0 OR EXISTS (
                SELECT 1
                FROM pg_class c JOIN pg_namespace ns ON ns.oid = c.relnamespace
                WHERE ns.nspname = current_schema() AND c.relkind = 'r'
                  AND c.relname ~ format('^consensus_period_staging_e\d{4}_%s$', p))
            THEN
                FOR rel IN
                    SELECT c.relname
                    FROM pg_class c JOIN pg_namespace ns ON ns.oid = c.relnamespace
                    WHERE ns.nspname = current_schema() AND c.relkind = 'r'
                      AND c.relname ~ format('^consensus_period_staging_e\d{4}_%s$', p)
                LOOP
                    EXECUTE format('DROP TABLE %I', rel.relname);
                END LOOP;
                p_total := p_total + n_round;
                COMMIT;
                PERFORM set_config('search_path', '@extschema@, public', true);
                RAISE LOG 'terminal fold (%, resumable): partition %/%: % relations folded at %',
                    lane, p + 1, nparts, n_round, clock_timestamp() - t0;
            END IF;
        END LOOP;
    END IF;

    PERFORM consensus_fold_swap();
    SELECT count(*) INTO p_total FROM consensus;
    RAISE LOG 'terminal fold (resumable): % consensus relations after swap in %',
        p_total, clock_timestamp() - t0;
END;
$$;
