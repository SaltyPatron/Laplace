    ST_MakePoint(0.1, 0.2, 0.3, 0.4),
    laplace_hilbert_decode(laplace_hilbert_encode(ST_MakePoint(0.1, 0.2, 0.3, 0.4)))
) < 1e-8 AS hilbert_roundtrip_close;
