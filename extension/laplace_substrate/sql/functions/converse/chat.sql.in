-- chat(prompt, session, lang, shape, bands, topic, topic2, type_name, elaborate)
-- A conversational turn: a THIN orchestrator over the existing intent machinery.
--
--   ORIENT  the topic is the prompt token whose synset carries the most
--           content-band consensus mass -- a measurement over the graph, not a
--           parse. An explicit p_topic from the caller wins outright.
--   SHAPE   the caller names the read (laplace.query_shapes()); nothing is
--           inferred from how the prompt is phrased.
--   LENS    p_bands selects salience bands. One band-parameterized read now
--           covers what used to be three hardcoded English branches
--           (parts / kinds / causes) and covers the other ten bands with it.
--   CARRY   session is metadata: a turn with no resolvable topic carries the
--           session's last resolved topic. p_elaborate advances through
--           non-empty fact layers.
--   CLOSE   happens at the FRONTEND, not here: every caller (MCP chat tool, HTTP
--           TurnWitness, CLI chat) deposits the prompt (UserPrompt) and response
--           (Response) through the writer spine -- full content mint + evidence +
--           inline fold, proper trust classes. SQL chat() stays read-side; its only
--           write is session_topics app-state.
--
-- The English pattern ladder this function used to run on (parse_ask, plus five
-- inline regexes over the prompt) is gone. It answered only English, in a
-- substrate whose identity law is language-agnostic by construction.
DROP FUNCTION IF EXISTS chat(text, bytea, bytea);

CREATE OR REPLACE FUNCTION chat(p_prompt text,
                                p_session bytea DEFAULT NULL,
                                p_lang bytea DEFAULT NULL,
                                p_shape text DEFAULT NULL,
                                p_bands int[] DEFAULT NULL,
                                p_topic bytea DEFAULT NULL,
                                p_topic2 bytea DEFAULT NULL,
                                p_type_name text DEFAULT NULL,
                                p_elaborate boolean DEFAULT false)
    RETURNS text
    LANGUAGE plpgsql VOLATILE
    SET search_path = @extschema@, public AS $$
DECLARE
    ctx   bytea; topic bytea; topic2 bytea;
    cands bytea[];   -- topic orientation, ranked, computed ONCE per turn
    xl    text;
    depth int;
    layers text[]; s text;
    resolved bytea;
    shape text := NULLIF(btrim(COALESCE(p_shape, '')), '');
    out   text := '';
BEGIN
    IF p_session IS NOT NULL THEN ctx := session_last_resolved(p_session); END IF;

    -- TOPIC = the prompt token whose SYNSET carries the most content-band mass.
    -- Content-band mass ranks the real topic above incidental tokens by counting
    -- witnessed edges -- a graph measurement, so it holds in any language. The
    -- whole ranked candidate list is kept (cands): the segmentation and the
    -- per-candidate band-mass aggregate run ONCE per turn, and topic2 reuses them.
    IF p_topic IS NOT NULL THEN
        topic := p_topic;
    ELSE
        SELECT array_agg(y.syn ORDER BY y.exact_hit DESC NULLS LAST,
                                        y.band_mass DESC,
                                        char_length(y.surface) DESC)
          INTO cands
        FROM (
            SELECT x.syn, x.surface,
                   (lower(realize(x.syn)) = x.surface AND char_length(x.surface) >= 3) AS exact_hit,
                   (SELECT count(*) FROM consensus c WHERE c.subject_id = x.syn
                      AND relation_highway_band(c.type_id) IN (1,2,4,7)) AS band_mass
            FROM (SELECT DISTINCT top_synset(p.id) syn, lower(render_text(p.id,32)) surface
                  FROM prompt_state(p_prompt) p WHERE p.id IS NOT NULL) x
            WHERE x.syn IS NOT NULL
        ) y;
        topic := cands[1];
        -- Nothing in this turn resolved: carry the session's standing topic.
        IF topic IS NULL THEN topic := ctx; END IF;
    END IF;

    IF topic IS NULL THEN
        out := converse(p_prompt);
    ELSE
        resolved := topic;  xl := realize(topic, p_lang);
        topic2 := p_topic2;

        -- Second topic for the two-topic shapes: the caller's, else the next
        -- ranked candidate that is not the first. Reuses the ranking already
        -- computed above rather than re-segmenting the same input.
        IF topic2 IS NULL AND shape IN ('reason', 'is_a') AND cands IS NOT NULL THEN
            SELECT u.syn INTO topic2
            FROM unnest(cands) WITH ORDINALITY u(syn, ord)
            WHERE u.syn <> topic
            ORDER BY u.ord
            LIMIT 1;
        END IF;

        IF p_elaborate AND p_session IS NOT NULL THEN
            -- ELABORATE: advance through NON-EMPTY fact layers by prior mentions.
            layers := ARRAY[]::text[];
            SELECT initcap(xl)||' has parts such as '||string_agg(l,', ' ORDER BY m DESC)||'.'
              INTO s FROM (SELECT realize(c.object_id,p_lang) l,(c.rating-2*c.rd) m
                FROM consensus c WHERE c.subject_id=topic AND relation_highway_band(c.type_id)=4
                ORDER BY (c.rating-2*c.rd) DESC LIMIT 6) z WHERE l IS NOT NULL;
            IF s IS NOT NULL THEN layers := layers||s; END IF;
            SELECT 'Kinds of '||xl||' include '||string_agg(l,', ' ORDER BY m DESC)||'.'
              INTO s FROM (SELECT realize(c.subject_id,p_lang) l,(c.rating-2*c.rd) m
                FROM consensus c WHERE c.object_id=topic AND relation_highway_band(c.type_id)=2
                ORDER BY (c.rating-2*c.rd) DESC LIMIT 8) z WHERE l IS NOT NULL;
            IF s IS NOT NULL THEN layers := layers||s; END IF;
            SELECT initcap(xl)||' is related to '||string_agg(l,' and ' ORDER BY m DESC)||'.'
              INTO s FROM (SELECT realize(c.object_id,p_lang) l,(c.rating-2*c.rd) m
                FROM consensus c WHERE c.subject_id=topic AND relation_highway_band(c.type_id)=7
                ORDER BY (c.rating-2*c.rd) DESC LIMIT 8) z
               WHERE l IS NOT NULL AND l !~ '^[0-9]{6,}-[nvasr]$' AND l !~ '^(noun|verb|adj|adv)\.' AND l !~ ' ' LIMIT 3;
            IF s IS NOT NULL THEN layers := layers||s; END IF;
            SELECT count(*) INTO depth FROM session_topics t
              WHERE t.session_id=p_session AND t.resolved_id=topic;
            out := CASE WHEN depth BETWEEN 1 AND COALESCE(array_length(layers,1),0)
                        THEN layers[depth]
                        ELSE 'That is the core of what I hold about '||xl||'.' END;

        ELSIF p_bands IS NOT NULL AND array_length(p_bands, 1) > 0 THEN
            -- BAND LENS: every edge of the topic inside the selected bands, both
            -- directions, ranked by eff_mu. This one read replaces the former
            -- parts / kinds / causes English branches and generalizes to all 13.
            SELECT string_agg(line, ' ') INTO out FROM (
                SELECT b.name || ': ' || string_agg(z.l, ', ' ORDER BY z.m DESC) || '.' AS line,
                       max(z.m) AS top_m
                FROM (
                    SELECT relation_highway_band(c.type_id) AS band,
                           realize(c.object_id, p_lang) AS l,
                           (c.rating - 2*c.rd) AS m
                    FROM consensus c
                    WHERE c.subject_id = topic
                      AND relation_highway_band(c.type_id) = ANY(p_bands)
                    UNION ALL
                    SELECT relation_highway_band(c.type_id),
                           realize(c.subject_id, p_lang),
                           (c.rating - 2*c.rd)
                    FROM consensus c
                    WHERE c.object_id = topic
                      AND relation_highway_band(c.type_id) = ANY(p_bands)
                ) z
                JOIN relation_band_catalog() b ON b.band = z.band
                WHERE z.l IS NOT NULL
                GROUP BY b.band, b.name
                ORDER BY b.band
            ) q;
            IF out IS NULL OR out = '' THEN
                out := 'I hold no witnessed edges for '||xl||' in the selected bands yet.';
            END IF;

        ELSIF shape = 'reason' AND topic2 IS NOT NULL THEN
            SELECT string_agg(reply, ' ') INTO out
              FROM recall_relation_summary_response(topic, topic2);

        ELSIF shape IN ('related','related_in') AND p_type_name IS NOT NULL THEN
            SELECT string_agg(reply, ' ') INTO out
              FROM recall_intent(shape, topic, NULL, p_type_name);
            IF out IS NULL OR out = '' THEN
                out := 'I hold no witnessed '||lower(p_type_name)||' for '||xl||' yet.';
            END IF;

        ELSIF shape IS NOT NULL AND shape NOT IN ('describe','fallback','walk','what_is') THEN
            -- Any other published shape answers through the shared responder family.
            SELECT string_agg(reply, ' ') INTO out
              FROM recall_intent(shape, topic, topic2, p_type_name);

        ELSE
            -- describe / what_is / walk / fallback and the no-shape default:
            -- the free-form fused walk over the topic already in hand.
            out := CASE WHEN xl IS NOT NULL THEN converse_about(topic)
                        ELSE converse(p_prompt) END;
        END IF;

        IF out IS NULL OR out = '' THEN
            out := CASE WHEN xl IS NOT NULL THEN converse_about(topic)
                        ELSE converse(p_prompt) END;
        END IF;
    END IF;

    -- RECORD session carry; the OODA close (turn witnessing) is the caller's duty.
    IF p_session IS NOT NULL THEN
        PERFORM session_record_prompt(p_session, p_prompt, resolved);
    END IF;

    RETURN btrim(out);
END;
$$;
