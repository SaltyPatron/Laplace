-- laplace_apply_batch — the ONE light set-based merge of a staged batch.
--
-- The C# writer COPYs the client-computed native tuples into three UNLOGGED
-- staging tables named <prefix>entities / <prefix>physicalities /
-- <prefix>attestations (each LIKE laplace.<table>), then calls this once. All
-- the merge logic lives in the C kernel (apply_batch.c) reached through this
-- thin LANGUAGE C binding — zero PL/pgSQL logic, one round trip per batch. The
-- DB does only the light set-based merge; every heavy step (parse / compose /
-- BLAKE3 / geometry / tiers) already ran client-side in laplace_core.
--
-- Returns (entities_inserted, physicalities_inserted, attestations_inserted,
-- attestations_folded, entities_skipped, physicalities_skipped) — skipped counts
-- instrument rows staged but already present (should be ≈0 when descent dedup ran).
CREATE OR REPLACE FUNCTION laplace_apply_batch(p_stage_prefix text)
    RETURNS TABLE (entities_inserted        bigint,
                   physicalities_inserted   bigint,
                   attestations_inserted    bigint,
                   attestations_folded      bigint,
                   entities_skipped         bigint,
                   physicalities_skipped    bigint)
    AS 'MODULE_PATHNAME', 'pg_laplace_apply_batch'
    LANGUAGE C VOLATILE;
