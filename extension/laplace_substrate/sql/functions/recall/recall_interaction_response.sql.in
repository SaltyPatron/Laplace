-- Commonsense-interaction realizer: given an event/concept, surface what the substrate
-- knows it ELICITS — intents, wants, reactions, effects, causes — from the ATOMIC-2020
-- and ConceptNet commonsense relations folded into consensus. This is the "what does
-- this situation lead to" query, the reasoning primitive under grounded conversation:
-- one pull on an event knot returns the taut strands (Glicko-ranked) that answer
-- "and then what / and so others feel". Each relation type maps to a natural connective
-- so the folded edge reads as an inference, not a table row.
CREATE OR REPLACE FUNCTION recall_interaction_response(p_topic bytea, p_limit int DEFAULT 8)
    RETURNS TABLE(reply text, eff_mu numeric, witnesses bigint)
    LANGUAGE sql STABLE PARALLEL SAFE
    SET search_path = @extschema@, public AS $$
    WITH kinds(type_id, phrase) AS (
        VALUES
            (relation_type_id('X_INTENT'),         'intends'),
            (relation_type_id('X_WANT'),           'then wants'),
            (relation_type_id('X_NEED'),           'first needs'),
            (relation_type_id('X_REACT'),          'feels'),
            (relation_type_id('X_EFFECT'),         'then'),
            (relation_type_id('O_WANT'),           'others then want'),
            (relation_type_id('O_REACT'),          'others feel'),
            (relation_type_id('O_EFFECT'),         'for others,'),
            (relation_type_id('CAUSES'),           'causes'),
            (relation_type_id('CAUSES_DESIRE'),    'causes a desire for'),
            (relation_type_id('MOTIVATED_BY_GOAL'),'is motivated by'),
            (relation_type_id('HAS_PREREQUISITE'), 'requires'),
            (relation_type_id('HAS_SUBEVENT'),     'involves'),
            (relation_type_id('OBSTRUCTED_BY'),    'is hindered by')
    ),
    -- edge_rank folds relation salience into the eff_mu ordering so mandate-band
    -- relations outrank probationary ones.
    facts AS (
        SELECT k.phrase,
               c.object_id,
               edge_rank(c.type_id, eff_mu(c.rating, c.rd)) AS rank,
               eff_mu(c.rating, c.rd) AS mu,
               c.witness_count AS witnesses
        FROM v_consensus_unrefuted c
        JOIN kinds k ON k.type_id = c.type_id
        WHERE c.subject_id = p_topic AND c.object_id IS NOT NULL
    ),
    -- Rank BEFORE rendering (Issue-52 pattern): the old shape ran render_text over
    -- the topic's FULL commonsense fan-out and only then ORDER/LIMIT'd to p_limit.
    -- Ranking needs only ids + rank/mu already in `facts`; render_text runs over
    -- exactly the p_limit survivors. Output-identical (no post-render filtering).
    ranked AS (
        SELECT f.phrase, f.object_id, f.rank, f.mu, f.witnesses
        FROM facts f
        ORDER BY f.rank DESC, f.mu DESC
        LIMIT p_limit
    )
    SELECT label(p_topic) || ' — ' || r.phrase || ' ' || render_text(r.object_id, 96) AS reply,
           r.mu AS eff_mu,
           r.witnesses
    FROM ranked r
    ORDER BY r.rank DESC, r.mu DESC
$$;
